---
import Layout from '../layouts/Layout.astro';
import { PHONE, PHONE_HREF } from '../data/site';
---

<Layout
  title="Page Not Found | Ashmead Roofing Supplies Ltd"
  description="The page you're looking for doesn't exist. Find roofing supplies, trade accounts and delivery information at Ashmead Roofing Supplies Ltd."
>

  <section class="section-white min-h-[80vh] flex items-center">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center py-20">

        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-primary/10 mb-8">
          <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>

        <p class="text-primary font-semibold text-sm uppercase tracking-widest mb-3">404 — Page Not Found</p>

        <h1 class="font-heading text-4xl md:text-5xl font-bold uppercase tracking-wide text-charcoal mb-4">
          That Page Doesn't Exist
        </h1>

        <p class="text-body/70 text-lg leading-relaxed mb-10">
          The page you're looking for may have moved or been removed. Try one of the links below, or give us a call — we're easier to reach than this page was.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center mb-14">
          <a href="/" class="inline-flex items-center justify-center gap-2 bg-[#0A5C36] hover:bg-[#0b6b40] text-white font-semibold px-6 py-3 rounded-full transition-colors">
            Back to Home
          </a>
          <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 border-2 border-charcoal/20 hover:border-primary text-charcoal hover:text-primary font-semibold px-6 py-3 rounded-full transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {PHONE}
          </a>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
          {[
            { label: 'Products', href: '/products' },
            { label: 'Areas We Cover', href: '/areas' },
            { label: 'Training', href: '/training' },
            { label: 'Contact', href: '/contact' },
          ].map(link => (
            <a href={link.href} class="bg-section hover:bg-primary/10 border border-border hover:border-primary/30 rounded-xl px-4 py-3 font-semibold text-charcoal hover:text-primary transition-all text-center">
              {link.label}
            </a>
          ))}
        </div>

      </div>
    </div>
  </section>

</Layout>
