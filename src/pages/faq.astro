---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import AnimatedSection from '../components/AnimatedSection.astro';
import SectionLabel from '../components/SectionLabel.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { PHONE, PHONE_HREF, EMAIL, heroImages } from '../data/site';

const faqs = [
  {
    category: "Ordering & Delivery",
    questions: [
      {
        q: "What areas do you deliver to?",
        a: "We deliver roofing supplies across the South West, including Bristol, Bath, Somerset, Gloucestershire and Wiltshire. Same-day collection is available from our Bristol depot, and next-day delivery is available to most postcodes in our coverage area."
      },
      {
        q: "How do I place an order?",
        a: `The quickest way is to call our trade counter on <a href="${PHONE_HREF}" class="text-primary font-semibold hover:underline">${PHONE}</a> — our team can check stock, confirm pricing and arrange delivery in one call. You can also email <a href="mailto:${EMAIL}" class="text-primary font-semibold hover:underline">${EMAIL}</a> or use the quote form on our contact page.`
      },
      {
        q: "Do you offer same-day delivery?",
        a: "Same-day collection is available from our Bristol depot during opening hours. For same-day delivery, call us before 10am and we'll do our best to accommodate — subject to stock availability and your location."
      },
      {
        q: "Is there a minimum order value?",
        a: "No minimum order. Whether you need a single ridge tile or a full roof's worth of materials, we'll sort you out. Delivery charges may apply for smaller orders — call us for details."
      },
      {
        q: "Can I collect from the depot?",
        a: "Yes — our Bristol depot is open Monday to Friday 07:00–16:30. Call ahead to confirm stock and we'll have your order ready to load."
      },
    ]
  },
  {
    category: "Trade Accounts",
    questions: [
      {
        q: "How do I open a trade account?",
        a: `Call us on <a href="${PHONE_HREF}" class="text-primary font-semibold hover:underline">${PHONE}</a> or email <a href="mailto:${EMAIL}" class="text-primary font-semibold hover:underline">${EMAIL}</a> to speak to our accounts team. We'll set you up quickly — most accounts are active within 24 hours.`
      },
      {
        q: "What are the benefits of a trade account?",
        a: "Trade account holders get access to our best pricing, priority service at the trade counter, 30-day credit terms (subject to approval) and a dedicated account contact for quotes and ordering."
      },
      {
        q: "Do you offer credit terms?",
        a: "Yes, 30-day credit terms are available for established trade customers subject to credit approval. Contact us to discuss your requirements."
      },
    ]
  },
  {
    category: "Products & Stock",
    questions: [
      {
        q: "What roofing products do you stock?",
        a: "We carry one of the widest ranges in the South West: concrete and clay tiles, natural and fibre-cement slates, flat roofing systems, breathable membranes, timber battens, lead sheet, guttering, fascias, soffits, roof windows (VELUX and Fakro), fixings and more. If we don't have it, we'll source it."
      },
      {
        q: "Do you stock VELUX roof windows?",
        a: "Yes — we stock a full range of VELUX roof windows, flashings and accessories. Call us with your specification and we'll confirm availability and pricing."
      },
      {
        q: "My tile has been discontinued — can you help?",
        a: "Often yes. Our team has extensive knowledge of tile ranges and can usually find a close match or suitable alternative. Bring a sample to the trade counter or describe the tile and we'll do our best."
      },
      {
        q: "Can you help me specify the right product for my job?",
        a: "Absolutely — this is what we're here for. Our trade counter staff have years of experience across all types of roofing. Call us with the details of your project and we'll recommend the right products."
      },
    ]
  },
  {
    category: "Training",
    questions: [
      {
        q: "Do you offer roofing training courses?",
        a: "Yes — we run hands-on training courses at our Bristol depot covering flat roofing, tiling and other disciplines. Courses are suitable for both new entrants and experienced roofers looking to upskill. Visit our Training page for current availability."
      },
      {
        q: "Who are the training courses suitable for?",
        a: "Our courses are designed for roofers at all stages — from apprentices getting started to experienced contractors who want to add new skills or gain certification in specific product systems."
      },
    ]
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.flatMap(cat =>
    cat.questions.map(faq => ({
      "@type": "Question",
      name: faq.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.a.replace(/<[^>]+>/g, '')
      }
    }))
  )
};
---

<Layout
  title="FAQ — Roofing Supplies Bristol | Ashmead Roofing Supplies Ltd"
  description="Frequently asked questions about ordering roofing supplies, trade accounts, delivery, stock and training at Ashmead Roofing Supplies Ltd, Bristol."
  schema={[faqSchema]}
>

  <Hero
    eyebrow="Help & Information"
    title="Frequently Asked"
    accent="Questions"
    description="Everything you need to know about ordering, delivery, trade accounts and our product range."
    image={heroImages.bristol}
    ctaPrimary={{ label: 'Call Us', href: PHONE_HREF, icon: 'phone' }}
    ctaSecondary={{ label: 'Get a Quote', href: '/contact', icon: 'arrow' }}
    minHeight="min-h-[45vh] md:min-h-[55vh]"
  />

  <section class="section-white section-padding">
    <div class="container">
      <div class="max-w-3xl mx-auto">

        {faqs.map((cat, ci) => (
          <AnimatedSection delay={ci * 0.05} class="mb-14">
            <div class="mb-6">
              <SectionLabel text={cat.category} />
            </div>

            <div class="space-y-3">
              {cat.questions.map((faq, i) => (
                <details class="group bg-section border border-border rounded-2xl overflow-hidden">
                  <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-heading font-bold uppercase tracking-wide text-charcoal text-sm md:text-base select-none hover:text-primary transition-colors">
                    {faq.q}
                    <svg class="w-5 h-5 text-primary shrink-0 transition-transform duration-300 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                  </summary>
                  <div class="px-6 pb-5 pt-1 text-body leading-relaxed border-t border-border" set:html={faq.a} />
                </details>
              ))}
            </div>
          </AnimatedSection>
        ))}

        <AnimatedSection class="bg-[#0B1F3A] rounded-2xl p-8 text-center mt-4">
          <p class="text-white/80 mb-2">Can't find what you're looking for?</p>
          <p class="text-white font-semibold text-lg mb-6">Call our trade team — we're here to help.</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-white text-charcoal font-semibold px-6 py-3 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {PHONE}
            </a>
            <a href="/contact" class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white text-white font-semibold px-6 py-3 transition-colors">
              Send a Message
            </a>
          </div>
        </AnimatedSection>

      </div>
    </div>
  </section>

  <CtaBanner />

</Layout>
