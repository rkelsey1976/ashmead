---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Button from '../../components/Button.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import BrandBar from '../../components/BrandBar.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME } from '../../data/site';
import { products } from '../../data/products';
import { heroImages } from '../../data/site';

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const heroImage = heroImages[product.slug] || heroImages.home;
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: product.name },
];
---

<Layout title={`${product.h1} | Ashmead Roofing Supplies Bristol`} description={product.metaDesc}>
  <!-- Product Hero — diagonal split -->
  <section class="relative overflow-hidden min-h-[400px] md:min-h-[500px]">
    <!-- Right side: image -->
    <div class="absolute inset-0">
      <img src={heroImage} alt="" class="w-full h-full object-cover" loading="eager" />
    </div>
    <!-- Diagonal dark overlay from left -->
    <div class="absolute inset-0 bg-charcoal" style="clip-path: polygon(0 0, 75% 0, 50% 100%, 0 100%)"></div>
    <!-- Green accent line along diagonal -->
    <div class="absolute inset-0" style="clip-path: polygon(74.5% 0, 75.5% 0, 50.5% 100%, 49.5% 100%); background: #009900;"></div>
    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-16 py-16 md:py-24 flex items-center min-h-[400px] md:min-h-[500px]">
      <div class="max-w-2xl">
        <div class="text-white/60 text-sm font-heading uppercase tracking-widest mb-4">
          {breadcrumbItems.map((item, i) => (
            <>{i > 0 && <span class="mx-2">/</span>}<a href={item.href} class="hover:text-white transition-colors">{item.label}</a></>
          ))}
        </div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading uppercase tracking-wide text-primary mb-6">{product.h1}</h1>
        <p class="text-lg text-white/80 mb-8">{product.shortDesc}</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button variant="primary" href="phone" icon="phone" size="lg">Call {PHONE}</Button>
          <a href="/contact" class="inline-block border-2 border-white text-white hover:bg-white hover:text-charcoal font-bold px-8 py-4 rounded transition-colors text-lg text-center">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Content -->
  <section class="section-white section-padding">
    <div class="container">
      <div class="max-w-4xl">
        <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">{product.h1} from Ashmead</h2>
        <div class="prose prose-lg text-body leading-relaxed space-y-4" set:html={product.longDesc} />
      </div>

      {product.brands && product.brands.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Brands We Supply</h2>
          <div class="flex flex-wrap gap-3">
            {product.brands.map(brand => (
              <span class="bg-section-highlight text-charcoal font-heading font-bold uppercase tracking-wide text-sm px-4 py-2 rounded">{brand}</span>
            ))}
          </div>
        </div>
      )}

      {product.applications && product.applications.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Applications</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {product.applications.map(app => (
              <li class="flex items-center gap-2 text-body">
                <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {app}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

  <BrandBar />

  <CtaBanner />
</Layout>