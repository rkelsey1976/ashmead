---
import Layout from '../../layouts/Layout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { products, getProduct } from '../../data/products';
import { areas } from '../../data/areas';
import { PHONE, PHONE_HREF } from '../../data/site';

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.longDesc,
  "brand": product.brands.length > 0 ? product.brands.map(b => ({"@type": "Brand", "name": b})) : undefined,
  "offers": {
    "@type": "Offer",
    "priceCurrency": "GBP",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "LocalBusiness",
      "name": "Ashmead Roofing Supplies Ltd",
      "telephone": "+441179860600"
    }
  }
};
---

<Layout title={product.metaTitle} description={product.metaDescription} schema={[productSchema]}>
  <!-- Product Hero -->
  <section class="bg-section-highlight py-16 md:py-24 border-b-4 border-primary">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-sm text-body mb-6">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/products" class="hover:text-primary transition-colors">Products</a>
        <span class="mx-2">/</span>
        <span class="text-charcoal">{product.name}</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">{product.h1}</h1>
      <p class="text-lg text-body max-w-3xl mb-8">{product.shortDesc}</p>
      <a href={PHONE_HREF} class="inline-flex items-center gap-2 bg-primary hover:bg-primary-hover text-white font-bold px-8 py-4 rounded text-lg transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call {PHONE}
      </a>
    </div>
  </section>

  <!-- Product Details -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">About {product.name}</h2>
          <p class="text-body leading-relaxed mb-8">{product.longDesc}</p>

          <h3 class="text-xl font-bold font-heading uppercase tracking-wide text-charcoal mb-4">Key Features</h3>
          <ul class="space-y-3 mb-8">
            {product.features.map(feature => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-body">{feature}</span>
              </li>
            ))}
          </ul>

          {product.brands.length > 0 && (
            <div class="mb-8">
              <h3 class="text-xl font-bold font-heading uppercase tracking-wide text-charcoal mb-4">Brands We Supply</h3>
              <div class="flex flex-wrap gap-3">
                {product.brands.map(brand => (
                  <span class="bg-primary/10 text-primary text-sm font-bold px-4 py-2 rounded">{brand}</span>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div>
          <div class="bg-white rounded-lg p-6 border border-border sticky top-24 shadow-sm">
            <h3 class="text-xl font-bold font-heading uppercase tracking-wide text-charcoal mb-4">Get a Quote</h3>
            <p class="text-body text-sm mb-6">Call our trade team for pricing, availability and expert advice on {product.name}.</p>
            <a href={PHONE_HREF} class="flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-white font-bold px-6 py-3 rounded transition-colors w-full mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {PHONE}
            </a>
            <a href="/contact" class="flex items-center justify-center border-2 border-primary text-primary hover:bg-primary hover:text-white font-bold px-6 py-3 rounded transition-colors w-full">
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cross-link: Areas this product is available -->
  <section class="bg-section py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal text-center mb-8">{product.name} — Areas We Cover</h2>
      <p class="text-body text-center max-w-2xl mx-auto mb-10">We supply {product.name} across the South West. Click on your area for local pricing, availability and delivery details.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {areas.map(area => (
          <a href={`/areas/${area.slug}`} class="group bg-white rounded-lg p-5 text-center transition-all border border-border hover:border-primary hover:shadow-lg">
            <h3 class="text-charcoal font-heading text-lg font-bold uppercase tracking-wide group-hover:text-primary transition-colors">{area.name}</h3>
            <span class="text-primary text-sm mt-2 inline-block">View supplies →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Cross-link: Other products -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal text-center mb-8">More Products</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {products.filter(p => p.slug !== product.slug).slice(0, 8).map(p => (
          <a href={`/products/${p.slug}`} class="group bg-white rounded-lg p-4 transition-all border border-border hover:border-primary hover:shadow-lg">
            <h3 class="text-charcoal font-heading text-base font-bold uppercase tracking-wide group-hover:text-primary transition-colors">{p.name}</h3>
            <span class="text-primary text-sm">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</Layout>