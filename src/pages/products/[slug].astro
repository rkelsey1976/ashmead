---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Button from '../../components/Button.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import BrandBar from '../../components/BrandBar.astro';
import BrandMarquee from '../../components/BrandMarquee.astro';
import Hero from '../../components/Hero.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME, heroImages } from '../../data/site';
import { products } from '../../data/products';
import { brandByName, brands } from '../../data/brands';

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: product.name },
];

const heroImage = heroImages[product.slug as keyof typeof heroImages] || heroImages.products;
---

<Layout title={`${product.h1} | Ashmead Roofing Supplies Bristol`} description={product.metaDesc}>
  <Hero
    title={product.h1}
    subtitle={product.shortDesc}
    image={heroImage}
    variant="full"
    breadcrumbs={breadcrumbItems}
  >
    <Button variant="primary" href={PHONE_HREF} icon="phone" size="md">Call {PHONE}</Button>
    <Button variant="white" href="/contact" size="md">Get a Quote</Button>
  </Hero>

  {product.brands && product.brands.length > 0 && (
    <BrandMarquee label="Recommended Brands" brands={product.brands.map(name => brandByName[name]).filter(Boolean)} theme="green" />
  )}

  <section class="section-white section-padding">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        {product.image && (
          <div class="rounded-lg overflow-hidden border border-border shadow-sm">
            <img src={product.image} alt={product.name} class="w-full h-auto object-cover" />
          </div>
        )}
        <div class={product.image ? "" : "max-w-4xl"}>
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">{product.h1} from Ashmead</h2>
          <div class="prose prose-lg text-body leading-relaxed space-y-4" set:html={product.longDesc} />
        </div>
      </div>

      {product.applications && product.applications.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Applications</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {product.applications.map(app => (
              <li class="flex items-center gap-2 text-body">
                <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {app}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>