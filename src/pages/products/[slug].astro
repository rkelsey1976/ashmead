---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import BrandMarquee from '../../components/BrandMarquee.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import Hero from '../../components/Hero.astro';
import AnimatedSection from '../../components/AnimatedSection.astro';
import { BUSINESS_NAME, CANONICAL_URL, heroImages } from '../../data/site';
import { brandByName, brands } from '../../data/brands';
import { reader } from '../../lib/reader';
import { getSiteSettings, productImagePath } from '../../lib/siteSettings';
import { areaProducts } from '../../data/areaProducts';
import { areas } from '../../data/areas';

export async function getStaticPaths() {
  const slugs = await reader.collections.products.list();
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const product = await reader.collections.products.read(slug as string);
if (!product) return Astro.redirect('/404');

const { PHONE, PHONE_HREF } = await getSiteSettings();

const localPages = areaProducts
  .filter(ap => ap.productSlug === slug)
  .map(ap => ({ ...ap, area: areas.find(a => a.slug === ap.areaSlug)! }))
  .filter(ap => ap.area);

const heroImage = productImagePath(slug as string) || heroImages.products;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: product.name },
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.h1,
  description: product.shortDesc,
  brand: product.brands?.length ? { "@type": "Brand", name: product.brands[0] } : undefined,
  offers: {
    "@type": "AggregateOffer",
    availability: "https://schema.org/InStock",
    priceCurrency: "GBP",
    seller: { "@type": "LocalBusiness", name: BUSINESS_NAME },
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${CANONICAL_URL}/` },
    { "@type": "ListItem", position: 2, name: "Products", item: `${CANONICAL_URL}/products/` },
    { "@type": "ListItem", position: 3, name: product.name },
  ],
};
---

<Layout title={`${product.h1} | Ashmead Roofing Supplies Bristol`} description={product.metaDescription} schema={[productSchema, breadcrumbSchema]} ogImage={heroImage}>

  <Hero
    eyebrow={product.brands?.[0] ? `Authorised stockist — ${product.brands[0]}` : 'Trade-Grade Product'}
    title={product.name}
    accent="Bristol"
    description={product.shortDesc}
    image={heroImage}
    ctaPrimary={{ label: 'Call for Pricing', href: PHONE_HREF, icon: 'phone' }}
    ctaSecondary={{ label: 'Get a Quote', href: '/contact', icon: 'arrow' }}
    minHeight="min-h-[60vh] md:min-h-[70vh]"
  />

  {product.brands && product.brands.length > 0 && (
    <BrandMarquee label="Recommended Brands" brands={product.brands.map(name => brandByName[name]).filter(Boolean)} theme="green" />
  )}

  <!-- Main content: image | copy | sidebar -->
  <section class="section-white section-padding">
    <div class="container">
      <Breadcrumb items={breadcrumbItems} />

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 items-start mt-10">

        <!-- Product image — sticky -->
        <AnimatedSection class="lg:col-span-4">
          <div class="sticky top-28">
            <div class="overflow-hidden border border-border bg-white">
              <img src={heroImage} alt={product.name} class="w-full h-auto object-cover" loading="eager" />
            </div>

            {product.brands && product.brands.length > 0 && (
              <div class="border border-t-0 border-border bg-section px-5 py-4 flex flex-wrap gap-2">
                {product.brands.map(b => (
                  <span class="text-[10px] font-bold uppercase tracking-[0.18em] text-charcoal border border-border bg-white px-3 py-1">{b}</span>
                ))}
              </div>
            )}
          </div>
        </AnimatedSection>

        <!-- Copy -->
        <div class="lg:col-span-5">
          <AnimatedSection>
            <SectionLabel text="Product Overview" />
            <h2 class="text-charcoal font-heading text-3xl md:text-4xl font-bold uppercase tracking-wide mb-6 leading-tight">
              {product.h1}
            </h2>
            <div class="prose prose-lg text-body leading-relaxed space-y-4" set:html={product.longDesc} />
          </AnimatedSection>

          {product.features && product.features.length > 0 && (
            <AnimatedSection delay={0.1} class="mt-10">
              <div class="border-t border-border pt-8">
                <h3 class="text-charcoal font-heading text-sm font-bold uppercase tracking-[0.2em] mb-6">Key Features</h3>
                <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-3">
                  {product.features.map((feature, i) => (
                    <li class="flex items-start gap-3">
                      <span class="text-[10px] font-bold text-accent font-heading tabular-nums mt-1 flex-shrink-0">{String(i + 1).padStart(2, '0')}</span>
                      <span class="text-body text-sm leading-snug">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </AnimatedSection>
          )}
        </div>

        <!-- Sticky sidebar CTA -->
        <AnimatedSection delay={0.15} class="lg:col-span-3">
          <div class="sticky top-28 space-y-3">

            <!-- Phone CTA -->
            <div class="bg-charcoal p-6">
              <p class="text-white/40 text-[10px] font-semibold uppercase tracking-[0.22em] font-body mb-1">Call for pricing</p>
              <a href={PHONE_HREF} class="block font-heading font-bold text-accent hover:text-white transition-colors duration-300 leading-none mb-5"
                 style="font-size: clamp(1.3rem, 2.5vw, 1.6rem)">{PHONE}</a>

              <ul class="space-y-2.5 mb-6 border-t border-white/10 pt-5">
                {[
                  `Trade pricing on ${product.name.toLowerCase()}`,
                  'Stock held at Keynsham depot',
                  'Next-day delivery available',
                  'Expert specification advice',
                ].map(point => (
                  <li class="flex items-start gap-2 text-white/65 text-xs font-body leading-snug">
                    <svg class="w-3.5 h-3.5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {point}
                  </li>
                ))}
              </ul>

              <div class="flex flex-col gap-2">
                <a href={PHONE_HREF}
                   class="flex items-center justify-center gap-2 bg-accent text-charcoal font-heading font-bold uppercase tracking-wide text-xs px-4 py-3 hover:bg-white transition-colors duration-300">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  Call Now
                </a>
                <a href="/contact"
                   class="flex items-center justify-center gap-2 border border-white/20 text-white font-heading font-bold uppercase tracking-wide text-xs px-4 py-3 hover:border-white hover:bg-white/5 transition-all duration-300">
                  Get a Quote
                </a>
              </div>
            </div>

            <!-- Back to products -->
            <a href="/products"
               class="flex items-center gap-2 border border-border text-body text-xs font-semibold uppercase tracking-wider px-4 py-3 hover:border-primary hover:text-primary transition-colors duration-200">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              All Products
            </a>

          </div>
        </AnimatedSection>

      </div>
    </div>
  </section>

  {localPages.length > 0 && (
    <section class="section-grey section-padding">
      <div class="container">
        <AnimatedSection>
          <SectionLabel text="Local Supply" />
          <h2 class="text-charcoal font-heading text-2xl md:text-3xl font-bold uppercase tracking-wide mb-2">
            {product.name} by Area
          </h2>
          <p class="text-body mb-8">Local information, delivery details and area-specific advice for your county.</p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {localPages.map(lp => (
              <a href={`/areas/${lp.areaSlug}/products/${lp.productSlug}`}
                 class="group flex items-center justify-between gap-4 bg-white border border-border p-5 hover:border-primary hover:shadow-md transition-all duration-200">
                <div>
                  <p class="text-charcoal font-heading font-bold uppercase tracking-wide text-sm group-hover:text-primary transition-colors">{lp.h1}</p>
                  <p class="text-body text-xs mt-1 line-clamp-2">{lp.intro}</p>
                </div>
                <svg class="w-5 h-5 text-body-light group-hover:text-primary transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ))}
          </div>
        </AnimatedSection>
      </div>
    </section>
  )}

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>
