---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Button from '../../components/Button.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import BrandBar from '../../components/BrandBar.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME } from '../../data/site';
import { products } from '../../data/products';

const logoMap: Record<string, string> = {
  "Redland": "/images/logos/redland.svg",
  "Marley": "/images/logos/marley.svg",
  "Velux": "/images/logos/velux.svg",
  "Kober": "/images/logos/kober.png",
  "Kytun": "/images/logos/kytun.svg",
  "A. Proctor Group": "/images/logos/a-proctor-group.svg",
  "Rockwool": "/images/logos/rockwool.jpg",
  "Roto": "/images/logos/roto.png",
  "FloPlast": "/images/logos/floplast.png",
  "British Lead Mills": "/images/logos/british-lead-mills.svg",
  "Cupa Pizarras": "/images/logos/cupa-pizarras.jpg",
};

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: product.name },
];
---

<Layout title={`${product.h1} | Ashmead Roofing Supplies Bristol`} description={product.metaDesc}>
  <section class="bg-section-highlight py-12 md:py-16">
    <div class="container">
      <div class="text-body/60 text-sm font-heading uppercase tracking-widest mb-3">
        {breadcrumbItems.map((item, i) => (
          <>{i > 0 && <span class="mx-2">/</span>}<a href={item.href} class="hover:text-primary transition-colors">{item.label}</a></>
        ))}
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading uppercase tracking-wide text-charcoal mb-4">{product.h1}</h1>
      <p class="text-lg text-body max-w-4xl mb-6">{product.shortDesc}</p>
      <div class="flex flex-col sm:flex-row gap-3">
        <Button variant="primary" href="phone" icon="phone" size="md">Call {PHONE}</Button>
        <a href="/contact" class="inline-block bg-white hover:bg-gray-100 text-charcoal font-bold px-6 py-3 rounded border-2 border-charcoal transition-colors text-base text-center">Contact Us</a>
      </div>
    </div>
  </section>

  {product.brands && product.brands.length > 0 && (
    <div class="bg-primary border-t border-white/10">
      <div class="container py-4">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <span class="text-xs md:text-sm text-white font-medium uppercase tracking-wider text-center sm:text-left">Recommended Brands</span>
          <div class="flex flex-wrap items-center justify-center gap-6 md:gap-8">
            {product.brands.map(brand => (
              logoMap[brand] && <img src={logoMap[brand]} alt={brand} class="h-7 md:h-8 w-auto object-contain" />
            ))}
          </div>
        </div>
      </div>
    </div>
  )}

  <section class="section-white section-padding">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        {product.image && (
          <div class="rounded-lg overflow-hidden border border-border shadow-sm">
            <img src={product.image} alt={product.name} class="w-full h-auto object-cover" />
          </div>
        )}
        <div class={product.image ? "" : "max-w-4xl"}>
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">{product.h1} from Ashmead</h2>
          <div class="prose prose-lg text-body leading-relaxed space-y-4" set:html={product.longDesc} />
        </div>
      </div>

      {product.applications && product.applications.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Applications</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {product.applications.map(app => (
              <li class="flex items-center gap-2 text-body">
                <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {app}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

  <BrandBar />

  <CtaBanner />
</Layout>