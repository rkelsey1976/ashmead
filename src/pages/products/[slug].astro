---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Button from '../../components/Button.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import AreaCard from '../../components/AreaCard.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products, getProduct } from '../../data/products';
import { areas } from '../../data/areas';
import { PHONE, heroImages } from '../../data/site';

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
const heroImage = heroImages[product.slug as keyof typeof heroImages] || heroImages.home;

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.longDesc,
  "brand": product.brands.length > 0 ? product.brands.map(b => ({"@type": "Brand", "name": b})) : undefined,
  "offers": {
    "@type": "Offer",
    "priceCurrency": "GBP",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "LocalBusiness",
      "name": "Ashmead Roofing Supplies Ltd",
      "telephone": "+441179860600"
    }
  }
};

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: product.name, href: `/products/${product.slug}` }
];
---

<Layout title={product.metaTitle} description={product.metaDescription} schema={[productSchema]}>
  <!-- Product Hero — split layout: charcoal text left, image right -->
  <section class="overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[320px]">
        <div class="bg-charcoal flex flex-col justify-center px-8 py-16 md:px-16 md:py-20 lg:py-24">
          <div class="text-white/60 text-sm font-heading uppercase tracking-widest mb-4">
            {breadcrumbItems.map((item, i) => (
              <>{i > 0 && <span class="mx-2">/</span>}<a href={item.href} class="hover:text-white transition-colors">{item.label}</a></>
            ))}
          </div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading uppercase tracking-wide text-primary mb-6">{product.h1}</h1>
          <p class="text-lg text-white/80 mb-8">{product.shortDesc}</p>
          <div class="flex flex-col sm:flex-row gap-4">
            <Button variant="white" href="phone" icon="phone" size="lg">Call {PHONE}</Button>
            <a href="/contact" class="inline-block border-2 border-white text-white hover:bg-white hover:text-charcoal font-bold px-8 py-4 rounded transition-colors text-lg text-center">Contact Us</a>
          </div>
        </div>
        <div class="hidden lg:block relative bg-charcoal/50">
          <img src={heroImage} alt={product.name} class="absolute inset-0 w-full h-full object-cover" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- Product Details -->
  <section class="section-white section-padding">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">About {product.name}</h2>
          <p class="text-body leading-relaxed mb-8">{product.longDesc}</p>

          <h3 class="text-xl font-bold font-heading uppercase tracking-wide text-charcoal mb-4">Key Features</h3>
          <ul class="space-y-3 mb-8">
            {product.features.map(feature => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-body">{feature}</span>
              </li>
            ))}
          </ul>

          {product.brands.length > 0 && (
            <div class="mb-8">
              <h3 class="text-xl font-bold font-heading uppercase tracking-wide text-charcoal mb-4">Brands We Supply</h3>
              <div class="flex flex-wrap gap-3">
                {product.brands.map(brand => (
                  <span class="bg-primary/10 text-primary text-sm font-bold px-4 py-2 rounded">{brand}</span>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div>
          <div class="bg-white rounded-lg p-6 border border-border sticky top-24 shadow-sm">
            <h3 class="text-xl font-bold font-heading uppercase tracking-wide text-charcoal mb-4">Get a Quote</h3>
            <p class="text-body text-sm mb-6">Call our trade team for pricing, availability and expert advice on {product.name}.</p>
            <div class="space-y-3">
              <Button variant="primary" href="phone" icon="phone" size="md" class="w-full flex">Call {PHONE}</Button>
              <a href="/contact" class="flex items-center justify-center border-2 border-primary text-primary hover:bg-primary hover:text-white font-bold px-8 py-4 rounded transition-colors w-full">Contact Us</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cross-link: Areas this product is available -->
  <section class="section-grey section-padding">
    <div class="container">
      <SectionHeading text={`${product.name} — Areas We Cover`} />
      <p class="text-body text-center max-w-2xl mx-auto mb-10">We supply {product.name} across the South West. Click on your area for local pricing, availability and delivery details.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {areas.map(area => (
          <AreaCard name={area.name} shortDesc="" href={`/areas/${area.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <!-- Cross-link: Other products -->
  <section class="section-white section-padding">
    <div class="container">
      <SectionHeading text="More Products" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {products.filter(p => p.slug !== product.slug).slice(0, 8).map(p => (
          <ProductCard name={p.name} shortDesc={p.shortDesc} href={`/products/${p.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</Layout>