---
import Layout from '../../layouts/Layout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import ProductCard from '../../components/ProductCard.astro';
import BrandMarquee from '../../components/BrandMarquee.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import AnimatedSection from '../../components/AnimatedSection.astro';
import { PHONE, PHONE_HREF, heroImages } from '../../data/site';
import { products } from '../../data/products';
import { brands } from '../../data/brands';
---

<Layout title="Roofing Products Bristol | Tiles, Slates, Membranes & More | Ashmead" description="Browse our full range of roofing supplies. Concrete tiles, clay tiles, slates, flat roofing, membranes, battens, fixings, guttering & more. Call 0117 986 0600.">
  
  <!-- Hero -->
  <section class="relative min-h-[60vh] md:min-h-[70vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImages.products} alt="Roofing products stacked at Ashmead Roofing Supplies depot" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-charcoal via-charcoal/90 to-charcoal/40"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/40 to-charcoal/40"></div>
    </div>
    
    <div class="container relative z-10 py-20 md:py-28">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm text-white px-4 py-2 rounded-md text-sm font-semibold uppercase tracking-wider mb-6 border border-white/20">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Full Trade Range
        </div>
        
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-bold uppercase leading-[0.92] tracking-wide text-white mb-6">
          Roofing
          <span class="block text-accent">Products</span>
        </h1>
        
        <p class="text-lg md:text-xl text-white/80 max-w-2xl mb-10 leading-relaxed">
          Browse our complete range of professional roofing supplies. From tiles and slates to flat roof systems, membranes, battens and fixings — all stocked at our Bristol trade counter.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-white font-semibold px-8 py-4 rounded-md transition-all hover:shadow-lg text-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call {PHONE}
          </a>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white text-white hover:bg-white hover:text-charcoal font-semibold px-8 py-4 rounded-md transition-all text-lg">
            Get a Quote
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Product grid -->
  <section class="section-white section-padding">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-end mb-14">
        <AnimatedSection>
          <SectionLabel text="Our Range" />
          <h2 class="text-charcoal font-heading text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-wide leading-[0.95]">
            Trade-Roofing
            <span class="block text-primary">Products</span>
          </h2>
        </AnimatedSection>
        
        <AnimatedSection class="lg:text-right">
          <p class="text-body text-lg leading-relaxed">
            Every product we stock is chosen for proven performance on South West roofs. Need help specifying? Call the trade team.
          </p>
        </AnimatedSection>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {products.map((product, i) => (
          <AnimatedSection delay={i * 0.05}>
            <ProductCard name={product.name} shortDesc={product.shortDesc} href={`/products/${product.slug}`} brands={product.brands} image={product.image} />
          </AnimatedSection>
        ))}
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>
