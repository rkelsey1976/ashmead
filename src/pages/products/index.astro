---
import Layout from '../../layouts/Layout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import ProductCard from '../../components/ProductCard.astro';
import BrandMarquee from '../../components/BrandMarquee.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import Hero from '../../components/Hero.astro';
import AnimatedSection from '../../components/AnimatedSection.astro';
import { heroImages } from '../../data/site';
import { brands } from '../../data/brands';
import { reader } from '../../lib/reader';
import { getSiteSettings, productImagePath } from '../../lib/siteSettings';

const { PHONE_HREF } = await getSiteSettings();

const slugs = await reader.collections.products.list();
const products = (await Promise.all(
  slugs.map(async slug => {
    const data = await reader.collections.products.read(slug);
    return data ? { slug, ...data, image: productImagePath(slug) } : null;
  })
)).filter(Boolean) as { slug: string; name: string; shortDesc: string; brands: string[]; image: string }[];
---

<Layout title="Roofing Products Bristol | Tiles, Slates, Membranes & More | Ashmead" description="Browse our full range of roofing supplies. Concrete tiles, clay tiles, slates, flat roofing, membranes, battens, fixings, guttering & more. Call 0117 986 0600.">

  <Hero
    eyebrow="Complete Roofing Systems"
    title="Everything"
    accent="On the Roof"
    description="Tiles, slates, membranes, battens, fixings and ventilation — all from brands roofers trust, stocked at our Bristol trade counter."
    image={heroImages.products}
    ctaPrimary={{ label: 'Call for Pricing', href: PHONE_HREF, icon: 'phone' }}
    ctaSecondary={{ label: 'Browse the Range', href: '#product-categories', icon: 'arrow' }}
    minHeight="min-h-[55vh] md:min-h-[65vh]"
  />

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Product grid -->
  <section class="section-white section-padding">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-end mb-14">
        <AnimatedSection>
          <SectionLabel text="Our Range" />
          <h2 class="text-charcoal font-heading text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-wide leading-[0.95]">
            Trade-Roofing
            <span class="block text-primary">Products</span>
          </h2>
        </AnimatedSection>

        <AnimatedSection class="lg:text-right">
          <p class="text-body text-lg leading-relaxed">
            Every product we stock is chosen for proven performance on South West roofs. Need help specifying? Call the trade team.
          </p>
        </AnimatedSection>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {products.map((product, i) => (
          <AnimatedSection delay={i * 0.05}>
            <ProductCard name={product.name} shortDesc={product.shortDesc} href={`/products/${product.slug}`} brands={product.brands} image={product.image} />
          </AnimatedSection>
        ))}
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>
