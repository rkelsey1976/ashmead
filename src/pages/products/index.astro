---
import Layout from '../../layouts/Layout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import ProductCard from '../../components/ProductCard.astro';
import BrandMarquee from '../../components/BrandMarquee.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import Hero from '../../components/Hero.astro';
import AnimatedSection from '../../components/AnimatedSection.astro';
import { heroImages } from '../../data/site';
import { brands } from '../../data/brands';
import { reader } from '../../lib/reader';
import { getSiteSettings, productImagePath } from '../../lib/siteSettings';

const { PHONE_HREF } = await getSiteSettings();

const slugs = await reader.collections.products.list();
const allProducts = (await Promise.all(
  slugs.map(async slug => {
    const data = await reader.collections.products.read(slug);
    return data ? { slug, ...data, image: productImagePath(slug) } : null;
  })
)).filter(Boolean) as { slug: string; name: string; shortDesc: string; brands: string[]; image: string }[];

const CATEGORIES = [
  {
    id: 'pitched',
    label: 'Pitched Roofing',
    description: 'Tiles, slates, underlays and everything that goes on top.',
    slugs: ['concrete-tiles', 'clay-tiles', 'slates', 'pitched-roof-membranes', 'roofing-battens', 'nails-and-fixings'],
  },
  {
    id: 'flat',
    label: 'Flat Roofing',
    description: 'Single-ply membranes, EPDM systems and flat roof accessories.',
    slugs: ['flat-roof-membranes', 'classicbond', 'duopoly', 'resitrix', 'fatra'],
  },
  {
    id: 'building',
    label: 'Building Products',
    description: 'Guttering, insulation, ventilation, roof windows and lead work.',
    slugs: ['fascias-and-guttering', 'insulation', 'ventilation-products', 'roof-windows', 'lead-products', 'calor-gas'],
  },
];

const productsBySlug = Object.fromEntries(allProducts.map(p => [p.slug, p]));
---

<Layout title="Roofing Products Bristol | Tiles, Slates, Membranes & More | Ashmead" description="Browse our full range of roofing supplies. Concrete tiles, clay tiles, slates, flat roofing, membranes, battens, fixings, guttering & more. Call 0117 986 0600.">

  <Hero
    eyebrow="Complete Roofing Systems"
    title="Everything"
    accent="On the Roof"
    description="Tiles, slates, membranes, battens, fixings and ventilation — all from brands roofers trust, stocked at our Bristol trade counter."
    image={heroImages.products}
    ctaPrimary={{ label: 'Call for Pricing', href: PHONE_HREF, icon: 'phone' }}
    ctaSecondary={{ label: 'Browse the Range', href: '#pitched', icon: 'arrow' }}
    minHeight="min-h-[55vh] md:min-h-[65vh]"
  />

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Category quick-nav -->
  <div class="sticky top-[61px] z-30 bg-white border-b border-border shadow-sm">
    <div class="container">
      <nav class="flex gap-1 py-3 overflow-x-auto scrollbar-none" aria-label="Product categories">
        {CATEGORIES.map(cat => (
          <a
            href={`#${cat.id}`}
            class="flex-shrink-0 px-5 py-2 text-sm font-semibold font-body text-body border border-border hover:border-primary hover:text-primary hover:bg-primary/5 transition-all duration-200 whitespace-nowrap"
          >
            {cat.label}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Category sections -->
  {CATEGORIES.map((cat, catIndex) => {
    const catProducts = cat.slugs.map(s => productsBySlug[s]).filter(Boolean);
    return (
      <section
        id={cat.id}
        class={catIndex % 2 === 0 ? 'section-white section-padding' : 'section-grey section-padding'}
      >
        <div class="container">
          <!-- Category header -->
          <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
            <AnimatedSection>
              <SectionLabel text={`0${catIndex + 1}`} />
              <h2 class="text-charcoal font-heading text-3xl md:text-4xl lg:text-5xl font-bold uppercase tracking-wide leading-tight">
                {cat.label}
              </h2>
              <p class="text-body mt-2">{cat.description}</p>
            </AnimatedSection>
          </div>

          <!-- Product grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {catProducts.map((product, i) => (
              <AnimatedSection delay={i * 0.07} class="h-full">
                <ProductCard
                  name={product.name}
                  shortDesc={product.shortDesc}
                  href={`/products/${product.slug}`}
                  brands={product.brands}
                  image={product.image}
                  variant="vertical"
                  index={i}
                />
              </AnimatedSection>
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />

</Layout>
