---
import Layout from '../../layouts/Layout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products';
import { brands } from '../../data/brands';
---

<Layout title="Roofing Products Bristol | Tiles, Slates, Membranes & More | Ashmead" description="Browse our full range of roofing supplies. Concrete tiles, clay tiles, slates, flat roofing, membranes, battens, fixings, guttering & more. Call 0117 986 0600.">
  <section class="bg-section-highlight py-12 md:py-16">
    <div class="container">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading uppercase tracking-wide text-charcoal mb-4">Roofing Products</h1>
      <p class="text-lg text-body max-w-4xl mb-0">Browse our complete range of professional roofing supplies, from tiles and slates to flat roof systems and fixings.</p>
    </div>
  </section>

  <div class="bg-primary border-t border-white/10">
    <div class="container py-3 md:py-4">
      <div class="overflow-x-auto scrollbar-hide">
        <div class="flex items-center gap-8 md:gap-12" style="width: max-content; min-width: calc(100% + 4rem);">
          <span class="text-xs md:text-sm text-white font-medium uppercase tracking-wider whitespace-nowrap">Brands We Supply</span>
          {brands.map(brand => (
            brand.logo && (
              <a
                href={brand.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex-shrink-0 inline-flex items-center h-10 md:h-12 px-4"
                aria-label={brand.name}
              >
                <img src={brand.logo} alt={brand.name} class="h-full w-auto object-contain" />
              </a>
            )
          ))}
        </div>
      </div>
    </div>
  </div>

  <style>
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <section class="section-white section-padding">
    <div class="container">
      <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-charcoal mb-10 text-center">Our Range</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {products.map(product => (
          <ProductCard name={product.name} shortDesc={product.shortDesc} href={`/products/${product.slug}`} brands={product.brands} image={product.image} />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</Layout>