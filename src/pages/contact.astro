---
import Layout from '../layouts/Layout.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME, EMAIL } from '../data/site';
import { products } from '../data/products';
import { areas } from '../data/areas';
---

<Layout title="Contact Ashmead Roofing Supplies | Call 0117 986 0600" description="Contact Ashmead Roofing Supplies Ltd in Bristol. Call 0117 986 0600 for trade pricing, expert advice and fast delivery across the South West.">
  <!-- Contact Hero -->
  <section class="bg-gradient-to-br from-primary via-section to-primary py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="text-3xl md:text-5xl font-bold font-heading uppercase tracking-wide text-heading mb-6">Contact Us</h1>
      <p class="text-lg text-body max-w-3xl mb-8">Get in touch with our trade team for pricing, availability and expert advice. We're here to help professional roofers across the South West.</p>
      <a href={PHONE_HREF} class="inline-flex items-center gap-2 bg-accent hover:bg-accent-light text-white font-bold px-8 py-4 rounded text-lg transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call {PHONE}
      </a>
    </div>
  </section>

  <section class="bg-primary py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-heading mb-6">Send Us a Message</h2>
          <form name="contact" method="POST" data-netlify="true" class="space-y-6">
            <input type="hidden" name="form-name" value="contact" />
            <div>
              <label for="name" class="block text-heading font-heading font-bold uppercase tracking-wide text-sm mb-2">Name</label>
              <input type="text" id="name" name="name" required class="w-full bg-card border border-card rounded px-4 py-3 text-heading placeholder-body/60 focus:outline-none focus:border-accent transition-colors" placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="block text-heading font-heading font-bold uppercase tracking-wide text-sm mb-2">Email</label>
              <input type="email" id="email" name="email" required class="w-full bg-card border border-card rounded px-4 py-3 text-heading placeholder-body/60 focus:outline-none focus:border-accent transition-colors" placeholder="your@email.com" />
            </div>
            <div>
              <label for="phone" class="block text-heading font-heading font-bold uppercase tracking-wide text-sm mb-2">Phone</label>
              <input type="tel" id="phone" name="phone" class="w-full bg-card border border-card rounded px-4 py-3 text-heading placeholder-body/60 focus:outline-none focus:border-accent transition-colors" placeholder="Your phone number" />
            </div>
            <div>
              <label for="product" class="block text-heading font-heading font-bold uppercase tracking-wide text-sm mb-2">Product Interest</label>
              <select id="product" name="product" class="w-full bg-card border border-card rounded px-4 py-3 text-heading focus:outline-none focus:border-accent transition-colors">
                <option value="">Select a product (optional)</option>
                {products.map(p => (
                  <option value={p.name}>{p.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="message" class="block text-heading font-heading font-bold uppercase tracking-wide text-sm mb-2">Message</label>
              <textarea id="message" name="message" rows="5" required class="w-full bg-card border border-card rounded px-4 py-3 text-heading placeholder-body/60 focus:outline-none focus:border-accent transition-colors resize-y" placeholder="Tell us about your project..."></textarea>
            </div>
            <button type="submit" class="w-full bg-accent hover:bg-accent-light text-white font-bold px-8 py-4 rounded text-lg transition-colors">Send Message</button>
          </form>
        </div>

        <!-- Contact Details -->
        <div>
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-heading mb-6">Get in Touch</h2>

          <div class="space-y-6 mb-8">
            <div class="bg-card rounded-lg p-6 border border-card">
              <h3 class="text-heading font-heading font-bold uppercase tracking-wide mb-2">Phone</h3>
              <a href={PHONE_HREF} class="text-accent hover:text-accent-light text-2xl font-bold transition-colors">{PHONE}</a>
              <p class="text-body text-sm mt-1">Call us for pricing, advice and orders</p>
            </div>

            <div class="bg-card rounded-lg p-6 border border-card">
              <h3 class="text-heading font-heading font-bold uppercase tracking-wide mb-2">Email</h3>
              <a href={`mailto:${EMAIL}`} class="text-accent hover:text-accent-light text-lg font-bold transition-colors">{EMAIL}</a>
              <p class="text-body text-sm mt-1">We aim to respond within 24 hours</p>
            </div>

            <div class="bg-card rounded-lg p-6 border border-card">
              <h3 class="text-heading font-heading font-bold uppercase tracking-wide mb-2">Depot</h3>
              <p class="text-heading font-bold">{BUSINESS_NAME}</p>
              <p class="text-body text-sm mt-1">Bristol, South West England</p>
            </div>
          </div>

          <h3 class="text-heading font-heading font-bold uppercase tracking-wide mb-3">Areas We Deliver To</h3>
          <div class="flex flex-wrap gap-2">
            {areas.map(area => (
              <a href={`/areas/${area.slug}`} class="bg-accent/20 text-accent text-sm font-medium px-3 py-1 rounded hover:bg-accent/30 transition-colors">{area.name}</a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Product Links -->
  <section class="bg-section py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-heading text-center mb-8">Our Products</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {products.map(p => (
          <a href={`/products/${p.slug}`} class="group bg-card rounded-lg p-4 text-center hover:bg-card/80 transition-all border border-card hover:border-accent/50">
            <h3 class="text-heading font-heading text-sm font-bold uppercase tracking-wide group-hover:text-accent transition-colors">{p.name}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>