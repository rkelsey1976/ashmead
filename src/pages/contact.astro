---
import Layout from '../layouts/Layout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Hero from '../components/Hero.astro';
import AnimatedSection from '../components/AnimatedSection.astro';
import Testimonials from '../components/Testimonials.astro';
import BrandMarquee from '../components/BrandMarquee.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME, EMAIL, ADDRESS, POSTCODE, heroImages } from '../data/site';
import { products } from '../data/products';
import { areas } from '../data/areas';
import { brands } from '../data/brands';

const openingHours = [
  { day: 'Monday', hours: '07:30 – 17:00' },
  { day: 'Tuesday', hours: '07:30 – 17:00' },
  { day: 'Wednesday', hours: '07:30 – 17:00' },
  { day: 'Thursday', hours: '07:30 – 17:00' },
  { day: 'Friday', hours: '07:30 – 17:00' },
  { day: 'Saturday', hours: '08:00 – 12:00' },
  { day: 'Sunday', hours: 'Closed' },
];
---

<Layout title="Contact Ashmead Roofing Supplies | Call 0117 986 0600" description="Contact Ashmead Roofing Supplies Ltd in Bristol. Call 0117 986 0600 for trade pricing, expert advice and fast delivery across the South West.">
  
  <Hero
    eyebrow="Trade Counter Open Six Days"
    title="Start Your"
    accent="Order Today"
    description="Call, email or visit our Bristol depot. Our team has pricing, stock levels and technical advice ready for roofers and builders across the South West."
    image={heroImages.contact}
    ctaPrimary={{ label: 'Call the Team', href: PHONE_HREF, icon: 'phone' }}
    ctaSecondary={{ label: 'Get a Quote', href: '#contact-form', icon: 'arrow' }}
    minHeight="min-h-[55vh] md:min-h-[65vh]"
  />

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Contact cards -->
  <section class="section-white section-padding">
    <div class="container">
      <div class="grid md:grid-cols-3 gap-6 mb-16">
        <AnimatedSection>
          <a href={PHONE_HREF} class="group block bg-charcoal p-6 md:p-8 rounded-2xl text-white hover:bg-charcoal/90 transition-colors h-full">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 rounded-lg bg-white/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <span class="text-sm font-semibold uppercase tracking-wide">Phone</span>
            </div>
            <p class="text-2xl font-bold font-heading">{PHONE}</p>
            <p class="text-white/70 text-sm mt-2">Speak directly to our trade counter team.</p>
          </a>
        </AnimatedSection>
        
        <AnimatedSection delay={0.05}>
          <a href={`mailto:${EMAIL}`} class="group block bg-primary p-6 md:p-8 rounded-2xl text-white hover:bg-primary-hover transition-colors h-full">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 rounded-lg bg-white/20 flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <span class="text-sm font-semibold uppercase tracking-wide">Email</span>
            </div>
            <p class="text-xl font-bold font-heading break-words">{EMAIL}</p>
            <p class="text-white/80 text-sm mt-2">We aim to respond within 24 hours.</p>
          </a>
        </AnimatedSection>
        
        <AnimatedSection delay={0.1}>
          <div class="bg-section p-6 md:p-8 rounded-2xl h-full">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 rounded-lg bg-white flex items-center justify-center">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <span class="text-sm font-semibold uppercase tracking-wide text-charcoal">Depot</span>
            </div>
            
            <p class="text-charcoal font-bold font-heading">{BUSINESS_NAME}</p>
            <p class="text-body text-sm mt-2">{ADDRESS}, Bristol, {POSTCODE}</p>
          </div>
        </AnimatedSection>
      </div>

      <div class="grid lg:grid-cols-3 gap-10 lg:gap-12">
        <!-- Contact Form -->
        <AnimatedSection class="lg:col-span-2">
          <SectionLabel text="Send a Message" />
          
          <h2 class="text-charcoal font-heading text-3xl md:text-4xl font-bold uppercase tracking-wide mb-2">Request a Quote</h2>
          
          <p class="text-body mb-8">Tell us what you need and our trade team will get back to you with pricing, availability and delivery options.</p>

          <form name="contact" method="POST" data-netlify="true" class="space-y-5">
            <input type="hidden" name="form-name" value="contact" />
            
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Name *</label>
                <input type="text" id="name" name="name" required class="w-full bg-white border border-border rounded-lg px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="Your name" />
              </div>
              <div>
                <label for="company" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Company</label>
                <input type="text" id="company" name="company" class="w-full bg-white border border-border rounded-lg px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="Your company" />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="email" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Email *</label>
                <input type="email" id="email" name="email" required class="w-full bg-white border border-border rounded-lg px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="your@email.com" />
              </div>
              <div>
                <label for="phone" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Phone</label>
                <input type="tel" id="phone" name="phone" class="w-full bg-white border border-border rounded-lg px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="Your phone number" />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="product" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Product Interest</label>
                <select id="product" name="product" class="w-full bg-white border border-border rounded-lg px-4 py-3 text-charcoal focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors">
                  <option value="">Select a product (optional)</option>
                  {products.map(p => (
                    <option value={p.name}>{p.name}</option>
                  ))}
                </select>
              </div>
              <div>
                <label for="delivery-area" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Delivery Area</label>
                <select id="delivery-area" name="delivery-area" class="w-full bg-white border border-border rounded-lg px-4 py-3 text-charcoal focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors">
                  <option value="">Select your area (optional)</option>
                  {areas.map(a => (
                    <option value={a.name}>{a.name}</option>
                  ))}
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Message *</label>
              <textarea id="message" name="message" rows="5" required class="w-full bg-white border border-border rounded-lg px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors resize-y" placeholder="Tell us about your project, quantities and when you need delivery..."></textarea>
            </div>
            
            <button type="submit" class="w-full sm:w-auto bg-primary hover:bg-primary-hover text-white font-bold px-10 py-4 rounded-lg text-lg transition-colors">Send Message</button>
          </form>
        </AnimatedSection>

        <!-- Sidebar -->
        <div class="space-y-6">
          <AnimatedSection delay={0.1}>
            <div class="bg-section rounded-2xl p-6 md:p-8">
              <h3 class="text-charcoal font-heading text-lg font-bold uppercase tracking-wide mb-5">Opening Hours</h3>
              <ul class="space-y-3">
                {openingHours.map(({ day, hours }) => (
                  <li class="flex justify-between text-sm">
                    <span class="font-medium text-charcoal">{day}</span>
                    <span class={hours === 'Closed' ? 'text-body' : 'text-charcoal font-medium'}>{hours}</span>
                  </li>
                ))}
              </ul>
            </div>
          </AnimatedSection>

          <AnimatedSection delay={0.2}>
            <div class="bg-charcoal rounded-2xl p-6 md:p-8">
              <h3 class="text-white font-heading text-lg font-bold uppercase tracking-wide mb-5">Why Trade Customers Call Us</h3>
              
              <ul class="space-y-4">
                <li class="flex items-start gap-3 text-white/90 text-sm">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Trade pricing and quantity discounts</span>
                </li>
                <li class="flex items-start gap-3 text-white/90 text-sm">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Next-day delivery across the South West</span>
                </li>
                <li class="flex items-start gap-3 text-white/90 text-sm">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Expert product and specification advice</span>
                </li>
                <li class="flex items-start gap-3 text-white/90 text-sm">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Trade accounts available</span>
                </li>
              </ul>
            </div>
          </AnimatedSection>

          <AnimatedSection delay={0.3}>
            <div class="bg-section rounded-2xl p-6 md:p-8">
              <h3 class="text-charcoal font-heading text-lg font-bold uppercase tracking-wide mb-4">Areas We Deliver To</h3>
              <div class="flex flex-wrap gap-2">
                {areas.map(area => (
                  <a href={`/areas/${area.slug}`} class="bg-white text-primary text-sm font-medium px-3 py-1.5 rounded-full border border-border hover:border-primary transition-colors">{area.name}</a>
                ))}
              </div>
            </div>
          </AnimatedSection>
        </div>
      </div>
    </div>
  </section>

  <!-- Map / depot -->
  <section class="bg-charcoal py-14 md:py-20">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <AnimatedSection>
          <SectionLabel text="Visit Us" light={true} />
          
          <h2 class="text-3xl md:text-4xl font-heading font-bold uppercase tracking-wide text-white mb-4">Visit Our Bristol Depot</h2>
          
          <p class="text-white/80 mb-6">
            Collect orders, speak to our trade counter team and take a look at product samples. We’re conveniently located for roofers and builders across Bristol, Bath and the surrounding areas.
          </p>
          
          <ul class="space-y-3 text-white/90 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
              <span>{ADDRESS}, Bristol, {POSTCODE}</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>Mon–Fri 07:30–17:00, Sat 08:00–12:00</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span>{PHONE}</span>
            </li>
          </ul>
          
          <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-white font-semibold px-8 py-4 rounded-md transition-colors text-lg">
            Call {PHONE}
          </a>
        </AnimatedSection>

        <AnimatedSection delay={0.1}>
          <div class="bg-white p-2 rounded-2xl shadow-2xl overflow-hidden">
            <iframe
              src="https://www.google.com/maps?q=Ashmead+Roofing+Supplies,Bristol,BS2+9RL&output=embed"
              width="100%"
              height="100%"
              style="border:0; min-height: 360px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ashmead Roofing Supplies Bristol depot location"
              class="rounded-xl w-full aspect-video md:aspect-[4/3]"
            ></iframe>
          </div>
        </AnimatedSection>
      </div>
    </div>
  </section>

  <!-- Quick Product Links -->
  <section class="section-white section-padding">
    <div class="container">
      <SectionLabel text="Our Range" />
      <h2 class="text-charcoal font-heading text-3xl md:text-4xl font-bold uppercase tracking-wide mb-8">Products to Enquire About</h2>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {products.map(p => (
          <a href={`/products/${p.slug}`} class="group bg-section rounded-xl p-4 text-center transition-all border border-border hover:border-primary hover:shadow-lg">
            <h3 class="text-charcoal font-heading text-sm font-bold uppercase tracking-wide group-hover:text-primary transition-colors">{p.name}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <Testimonials title="What Our Customers Say" />

  <CtaBanner />
</Layout>
