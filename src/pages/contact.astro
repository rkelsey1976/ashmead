---
import Layout from '../layouts/Layout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Hero from '../components/Hero.astro';
import AnimatedSection from '../components/AnimatedSection.astro';
import BrandMarquee from '../components/BrandMarquee.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { BUSINESS_NAME, heroImages } from '../data/site';
import { products } from '../data/products';
import { brands } from '../data/brands';
import { getSiteSettings } from '../lib/siteSettings';

const { PHONE, PHONE_HREF, EMAIL, ADDRESS, POSTCODE, OPENING_HOURS } = await getSiteSettings();

const formatHour = (h: { opens: string; closes: string }) =>
  h.opens ? `${h.opens} – ${h.closes}` : 'Closed';
---

<Layout title="Contact Ashmead Roofing Supplies | Call 0117 986 0600" description="Contact Ashmead Roofing Supplies Ltd in Bristol. Call 0117 986 0600 for trade pricing, expert advice and fast delivery across the South West.">

  <Hero
    eyebrow="Trade Counter Open Six Days"
    title="Start Your"
    accent="Order Today"
    description="Call, email or visit our Bristol depot. Our team has pricing, stock levels and technical advice ready for roofers and builders across the South West."
    image={heroImages.contact}
    ctaPrimary={{ label: 'Call the Team', href: PHONE_HREF, icon: 'phone' }}
    ctaSecondary={{ label: 'Get a Quote', href: '#contact-form', icon: 'arrow' }}
    minHeight="min-h-[55vh] md:min-h-[65vh]"
  />

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Contact cards -->
  <section class="section-white section-padding" id="contact-form">
    <div class="container">

      <div class="grid md:grid-cols-3 gap-px bg-border mb-14">
        <AnimatedSection>
          <a href={PHONE_HREF} class="group flex flex-col bg-charcoal p-7 md:p-8 text-white hover:bg-charcoal/90 transition-colors h-full">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 bg-white/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <span class="text-white/50 text-[10px] font-semibold uppercase tracking-[0.2em] font-body">Phone</span>
            </div>
            <p class="font-heading font-bold text-accent leading-none mb-2" style="font-size: clamp(1.4rem, 2.5vw, 1.8rem)">{PHONE}</p>
            <p class="text-white/60 text-sm mt-auto pt-4">Speak directly to our trade counter team.</p>
          </a>
        </AnimatedSection>

        <AnimatedSection delay={0.05}>
          <a href={`mailto:${EMAIL}`} class="group flex flex-col bg-primary p-7 md:p-8 text-white hover:bg-primary/90 transition-colors h-full">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 bg-white/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <span class="text-white/60 text-[10px] font-semibold uppercase tracking-[0.2em] font-body">Email</span>
            </div>
            <p class="font-heading font-bold text-white leading-tight mb-2 break-words" style="font-size: clamp(0.9rem, 1.5vw, 1.1rem)">{EMAIL}</p>
            <p class="text-white/60 text-sm mt-auto pt-4">We aim to respond within 24 hours.</p>
          </a>
        </AnimatedSection>

        <AnimatedSection delay={0.1}>
          <div class="flex flex-col bg-section p-7 md:p-8 h-full">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 bg-white flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <span class="text-body text-[10px] font-semibold uppercase tracking-[0.2em] font-body">Depot</span>
            </div>
            <p class="text-charcoal font-heading font-bold text-lg leading-tight mb-2">{BUSINESS_NAME}</p>
            <p class="text-body text-sm">{ADDRESS} {POSTCODE}</p>
          </div>
        </AnimatedSection>
      </div>

      <!-- Form + sidebar -->
      <div class="grid lg:grid-cols-3 gap-10 lg:gap-14">

        <!-- Form -->
        <AnimatedSection class="lg:col-span-2">
          <SectionLabel text="Send a Message" />
          <h2 class="text-charcoal font-heading text-3xl md:text-4xl font-bold uppercase tracking-wide mb-2">Request a Quote</h2>
          <p class="text-body mb-8">Tell us what you need and our trade team will get back to you with pricing, availability and delivery options.</p>

          <form name="contact" method="POST" data-netlify="true" action="/thank-you" class="space-y-5">
            <input type="hidden" name="form-name" value="contact" />

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Name *</label>
                <input type="text" id="name" name="name" required class="w-full bg-white border border-border px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary transition-colors" placeholder="Your name" />
              </div>
              <div>
                <label for="company" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Company</label>
                <input type="text" id="company" name="company" class="w-full bg-white border border-border px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary transition-colors" placeholder="Your company" />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="email" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Email *</label>
                <input type="email" id="email" name="email" required class="w-full bg-white border border-border px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary transition-colors" placeholder="your@email.com" />
              </div>
              <div>
                <label for="phone" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Phone</label>
                <input type="tel" id="phone" name="phone" class="w-full bg-white border border-border px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary transition-colors" placeholder="Your phone number" />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="product" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Product Interest</label>
                <select id="product" name="product" class="w-full bg-white border border-border px-4 py-3 text-charcoal focus:outline-none focus:border-primary transition-colors">
                  <option value="">Select a product (optional)</option>
                  {products.map(p => (
                    <option value={p.name}>{p.name}</option>
                  ))}
                </select>
              </div>
              <div>
                <label for="delivery-area" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Delivery Area</label>
                <select id="delivery-area" name="delivery-area" class="w-full bg-white border border-border px-4 py-3 text-charcoal focus:outline-none focus:border-primary transition-colors">
                  <option value="">Select your area (optional)</option>
                  {['Bristol', 'Bath', 'Somerset', 'Gloucester', 'Wiltshire'].map(a => (
                    <option value={a}>{a}</option>
                  ))}
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Message *</label>
              <textarea id="message" name="message" rows="5" required class="w-full bg-white border border-border px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary transition-colors resize-y" placeholder="Tell us about your project, quantities and when you need delivery..."></textarea>
            </div>

            <button type="submit" class="bg-primary hover:bg-primary/90 text-white font-heading font-bold uppercase tracking-wide px-10 py-4 text-sm transition-colors">
              Send Message
            </button>
          </form>
        </AnimatedSection>

        <!-- Sidebar -->
        <div class="space-y-4">
          <AnimatedSection delay={0.1}>
            <div class="bg-charcoal p-7">
              <p class="text-white/40 text-[10px] font-semibold uppercase tracking-[0.2em] font-body mb-1">Trade team</p>
              <h3 class="text-white font-heading text-base font-bold uppercase tracking-wide mb-5">Why Roofers Choose Us</h3>
              <ul class="space-y-3">
                {[
                  'Trade pricing & quantity discounts',
                  'Next-day delivery across the South West',
                  'Expert product & specification advice',
                  'Trade accounts available',
                  'Same-day collection from Keynsham',
                ].map(point => (
                  <li class="flex items-start gap-2.5 text-white/75 text-sm font-body leading-snug">
                    <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {point}
                  </li>
                ))}
              </ul>
            </div>
          </AnimatedSection>

          <AnimatedSection delay={0.2}>
            <div class="bg-section border border-border p-7">
              <h3 class="text-charcoal font-heading text-base font-bold uppercase tracking-wide mb-5">Opening Hours</h3>
              <ul class="space-y-2.5">
                {OPENING_HOURS.map(h => (
                  <li class="flex justify-between text-sm">
                    <span class="font-semibold text-charcoal font-body">{h.day}</span>
                    <span class={h.opens ? 'text-charcoal font-body' : 'text-body font-body'}>{formatHour(h)}</span>
                  </li>
                ))}
              </ul>
            </div>
          </AnimatedSection>
        </div>

      </div>
    </div>
  </section>

  <!-- Map / depot -->
  <section class="bg-charcoal py-14 md:py-20">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <AnimatedSection>
          <SectionLabel text="Visit Us" light={true} />
          <h2 class="text-3xl md:text-4xl font-heading font-bold uppercase tracking-wide text-white mb-4">Visit Our Keynsham Depot</h2>
          <p class="text-white/70 mb-8 leading-relaxed">
            Collect orders, speak to our trade counter team and view product samples. Conveniently located for roofers across Bristol, Bath and the surrounding areas.
          </p>
          <ul class="space-y-3 text-white/80 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-accent flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
              <span class="text-sm">{ADDRESS} {POSTCODE}</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-accent flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-sm">Mon–Fri 07:00–16:30</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-accent flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span class="text-sm">{PHONE}</span>
            </li>
          </ul>
          <a href={PHONE_HREF} class="inline-flex items-center gap-2 bg-accent text-charcoal font-heading font-bold uppercase tracking-wide text-sm px-8 py-4 hover:bg-white transition-colors">
            Call {PHONE}
          </a>
        </AnimatedSection>

        <AnimatedSection delay={0.1}>
          <div class="overflow-hidden shadow-2xl">
            <iframe
              src="https://www.google.com/maps?q=Ashmead+Roofing+Supplies,Keynsham,BS31+1TU&output=embed"
              width="100%"
              height="100%"
              style="border:0; min-height: 360px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ashmead Roofing Supplies Bristol depot location"
              class="w-full aspect-video md:aspect-[4/3]"
            ></iframe>
          </div>
        </AnimatedSection>
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>
