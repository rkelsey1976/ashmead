---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME, EMAIL, heroImages } from '../data/site';
import { products } from '../data/products';
import { areas } from '../data/areas';
---

<Layout title="Contact Ashmead Roofing Supplies | Call 0117 986 0600" description="Contact Ashmead Roofing Supplies Ltd in Bristol. Call 0117 986 0600 for trade pricing, expert advice and fast delivery across the South West.">
  <!-- Contact Hero — diagonal split -->
  <section class="relative overflow-hidden min-h-[400px] md:min-h-[500px]">
    <div class="absolute inset-0">
      <img src={heroImages.contact} alt="" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="absolute inset-0 bg-charcoal" style="clip-path: polygon(0 0, 75% 0, 50% 100%, 0 100%)"></div>
    <div class="absolute inset-0" style="clip-path: polygon(74.5% 0, 75.5% 0, 50.5% 100%, 49.5% 100%); background: #009900;"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-8 md:px-12 lg:px-16 py-16 md:py-24 flex items-center min-h-[400px] md:min-h-[500px]">
      <div class="max-w-2xl">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading uppercase tracking-wide text-primary mb-6">Contact Us</h1>
        <p class="text-lg text-white/80 mb-8">Get in touch with our trade team for pricing, availability and expert advice. We're here to help professional roofers across the South West.</p>
        <Button variant="primary" href="phone" icon="phone" size="lg">Call {PHONE}</Button>
      </div>
    </div>
  </section>

  <section class="section-white section-padding">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Send Us a Message</h2>
          <form name="contact" method="POST" data-netlify="true" class="space-y-6">
            <input type="hidden" name="form-name" value="contact" />
            <div>
              <label for="name" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Name</label>
              <input type="text" id="name" name="name" required class="w-full bg-white border border-border rounded px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary transition-colors" placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Email</label>
              <input type="email" id="email" name="email" required class="w-full bg-white border border-border rounded px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary transition-colors" placeholder="your@email.com" />
            </div>
            <div>
              <label for="phone" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Phone</label>
              <input type="tel" id="phone" name="phone" class="w-full bg-white border border-border rounded px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary transition-colors" placeholder="Your phone number" />
            </div>
            <div>
              <label for="product" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Product Interest</label>
              <select id="product" name="product" class="w-full bg-white border border-border rounded px-4 py-3 text-charcoal focus:outline-none focus:border-primary transition-colors">
                <option value="">Select a product (optional)</option>
                {products.map(p => (
                  <option value={p.name}>{p.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="message" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Message</label>
              <textarea id="message" name="message" rows="5" required class="w-full bg-white border border-border rounded px-4 py-3 text-charcoal placeholder-gray-400 focus:outline-none focus:border-primary transition-colors resize-y" placeholder="Tell us about your project..."></textarea>
            </div>
            <button type="submit" class="w-full bg-primary hover:bg-primary-hover text-white font-bold px-8 py-4 rounded text-lg transition-colors">Send Message</button>
          </form>
        </div>

        <!-- Contact Details -->
        <div>
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Get in Touch</h2>

          <div class="space-y-6 mb-8">
            <div class="bg-white rounded-lg p-6 border border-border shadow-sm">
              <h3 class="text-charcoal font-heading font-bold uppercase tracking-wide mb-2">Phone</h3>
              <a href={PHONE_HREF} class="text-primary hover:text-primary-hover text-2xl font-bold transition-colors">{PHONE}</a>
              <p class="text-body text-sm mt-1">Call us for pricing, advice and orders</p>
            </div>

            <div class="bg-white rounded-lg p-6 border border-border shadow-sm">
              <h3 class="text-charcoal font-heading font-bold uppercase tracking-wide mb-2">Email</h3>
              <a href={`mailto:${EMAIL}`} class="text-primary hover:text-primary-hover text-lg font-bold transition-colors">{EMAIL}</a>
              <p class="text-body text-sm mt-1">We aim to respond within 24 hours</p>
            </div>

            <div class="bg-white rounded-lg p-6 border border-border shadow-sm">
              <h3 class="text-charcoal font-heading font-bold uppercase tracking-wide mb-2">Depot</h3>
              <p class="text-charcoal font-bold">{BUSINESS_NAME}</p>
              <p class="text-body text-sm mt-1">Bristol, South West England</p>
            </div>
          </div>

          <h3 class="text-charcoal font-heading font-bold uppercase tracking-wide mb-3">Areas We Deliver To</h3>
          <div class="flex flex-wrap gap-2">
            {areas.map(area => (
              <a href={`/areas/${area.slug}`} class="bg-primary/10 text-primary text-sm font-medium px-3 py-1 rounded hover:bg-primary/20 transition-colors">{area.name}</a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Product Links -->
  <section class="section-grey section-padding">
    <div class="container">
      <SectionHeading text="Our Products" />
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {products.map(p => (
          <a href={`/products/${p.slug}`} class="group bg-white rounded-lg p-4 text-center transition-all border border-border hover:border-primary hover:shadow-lg">
            <h3 class="text-charcoal font-heading text-sm font-bold uppercase tracking-wide group-hover:text-primary transition-colors">{p.name}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>