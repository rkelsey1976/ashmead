---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import BrandMarquee from '../components/BrandMarquee.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Hero from '../components/Hero.astro';
import AnimatedSection from '../components/AnimatedSection.astro';
import { brands } from '../data/brands';
import { PHONE, PHONE_HREF, heroImages } from '../data/site';

const title = "Roofing Training, CPDs & Trade Events | Ashmead Roofing Supplies";
const description = "Upcoming roofing training courses, manufacturer CPDs and trade events for roofers and builders across Bristol, Bath, Somerset, Gloucestershire and Wiltshire.";

interface TrainingEvent {
  name: string;
  provider: string;
  type: string;
  audience: string;
  description: string;
  link?: string;
}

const events: TrainingEvent[] = [
  {
    name: "Marley Roofing Academy",
    provider: "Marley",
    type: "Installer training",
    audience: "Roofers & contractors",
    description: "Hands-on courses covering concrete and clay tile installation, dry-fix systems, battens and BS 5534 updates. Held at regional training centres across the UK.",
    link: "https://www.marley.co.uk/training"
  },
  {
    name: "Redland/Russell Roof Tiles Training",
    provider: "Redland",
    type: "Product & installation training",
    audience: "Roofers & merchants",
    description: "Practical training on tile and slate installation, dry ridge and hip systems, underlays and fixing specifications. Booking available through the Redland website.",
    link: "https://www.redland.co.uk/training"
  },
  {
    name: "VELUX Installer Training & CPDs",
    provider: "VELUX",
    type: "Installer academy & CPD",
    audience: "Roofers, builders & architects",
    description: "Roof window installation, flashing kits, daylighting design and product CPDs. Available at VELUX training centres and online.",
    link: "https://www.velux.co.uk/training"
  },
  {
    name: "Cupa Pizarras CPDs & Slating Courses",
    provider: "Cupa Pizarras",
    type: "CPD & practical slating",
    audience: "Roofers & specifiers",
    description: "Natural slate CPD sessions and on-site slating courses covering grading, fixing, heritage work and detailing around dormers and valleys.",
    link: "https://www.cupapizarras.com/uk/training"
  },
  {
    name: "Rockwool CPD & Fire Safety Training",
    provider: "Rockwool",
    type: "CPD",
    audience: "Builders, roofers & architects",
    description: "Roof and facade insulation CPDs covering fire safety, acoustics, thermal performance and compliance with building regulations.",
    link: "https://www.rockwool.com/uk/cpd"
  },
  {
    name: "A. Proctor Group CPDs",
    provider: "A. Proctor Group",
    type: "CPD",
    audience: "Roofers, builders & architects",
    description: "Breather membranes, vapour control, airtightness and pitched roof condensation risk. Available as face-to-face or online CPDs.",
    link: "https://www.proctorgroup.com/cpd"
  },
  {
    name: "ClassicBond EPDM Training",
    provider: "ClassicBond",
    type: "Flat-roof installer training",
    audience: "Flat roofers",
    description: "One-day EPDM membrane courses covering preparation, adhesives, seams, detailing and domestic flat roof applications.",
    link: "https://www.classicbond.co.uk/training"
  },
  {
    name: "Resitrix & Duopoly Training",
    provider: "Resitrix / Duopoly",
    type: "Flat-roof installer training",
    audience: "Flat roofers & contractors",
    description: "Hot-air welded membrane and liquid-applied flat roofing training, including detailing, preparation and guarantees.",
    link: "https://www.resitrix.co.uk/training"
  },
  {
    name: "Fatra Flat Roofing Courses",
    provider: "Fatra",
    type: "Installer training",
    audience: "Flat roofers",
    description: "PVC membrane and liquid waterproofing training for commercial and domestic flat roofs, including welding and detailing.",
    link: "https://www.fatra.co.uk/training"
  },
  {
    name: "Icopal / BMI Group Training",
    provider: "Icopal",
    type: "Built-up flat roofing training",
    audience: "Commercial roofers",
    description: "Torch-on, self-adhesive and liquid waterproofing systems for built-up flat roofing, including QA and guarantee programmes.",
    link: "https://www.bmigroup.com/uk/training"
  },
  {
    name: "NFRC Roofing Trade Show & Awards",
    provider: "NFRC",
    type: "Trade show & networking",
    audience: "Roofers, merchants & suppliers",
    description: "Annual roofing industry exhibition, awards dinner and seminar programme covering regulation changes, products and business skills.",
    link: "https://www.nfrc.co.uk/events"
  },
  {
    name: "Roofing Expo / UK Construction Week",
    provider: "Industry",
    type: "Trade show",
    audience: "Roofers, builders & specifiers",
    description: "National construction and roofing exhibitions featuring new products, live demos and CPD seminars. Check current dates and venues.",
    link: "https://www.ukconstructionweek.com"
  },
  {
    name: "CITB / Site Safe Rooftop Safety Training",
    provider: "CITB / accredited providers",
    type: "Safety training",
    audience: "Roofers & labourers",
    description: "Working at height, harness use, scaffold awareness and rooftop safety. Essential for compliance and site eligibility.",
    link: "https://www.citb.co.uk/courses-and-qualifications/"
  },
  {
    name: "Ashmead Roofing Depot Open Days",
    provider: "Ashmead Roofing Supplies",
    type: "Merchant open day",
    audience: "Local roofers & builders",
    description: "Trade mornings and manufacturer demo days at our Bristol depot. Product launches, special offers, breakfast rolls and expert advice. Call us to register your interest.",
    link: PHONE_HREF
  }
];

const hostedBenefits = [
  "Manufacturer demo days with Marley, Redland, VELUX, Cupa Pizarras and more",
  "Flat-roofing practical sessions — ClassicBond, Resitrix, Duopoly and Fatra",
  "BS 5534, insulation and ventilation updates for pitched roofs",
  "Trade-only pricing, breakfast rolls and networking with local roofers",
];
---

<Layout title={title} description={description} ogImage={heroImages.training}>
  
  <Hero
    eyebrow="Manufacturer-Accredited"
    title="Train Smarter,"
    accent="Roof Better"
    description="CPDs, product updates and hands-on trade events designed for South West roofers who want to stay current and win more work."
    image={heroImages.training}
    ctaPrimary={{ label: 'Call to Register', href: PHONE_HREF, icon: 'phone' }}
    ctaSecondary={{ label: 'View Upcoming Events', href: '#upcoming-events', icon: 'arrow' }}
    minHeight="min-h-[55vh] md:min-h-[65vh]"
  />

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Intro -->
  <section class="section-white section-padding">
    <div class="container">
      <AnimatedSection class="max-w-3xl">
        <SectionLabel text="Keep Your Skills Current" />
        
        <h2 class="text-charcoal font-heading text-3xl md:text-4xl font-bold uppercase tracking-wide mb-6">Training That Helps Your Business Win Work</h2>
        
        <div class="space-y-4 text-body text-lg leading-relaxed">
          <p>Roofing is changing fast: new regulations, tighter building standards and more technical products. The roofers and contractors who keep their skills current win the best jobs.</p>
          <p>We keep our customers informed about training from the brands we stock, plus the wider roofing trade events that matter. Whether you need a refresher on BS 5534, a VELUX installation certificate, or a flat-roofing guarantee programme, start here.</p>
        </div>
      </AnimatedSection>
    </div>
  </section>

  <!-- Hosted training feature -->
  <section class="bg-primary section-padding">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-12 items-start">
        
        <AnimatedSection>
          <p class="text-white/80 text-sm font-semibold uppercase tracking-wider mb-3">At Our Keynsham Depot</p>
          
          <h2 class="text-charcoal font-heading text-3xl md:text-4xl font-bold uppercase tracking-wide text-white mb-4">Training Events Hosted by Ashmead</h2>
          
          <p class="text-white/90 text-lg mb-8 leading-relaxed">
            We run regular trade mornings, product demos and manufacturer-led sessions at our Bristol depot. Get hands-on with the latest materials, ask our suppliers direct questions, and pick up trade-only deals — all over a bacon roll and a brew.
          </p>

          <ul class="space-y-4 mb-8">
            {hostedBenefits.map(benefit => (
              <li class="flex items-start gap-3 text-white">
                <div class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span>{benefit}</span>
              </li>
            ))}
          </ul>

          <div class="flex flex-wrap gap-3">
            <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 bg-white hover:bg-section text-primary font-semibold px-6 py-3 transition-colors">
              Call {PHONE}
            </a>
            <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white text-white hover:bg-white hover:text-primary font-semibold px-6 py-3 transition-colors">
              Register Interest
            </a>
          </div>
        </AnimatedSection>

        <AnimatedSection delay={0.1}>
          <div class="bg-white rounded-2xl p-6 md:p-8 shadow-xl">
            <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-2">Register for Ashmead Training</h3>
            
            <p class="text-body mb-6">Leave your details and we'll add you to our training mailing list. You'll get first notice of upcoming depot events, manufacturer demo days and exclusive trade offers.</p>

            <form name="training-register" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you" class="space-y-4">
              <input type="hidden" name="form-name" value="training-register" />
              <p class="hidden"><label>Don't fill this in: <input name="bot-field" /></label></p>
              <div>
                <label for="name" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Name</label>
                <input type="text" id="name" name="name" required class="w-full border border-border px-4 py-3 text-charcoal focus:outline-none focus:border-primary transition-colors" />
              </div>
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="company" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Company</label>
                  <input type="text" id="company" name="company" class="w-full border border-border px-4 py-3 text-charcoal focus:outline-none focus:border-primary transition-colors" />
                </div>
                <div>
                  <label for="email" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">Email *</label>
                  <input type="email" id="email" name="email" required class="w-full border border-border px-4 py-3 text-charcoal focus:outline-none focus:border-primary transition-colors" />
                </div>
              </div>
              <div>
                <label for="interest" class="block text-charcoal font-heading font-bold uppercase tracking-wide text-sm mb-2">I'm interested in</label>
                <select id="interest" name="interest" class="w-full border border-border px-4 py-3 text-charcoal focus:outline-none focus:border-primary transition-colors bg-white appearance-none">
                  <option value="">Select an option</option>
                  <option value="tile-and-slate">Tile & slate training</option>
                  <option value="flat-roofing">Flat roofing training</option>
                  <option value="roof-windows">Roof windows / VELUX</option>
                  <option value="insulation-ventilation">Insulation & ventilation</option>
                  <option value="cpd">CPD / specification</option>
                  <option value="trade-mornings">Depot trade mornings</option>
                </select>
              </div>
              <button type="submit" class="w-full bg-primary hover:bg-primary-hover text-white font-bold py-4 text-lg transition-colors">
                Register Interest
              </button>
            </form>
          </div>
        </AnimatedSection>
      </div>
    </div>
  </section>

  <!-- Events grid -->
  <section class="section-grey section-padding">
    <div class="container">
      <AnimatedSection>
        <SectionLabel text="Upcoming Training & Events" />
        
        <h2 class="text-charcoal font-heading text-3xl md:text-4xl font-bold uppercase tracking-wide mb-10">Training Courses, CPDs & Trade Shows</h2>
      </AnimatedSection>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {events.map((event, i) => (
          <AnimatedSection delay={i * 0.05}>
            <article class="bg-white rounded-2xl p-6 md:p-7 border border-border flex flex-col h-full hover:border-primary transition-colors group">
              <div class="flex items-center justify-between gap-3 mb-4">
                <span class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-wide bg-section text-primary rounded-full">{event.type}</span>
                
                <span class="text-xs font-semibold text-body uppercase tracking-wide">{event.provider}</span>
              </div>
              
              <h3 class="text-lg font-bold font-heading text-charcoal mb-2 group-hover:text-primary transition-colors">{event.name}</h3>
              
              <p class="text-sm text-body mb-4">{event.audience}</p>
              
              <p class="text-body text-sm mb-6 flex-grow leading-relaxed">{event.description}</p>
              
              {event.link && (
                <a href={event.link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-semibold text-primary hover:text-primary-hover transition-colors">
                  Find out more
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              )}
            </article>
          </AnimatedSection>
        ))}
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>
