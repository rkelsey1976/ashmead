---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME, brands } from '../data/site';
import { products } from '../data/products';
---

<Layout title="About Ashmead Roofing Supplies | Bristol's Trade Counter" description="Ashmead Roofing Supplies Ltd — Bristol's trusted roofing trade counter supplying professional roofers across the South West. Expert advice, massive stock, fast delivery.">
  <!-- About Hero -->
  <section class="bg-section-highlight py-16 md:py-24 border-b-4 border-primary">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="text-3xl md:text-5xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">About {BUSINESS_NAME}</h1>
      <p class="text-lg text-body max-w-3xl mb-8">Bristol's trusted roofing trade counter, supplying professional roofers and builders across the South West with tiles, slates, flat roofing, membranes, fixings and everything in between.</p>
      <a href={PHONE_HREF} class="inline-flex items-center gap-2 bg-primary hover:bg-primary-hover text-white font-bold px-8 py-4 rounded text-lg transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call {PHONE}
      </a>
    </div>
  </section>

  <!-- Our Story -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Our Story</h2>
          <p class="text-body leading-relaxed mb-4">{BUSINESS_NAME} was founded on a simple principle: give professional roofers the materials they need, when they need them, at prices that keep them competitive. From our Bristol depot we've built a reputation for stock availability, trade expertise and reliable delivery that keeps projects on track.</p>
          <p class="text-body leading-relaxed mb-4">We understand roofing because we come from roofing. Our trade counter team has years of on-the-tools experience, which means they can advise on product selection, calculate quantities, and help specify the right system for any project — from a single garage flat roof to a 200-unit housing development.</p>
          <p class="text-body leading-relaxed">That expertise, combined with one of the widest product ranges in the South West, makes Ashmead the first call for professional roofers across Bristol, Bath, Somerset, Gloucester and Wiltshire.</p>
        </div>
        <div>
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Why Trade Roofers Choose Us</h2>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-body"><strong class="text-charcoal">Massive stock holding</strong> — One of the widest ranges of roofing materials in the South West, ready for immediate collection or next-day delivery.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-body"><strong class="text-charcoal">Trade expertise</strong> — Our team knows roofing. We advise on products, calculate quantities and help specify the right system first time.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-body"><strong class="text-charcoal">Trade pricing</strong> — Competitive, honest pricing without the inflated margins. What you see is what you get.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-body"><strong class="text-charcoal">Fast delivery</strong> — Our fleet covers Bristol, Bath, Somerset, Gloucester and Wiltshire. Need it faster? Collect from our Bristol depot.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-body"><strong class="text-charcoal">Leading brands</strong> — We supply Redland, Marley, Velux, Cupa Pizarras, A. Proctor Group, Rockwool, Kober, Kytun, FloPlast, Roto and British Lead Mills.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Brands -->
  <section class="bg-section py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal text-center mb-12">Brands We Supply</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {brands.map(brand => (
          <div class="bg-white rounded-lg p-4 text-center border border-border hover:border-primary transition-colors">
            <span class="text-charcoal font-heading text-base font-bold uppercase tracking-wide">{brand}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</Layout>