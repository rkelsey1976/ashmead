---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import BrandMarquee from '../components/BrandMarquee.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Hero from '../components/Hero.astro';
import AnimatedSection from '../components/AnimatedSection.astro';
import Testimonials from '../components/Testimonials.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME, ADDRESS, heroImages } from '../data/site';
import { brands } from '../data/brands';

const stats = [
  { value: '40+', label: 'Years serving roofers' },
  { value: '5', label: 'Counties delivered to' },
  { value: '68+', label: 'Towns covered' },
  { value: '1000s', label: 'Trade orders fulfilled' },
];

const values = [
  {
    title: 'Massive stock holding',
    desc: 'One of the widest ranges of roofing materials in the South West, ready for immediate collection or next-day delivery.',
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  },
  {
    title: 'Trade expertise',
    desc: 'Our team knows roofing. We advise on products, calculate quantities and help specify the right system first time.',
    icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  },
  {
    title: 'Trade pricing',
    desc: 'Competitive, honest pricing without the inflated margins. What you see is what you get.',
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Fast delivery',
    desc: 'Our fleet covers Bristol, Bath, Somerset, Gloucester and Wiltshire. Need it faster? Collect from our Bristol depot.',
    icon: 'M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0',
  },
  {
    title: 'Leading brands',
    desc: 'We stock Redland, Marley, Velux, Cupa Pizarras, A. Proctor Group, Rockwool, Kober, Kytun, FloPlast, Roto and British Lead Mills.',
    icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-4l5-5m-5 5l-5-5m5 5v6m0-6h6',
  },
  {
    title: 'Account support',
    desc: 'Open a trade account for faster checkout, credit terms and dedicated support from our Bristol team.',
    icon: 'M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2',
  },
];
---

<Layout title={`About ${BUSINESS_NAME} | Bristol's Trade Counter`} description="Ashmead Roofing Supplies Ltd — Bristol's trusted roofing trade counter supplying professional roofers across the South West. Expert advice, massive stock, fast delivery.">
  
  <Hero
    eyebrow="Roofing Suppliers Since 1985"
    title="Built by Roofers,"
    accent="For Roofers"
    description="Independent trade counter supplying quality materials, honest advice and next-day delivery to roofing contractors across the South West."
    image={heroImages.about}
    ctaPrimary={{ label: 'Call the Team', href: PHONE_HREF, icon: 'phone' }}
    ctaSecondary={{ label: 'View Our Products', href: '/products', icon: 'arrow' }}
    minHeight="min-h-[60vh] md:min-h-[70vh]"
  />

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Story -->
  <section class="section-white section-padding">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <AnimatedSection>
          <SectionLabel text="Our Story" />
          <h2 class="text-charcoal font-heading text-3xl md:text-4xl font-bold uppercase tracking-wide mb-6">
            Built for Bristol Roofers
          </h2>
          
          <div class="space-y-4 text-body text-lg leading-relaxed">
            <p>Ashmead Roofing Supplies Ltd Bristol supply roofing supplies to the Bristol and Bath roofing and building trades. With a dedicated team and a diverse wealth of roofing knowledge, we believe we can source and supply just about any roofing product you may require.</p>
            <p>All our tiles are stocked at our own warehouse depot in Bristol and are often available for immediate delivery – we supply hundreds of contractors, homeowners and property builders on a daily basis.</p>
            <p>Our aim is to continuously increase our range to provide you with competitive and quality products for all your roofing needs. Can’t see something you are looking for? Give us a call and we will be happy to source it for you.</p>
            <p>{BUSINESS_NAME} was founded on a simple principle: give professional roofers the materials they need, when they need them, at prices that keep them competitive.</p>
          </div>
        </AnimatedSection>
        
        <AnimatedSection delay={0.1}>
          <div class="bg-section rounded-2xl p-6 md:p-8 lg:sticky lg:top-28">
            <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-6">Why Trade Roofers Choose Us</h3>
            
            <ul class="space-y-5">
              {values.map(value => (
                <li class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={value.icon} />
                    </svg>
                  </div>
                  <div>
                    <h4 class="text-charcoal font-semibold mb-1">{value.title}</h4>
                    <p class="text-body text-sm leading-relaxed">{value.desc}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </AnimatedSection>
      </div>    
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-charcoal py-14 md:py-20">
    <div class="container">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {stats.map(stat => {
          const num = stat.value.replace(/[^0-9]/g, '');
          const suffix = stat.value.replace(/[0-9]/g, '');
          return (
            <div class="text-center md:text-left">
              <p class="text-accent font-heading text-4xl md:text-5xl font-bold mb-2" data-count-to={num} data-count-suffix={suffix}>{stat.value}</p>
              <p class="text-white/70 text-sm md:text-base uppercase tracking-wide">{stat.label}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Call us -->
  <section class="bg-primary section-padding">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div class="text-white">
          <p class="text-white/80 text-sm font-semibold uppercase tracking-wider mb-3">Call Us Today</p>
          <h2 class="text-4xl md:text-5xl font-heading font-bold uppercase tracking-wide mb-4">{PHONE}</h2>
          <p class="text-white/90 text-lg max-w-lg">Speak to our trade counter team for advice, stock availability, trade accounts and delivery options across the South West.</p>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4 lg:justify-end">
          <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 bg-white hover:bg-section text-primary font-semibold px-8 py-4 transition-all text-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call Now
          </a>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white text-white hover:bg-white hover:text-primary font-semibold px-8 py-4 transition-all text-lg">
            Visit Depot
          </a>
        </div>
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <Testimonials title="Trusted by Roofers Across the South West" />

  <CtaBanner />
</Layout>
