---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import BrandBar from '../components/BrandBar.astro';
import BrandMarquee from '../components/BrandMarquee.astro';
import Button from '../components/Button.astro';
import Hero from '../components/Hero.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME, heroImages } from '../data/site';
import { brands } from '../data/brands';
---

<Layout title={`About ${BUSINESS_NAME} | Bristol's Trade Counter`} description="Ashmead Roofing Supplies Ltd — Bristol's trusted roofing trade counter supplying professional roofers across the South West. Expert advice, massive stock, fast delivery.">
  <Hero
    title="More About Ashmead"
    subtitle="Bristol's trusted roofing trade counter — supplying professional roofers with quality materials, expert advice and fast delivery across the South West."
    image={heroImages.about}
    variant="full"
  >
    <Button variant="primary" href={PHONE_HREF} icon="phone" size="lg">Call {PHONE}</Button>
    <Button variant="white" href="/contact" size="lg">Contact Us</Button>
  </Hero>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <section class="section-white section-padding">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Our Story</h2>
          <p class="text-body leading-relaxed mb-4">Ashmead Roofing Supplies Ltd Bristol supply roofing supplies to the Bristol and Bath roofing and building trades. With a dedicated team and a diverse wealth of roofing knowledge, we believe we can source and supply just about any roofing product you may require.</p>
          <p class="text-body leading-relaxed mb-4">All our tiles are stocked at our own warehouse depot in Bristol and are often available for immediate delivery – we supply hundreds of contractors, homeowners and property builders on a daily basis.</p>
          <p class="text-body leading-relaxed mb-4">Our aim is to continuously increase our range to provide you with competitive and quality products for all your roofing needs. Can’t see something you are looking for? Give us a call and we will be happy to source it for you. We can also offer friendly, helpful advice and an estimation service. Our knowledgeable staff can provide you with extensive product information and help you open a trade account if needed.</p>
          <p class="text-body leading-relaxed mb-4">Take some time to look around our website where you will be able to find information on all the products you may need. When it comes to roofing supplies in Bristol we are your one-stop shop.</p>
          <p class="text-body leading-relaxed">{BUSINESS_NAME} was founded on a simple principle: give professional roofers the materials they need, when they need them, at prices that keep them competitive. From our Bristol depot we've built a reputation for stock availability, trade expertise and reliable delivery that keeps projects on track.</p>
        </div>
        <div>
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Why Trade Roofers Choose Us</h2>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-body"><strong class="text-charcoal">Massive stock holding</strong> — One of the widest ranges of roofing materials in the South West, ready for immediate collection or next-day delivery.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-body"><strong class="text-charcoal">Trade expertise</strong> — Our team knows roofing. We advise on products, calculate quantities and help specify the right system first time.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-body"><strong class="text-charcoal">Trade pricing</strong> — Competitive, honest pricing without the inflated margins. What you see is what you get.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-body"><strong class="text-charcoal">Fast delivery</strong> — Our fleet covers Bristol, Bath, Somerset, Gloucester and Wiltshire. Need it faster? Collect from our Bristol depot.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-body"><strong class="text-charcoal">Leading brands</strong> — We supply Redland, Marley, Velux, Cupa Pizarras, A. Proctor Group, Rockwool, Kober, Kytun, FloPlast, Roto and British Lead Mills.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-section-highlight section-padding">
    <div class="container text-center">
      <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-charcoal mb-4">Call Us Today On: {PHONE}</h2>
      <p class="text-body max-w-2xl mx-auto mb-8">Speak to our trade counter team for advice, stock availability, trade accounts and delivery options across the South West.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button variant="primary" href="phone" icon="phone" size="lg">Call {PHONE}</Button>
        <a href="/contact" class="inline-block bg-white hover:bg-gray-100 text-charcoal font-bold px-8 py-4 rounded border-2 border-charcoal transition-colors text-lg text-center">Contact Us</a>
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>