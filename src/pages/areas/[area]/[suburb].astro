---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBanner from '../../../components/CtaBanner.astro';
import SectionLabel from '../../../components/SectionLabel.astro';
import Hero from '../../../components/Hero.astro';
import AnimatedSection from '../../../components/AnimatedSection.astro';
import Button from '../../../components/Button.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME, CANONICAL_URL, heroImages } from '../../../data/site';
import { areas } from '../../../data/areas';
import { brands } from '../../../data/brands';
import BrandMarquee from '../../../components/BrandMarquee.astro';

export function getStaticPaths() {
  const paths: { params: { area: string; suburb: string }; props: { area: any; suburb: any } }[] = [];
  areas.forEach(area => {
    if (area.suburbs) {
      area.suburbs.forEach(suburb => {
        paths.push({
          params: { area: area.slug, suburb: suburb.slug },
          props: { area, suburb },
        });
      });
    }
  });
  return paths;
}

const { area, suburb } = Astro.props;
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Areas We Cover', href: '/areas' },
  { label: area.name, href: `/areas/${area.slug}` },
  { label: suburb.name },
];

const suburbSchema = {
  "@context": "https://schema.org",
  "@type": "ServiceArea",
  name: `${BUSINESS_NAME} - ${suburb.name}`,
  provider: { "@type": "LocalBusiness", name: BUSINESS_NAME },
  areaServed: { "@type": "City", name: suburb.name },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${CANONICAL_URL}/` },
    { "@type": "ListItem", position: 2, name: "Areas We Cover", item: `${CANONICAL_URL}/areas/` },
    { "@type": "ListItem", position: 3, name: area.name, item: `${CANONICAL_URL}/areas/${area.slug}/` },
    { "@type": "ListItem", position: 4, name: suburb.name },
  ],
};
---

<Layout title={suburb.metaTitle} description={suburb.metaDescription} schema={[suburbSchema, breadcrumbSchema]} ogImage={heroImages[area.slug as keyof typeof heroImages]}>
  
  <Hero
    eyebrow="Local Delivery"
    title={suburb.h1.replace(` Roofing Supplies`, '')}
    accent="Roofing Supplies"
    description={`${suburb.shortDesc} Trade pricing, next-day delivery and expert advice for roofers in ${suburb.name}.`}
    image={heroImages[area.slug as keyof typeof heroImages]}
    ctaPrimary={{ label: 'Call to Order', href: PHONE_HREF, icon: 'phone' }}
    ctaSecondary={{ label: 'Get a Quote', href: '/contact', icon: 'arrow' }}
    minHeight="min-h-[55vh] md:min-h-[65vh]"
  />

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Main content -->
  <section class="section-white section-padding">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12">
        
        <!-- Main copy -->
        <div class="lg:col-span-8">
          <AnimatedSection>
            <Breadcrumb items={breadcrumbItems} />
            
            <div class="mt-6">
              <SectionLabel text={`${suburb.name} Delivery`} />
            </div>
            
            <h2 class="text-charcoal font-heading text-3xl md:text-4xl font-bold uppercase tracking-wide mb-6">
              Roofing Supply in {suburb.name}
            </h2>
            
            <div class="prose prose-lg text-body leading-relaxed space-y-4" set:html={suburb.longDesc} />
          </AnimatedSection>
          
          <AnimatedSection delay={0.1} class="mt-12">
            <div class="bg-section rounded-2xl p-6 md:p-8">
              <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-6">Why Roofers in {suburb.name} Choose Ashmead</h3>
              
              <ul class="space-y-4">
                <li class="flex items-start gap-3 text-body">
                  <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Huge stock at our Bristol depot, just minutes from {suburb.name}.</span>
                </li>
                <li class="flex items-start gap-3 text-body">
                  <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Next-day delivery to {suburb.name} and across {area.name}.</span>
                </li>
                <li class="flex items-start gap-3 text-body">
                  <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Trade pricing and expert product advice.</span>
                </li>
                <li class="flex items-start gap-3 text-body">
                  <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Roofing materials for heritage, modern and new-build properties.</span>
                </li>
              </ul>
            </div>
          </AnimatedSection>
        </div>
        
        <!-- Sidebar CTA -->
        <div class="lg:col-span-4">
          <AnimatedSection class="bg-charcoal rounded-2xl p-6 md:p-8 sticky top-28">
            <h3 class="text-white font-heading text-xl font-bold uppercase tracking-wide mb-4">Order for {suburb.name}</h3>
            
            <p class="text-white/70 mb-6">Call our trade team now for expert advice, competitive pricing and fast delivery to {suburb.name}.</p>
            
            <div class="flex flex-col gap-3">
              <Button variant="primary" href={PHONE_HREF} icon="phone">{PHONE}</Button>
              <Button variant="white" href="/contact">Get a Quote</Button>
            </div>
            
            <hr class="border-white/20 my-6" />
            
            <p class="text-white/60 text-sm">
              Based in {area.name}? <a href={`/areas/${area.slug}`} class="text-accent hover:underline">View all {area.name} areas.</a>
            </p>
          </AnimatedSection>
        </div>
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>
