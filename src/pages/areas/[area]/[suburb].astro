---
import Layout from '../../../layouts/Layout.astro';
import Button from '../../../components/Button.astro';
import CtaBanner from '../../../components/CtaBanner.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME } from '../../../data/site';
import { areas, getSuburb, getArea } from '../../../data/areas';

export function getStaticPaths() {
  const paths: { params: { area: string; suburb: string }; props: { area: any; suburb: any } }[] = [];
  areas.forEach(area => {
    if (area.suburbs) {
      area.suburbs.forEach(suburb => {
        paths.push({
          params: { area: area.slug, suburb: suburb.slug },
          props: { area, suburb },
        });
      });
    }
  });
  return paths;
}

const { area, suburb } = Astro.props;
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Areas We Cover', href: '/areas' },
  { label: area.name, href: `/areas/${area.slug}` },
  { label: suburb.name },
];
---

<Layout title={suburb.metaTitle} description={suburb.metaDescription}>
  <section class="bg-section-highlight section-padding">
    <div class="container">
      <nav aria-label="Breadcrumb" class="text-body/60 text-sm font-heading uppercase tracking-widest mb-4">
        {breadcrumbItems.map((item, i) => (
          <>
            {i > 0 && <span class="mx-2">/</span>}
            {item.href ? (
              <a href={item.href} class="hover:text-primary transition-colors">{item.label}</a>
            ) : (
              <span>{item.label}</span>
            )}
          </>
        ))}
      </nav>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">{suburb.h1}</h1>
      <p class="text-lg text-body max-w-2xl mb-8">{suburb.shortDesc}</p>
      <Button variant="primary" href="phone" icon="phone" size="lg">Call {PHONE}</Button>
    </div>
  </section>

  <section class="section-white section-padding">
    <div class="container">
      <div class="max-w-4xl">
        <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">{suburb.h1} — Expert Roofing Supply</h2>
        <div class="prose prose-lg text-body leading-relaxed space-y-4" set:html={suburb.longDesc} />
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-section-highlight p-6 rounded">
          <h3 class="text-xl font-bold font-heading uppercase tracking-wide text-charcoal mb-4">Why Roofers in {suburb.name} Choose Ashmead</h3>
          <ul class="space-y-3 text-body">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Huge stock at our Bristol depot, just minutes from {suburb.name}</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Next-day delivery to {suburb.name} and across {area.name}</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Trade pricing and expert product advice</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Roofing materials for heritage, modern and new-build properties</span>
            </li>
          </ul>
        </div>

        <div class="bg-primary p-6 rounded text-white">
          <h3 class="text-xl font-bold font-heading uppercase tracking-wide mb-4">Order for {suburb.name} Today</h3>
          <p class="text-white/90 mb-6">Call our trade team now for expert advice, competitive pricing and fast delivery to {suburb.name}.</p>
          <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 bg-white text-primary font-bold px-6 py-3 rounded hover:bg-gray-100 transition-colors text-lg w-full">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {PHONE}
          </a>
          <a href="/contact" class="mt-3 inline-flex items-center justify-center border-2 border-white text-white font-bold px-6 py-3 rounded hover:bg-white hover:text-primary transition-colors text-lg w-full">
            Get a Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner />
</Layout>