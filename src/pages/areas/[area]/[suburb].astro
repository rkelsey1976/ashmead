---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBanner from '../../../components/CtaBanner.astro';
import SectionLabel from '../../../components/SectionLabel.astro';
import AnimatedSection from '../../../components/AnimatedSection.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME, CANONICAL_URL, heroImages } from '../../../data/site';
import { areas } from '../../../data/areas';
import { brands } from '../../../data/brands';
import BrandMarquee from '../../../components/BrandMarquee.astro';

export function getStaticPaths() {
  const paths: { params: { area: string; suburb: string }; props: { area: any; suburb: any } }[] = [];
  areas.forEach(area => {
    if (area.suburbs) {
      area.suburbs.forEach(suburb => {
        paths.push({
          params: { area: area.slug, suburb: suburb.slug },
          props: { area, suburb },
        });
      });
    }
  });
  return paths;
}

const { area, suburb } = Astro.props;
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Areas We Cover', href: '/areas' },
  { label: area.name, href: `/areas/${area.slug}` },
  { label: suburb.name },
];

const suburbSchema = {
  "@context": "https://schema.org",
  "@type": "ServiceArea",
  name: `${BUSINESS_NAME} - ${suburb.name}`,
  provider: { "@type": "LocalBusiness", name: BUSINESS_NAME },
  areaServed: { "@type": "City", name: suburb.name },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${CANONICAL_URL}/` },
    { "@type": "ListItem", position: 2, name: "Areas We Cover", item: `${CANONICAL_URL}/areas/` },
    { "@type": "ListItem", position: 3, name: area.name, item: `${CANONICAL_URL}/areas/${area.slug}/` },
    { "@type": "ListItem", position: 4, name: suburb.name },
  ],
};
---

<Layout title={suburb.metaTitle} description={suburb.metaDescription} schema={[suburbSchema, breadcrumbSchema]} ogImage={heroImages[area.slug as keyof typeof heroImages]}>
  
  <!-- Hero -->
  <section class="relative min-h-[55vh] md:min-h-[65vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImages[area.slug as keyof typeof heroImages]} alt={`Roofing supplies ${suburb.name}`} class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-charcoal via-charcoal/90 to-charcoal/40"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/40 to-charcoal/40"></div>
    </div>
    
    <div class="container relative z-10 py-20 md:py-28">
      <div class="max-w-4xl">
        <Breadcrumb items={breadcrumbItems} light={true} />
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-heading font-bold uppercase leading-[0.92] tracking-wide text-white mt-6 mb-6">
          {suburb.h1.replace(` Roofing Supplies`, '')}
          <span class="block text-accent">Roofing Supplies</span>
        </h1>
        
        <p class="text-lg md:text-xl text-white/80 max-w-2xl mb-10 leading-relaxed">
          {suburb.shortDesc}
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-white font-semibold px-8 py-4 rounded-md transition-all hover:shadow-lg text-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call {PHONE}
          </a>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white text-white hover:bg-white hover:text-charcoal font-semibold px-8 py-4 rounded-md transition-all text-lg">
            Get a Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Main content -->
  <section class="section-white section-padding">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12">
        
        <!-- Main copy -->
        <div class="lg:col-span-8">
          <AnimatedSection>
            <SectionLabel text={`${suburb.name} Delivery`} />
            
            <h2 class="text-charcoal font-heading text-3xl md:text-4xl font-bold uppercase tracking-wide mb-6">
              {suburb.h1} — Expert Roofing Supply
            </h2>
            
            <div class="prose prose-lg text-body leading-relaxed space-y-4" set:html={suburb.longDesc} />
          </AnimatedSection>
          
          <AnimatedSection delay={0.1} class="mt-12">
            <div class="bg-section rounded-2xl p-6 md:p-8">
              <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-6">Why Roofers in {suburb.name} Choose Ashmead</h3>
              
              <ul class="space-y-4">
                <li class="flex items-start gap-3 text-body">
                  <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Huge stock at our Bristol depot, just minutes from {suburb.name}.</span>
                </li>
                <li class="flex items-start gap-3 text-body">
                  <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Next-day delivery to {suburb.name} and across {area.name}.</span>
                </li>
                <li class="flex items-start gap-3 text-body">
                  <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Trade pricing and expert product advice.</span>
                </li>
                <li class="flex items-start gap-3 text-body">
                  <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Roofing materials for heritage, modern and new-build properties.</span>
                </li>
              </ul>
            </div>
          </AnimatedSection>
        </div>
        
        <!-- Sidebar CTA -->
        <div class="lg:col-span-4">
          <AnimatedSection class="bg-charcoal rounded-2xl p-6 md:p-8 sticky top-28">
            <h3 class="text-white font-heading text-xl font-bold uppercase tracking-wide mb-4">Order for {suburb.name}</h3>
            
            <p class="text-white/70 mb-6">Call our trade team now for expert advice, competitive pricing and fast delivery to {suburb.name}.</p>
            
            <div class="flex flex-col gap-3">
              <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-white font-semibold px-6 py-4 rounded-md transition-colors text-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                {PHONE}
              </a>
              <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-section text-charcoal font-semibold px-6 py-4 rounded-md transition-colors text-lg">
                Get a Quote
              </a>
            </div>
            
            <hr class="border-white/20 my-6" />
            
            <p class="text-white/60 text-sm">
              Based in {area.name}? <a href={`/areas/${area.slug}`} class="text-accent hover:underline">View all {area.name} areas.</a>
            </p>
          </AnimatedSection>
        </div>
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>
