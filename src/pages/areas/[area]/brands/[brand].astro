---
import Layout from '../../../../layouts/Layout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBanner from '../../../../components/CtaBanner.astro';
import BrandMarquee from '../../../../components/BrandMarquee.astro';
import SectionLabel from '../../../../components/SectionLabel.astro';
import Hero from '../../../../components/Hero.astro';
import AnimatedSection from '../../../../components/AnimatedSection.astro';
import { BUSINESS_NAME, CANONICAL_URL, heroImages } from '../../../../data/site';
import { areas } from '../../../../data/areas';
import { brands, brandByName } from '../../../../data/brands';
import { areaBrands } from '../../../../data/areaBrands';
import { areaProducts } from '../../../../data/areaProducts';
import { products } from '../../../../data/products';
import { getSiteSettings } from '../../../../lib/siteSettings';

export function getStaticPaths() {
  return areaBrands.map(ab => {
    const area = areas.find(a => a.slug === ab.areaSlug)!;
    return {
      params: { area: ab.areaSlug, brand: ab.brandSlug },
      props: { area, areaBrand: ab },
    };
  });
}

const { area, areaBrand } = Astro.props;
const { PHONE, PHONE_HREF } = await getSiteSettings();

const heroImage = heroImages[area.slug as keyof typeof heroImages] || heroImages.areas;

const brandData = brandByName[areaBrand.brandName];

// Related product pages for this area
const relatedProducts = areaBrand.products
  .map(slug => {
    const ap = areaProducts.find(a => a.areaSlug === area.slug && a.productSlug === slug);
    const product = products.find(p => p.slug === slug);
    return ap && product ? { ap, product } : null;
  })
  .filter(Boolean) as { ap: typeof areaProducts[0]; product: typeof products[0] }[];

// Other brand+area pages for same area (cross-link to sibling brands)
const otherAreaBrands = areaBrands.filter(
  ab => ab.areaSlug === area.slug && ab.brandSlug !== areaBrand.brandSlug
);

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Areas We Cover', href: '/areas' },
  { label: area.name, href: `/areas/${area.slug}` },
  { label: areaBrand.brandName },
];

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: BUSINESS_NAME,
  description: areaBrand.metaDescription,
  areaServed: { "@type": "AdministrativeArea", name: area.name },
  brand: { "@type": "Brand", name: areaBrand.brandName },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${CANONICAL_URL}/` },
    { "@type": "ListItem", position: 2, name: "Areas We Cover", item: `${CANONICAL_URL}/areas/` },
    { "@type": "ListItem", position: 3, name: area.name, item: `${CANONICAL_URL}/areas/${area.slug}/` },
    { "@type": "ListItem", position: 4, name: areaBrand.brandName },
  ],
};
---

<Layout title={areaBrand.metaTitle} description={areaBrand.metaDescription} schema={[pageSchema, breadcrumbSchema]} ogImage={heroImage}>

  <Hero
    eyebrow={`${area.name} Authorised Stockist`}
    title={areaBrand.brandName}
    accent={area.name}
    description={areaBrand.intro}
    image={heroImage}
    ctaPrimary={{ label: 'Call to Order', href: PHONE_HREF, icon: 'phone' }}
    ctaSecondary={{ label: 'Get a Quote', href: '/contact', icon: 'arrow' }}
    minHeight="min-h-[55vh] md:min-h-[65vh]"
  />

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Main content -->
  <section class="section-white section-padding">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-start">

        <!-- Main copy -->
        <div class="lg:col-span-8">
          <AnimatedSection>
            <Breadcrumb items={breadcrumbItems} />
            <div class="mt-6">
              <SectionLabel text={`${areaBrand.brandName} · ${area.name}`} />
            </div>

            <h2 class="text-charcoal font-heading text-3xl md:text-4xl lg:text-5xl font-bold uppercase tracking-wide mb-6">
              {areaBrand.h1}
            </h2>

            {brandData?.logo && (
              <div class="mb-8">
                <img
                  src={brandData.logo}
                  alt={`${areaBrand.brandName} logo`}
                  class="h-10 object-contain"
                  loading="lazy"
                />
              </div>
            )}

            <div class="prose prose-lg text-body leading-relaxed">
              {areaBrand.longDesc.split('\n\n').map(para => (
                <p class="mb-4">{para}</p>
              ))}
            </div>
          </AnimatedSection>

          <!-- Related product pages -->
          {relatedProducts.length > 0 && (
            <AnimatedSection delay={0.1} class="mt-12">
              <div class="bg-section border border-border p-6 md:p-8">
                <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-2">
                  {areaBrand.brandName} Products in {area.name}
                </h3>
                <p class="text-body text-sm mb-6">Local delivery and trade pricing for every {areaBrand.brandName} product category.</p>
                <div class="grid sm:grid-cols-2 gap-3">
                  {relatedProducts.map(({ ap, product }) => (
                    <a
                      href={`/areas/${area.slug}/products/${product.slug}`}
                      class="group flex items-center justify-between gap-3 bg-white border border-border px-4 py-3.5 hover:border-primary hover:shadow-sm transition-all duration-200"
                    >
                      <div class="flex items-center gap-3">
                        <div class="w-2 h-2 bg-accent flex-shrink-0"></div>
                        <div>
                          <p class="text-charcoal text-sm font-semibold group-hover:text-primary transition-colors">{product.name}</p>
                          <p class="text-body text-xs mt-0.5 leading-tight line-clamp-1">{ap.intro}</p>
                        </div>
                      </div>
                      <svg class="w-4 h-4 text-body-light group-hover:text-accent transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  ))}
                </div>
              </div>
            </AnimatedSection>
          )}

          <!-- Other brands in this area -->
          {otherAreaBrands.length > 0 && (
            <AnimatedSection delay={0.2} class="mt-12">
              <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-5">
                Other Brands We Stock in {area.name}
              </h3>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                {otherAreaBrands.map(ab => (
                  <a
                    href={`/areas/${area.slug}/brands/${ab.brandSlug}`}
                    class="group flex items-center justify-between gap-2 bg-section hover:bg-primary/10 border border-border hover:border-primary/30 px-4 py-3 transition-all"
                  >
                    <span class="text-sm font-semibold text-charcoal group-hover:text-primary transition-colors">{ab.brandName}</span>
                    <svg class="w-4 h-4 text-primary opacity-0 group-hover:opacity-100 transition-opacity shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                ))}
              </div>
              <a href={`/areas/${area.slug}`} class="inline-flex items-center gap-1.5 text-primary hover:text-primary-hover font-semibold text-sm mt-4 transition-colors">
                All {area.name} roofing supplies
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </AnimatedSection>
          )}
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-4">
          <AnimatedSection class="sticky top-28 space-y-4">

            <!-- CTA card -->
            <div class="bg-charcoal p-7">
              <p class="text-white/40 text-[10px] font-semibold uppercase tracking-[0.22em] font-body mb-1">Authorised stockist</p>
              <a href={PHONE_HREF} class="block font-heading font-bold text-accent hover:text-white transition-colors duration-300 leading-none mb-6"
                 style="font-size: clamp(1.5rem, 3vw, 2rem)">{PHONE}</a>

              <ul class="space-y-3 mb-7 border-t border-white/10 pt-6">
                {[
                  `Authorised ${areaBrand.brandName} stockist`,
                  `Serving ${area.name} from Keynsham depot`,
                  'Same-day collection or next-day delivery',
                  'Trade pricing & expert specification advice',
                ].map(point => (
                  <li class="flex items-start gap-2.5 text-white/75 text-sm font-body leading-snug">
                    <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {point}
                  </li>
                ))}
              </ul>

              <div class="flex flex-col gap-2.5">
                <a href={PHONE_HREF}
                   class="flex items-center justify-center gap-2 bg-accent text-charcoal font-heading font-bold uppercase tracking-wide text-sm px-5 py-3 hover:bg-white transition-colors duration-300">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  Call Now
                </a>
                <a href="/contact"
                   class="flex items-center justify-center gap-2 border border-white/20 text-white font-heading font-bold uppercase tracking-wide text-sm px-5 py-3 hover:border-white hover:bg-white/5 transition-all duration-300">
                  Get a Quote
                </a>
              </div>
            </div>

            <!-- Drive time card -->
            {area.driveTime && (
              <div class="bg-section border border-border p-5 flex items-center gap-4">
                <div class="w-10 h-10 bg-primary/10 text-primary flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-charcoal font-heading font-bold text-sm uppercase tracking-wide">{area.driveTime} from depot</p>
                  <p class="text-body text-xs mt-0.5">Keynsham, Bristol BS31 1TU</p>
                </div>
              </div>
            )}

            <!-- Link to brand website -->
            {brandData?.url && (
              <a href={brandData.url} target="_blank" rel="noopener noreferrer"
                 class="flex items-center justify-between gap-3 bg-section border border-border p-5 hover:border-primary transition-colors group">
                <div>
                  <p class="text-charcoal font-heading font-bold text-sm uppercase tracking-wide group-hover:text-primary transition-colors">{areaBrand.brandName} Website</p>
                  <p class="text-body text-xs mt-0.5">Technical data, product specs &amp; installation guides</p>
                </div>
                <svg class="w-5 h-5 text-body-light group-hover:text-primary transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}

          </AnimatedSection>
        </div>

      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>
