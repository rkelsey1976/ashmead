---
import Layout from '../../layouts/Layout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { areas } from '../../data/areas';
import { products } from '../../data/products';
import { PHONE, PHONE_HREF } from '../../data/site';

export function getStaticPaths() {
  return areas.map(area => ({
    params: { slug: area.slug },
    props: { area }
  }));
}

const { area } = Astro.props;
---

<Layout title={area.metaTitle} description={area.metaDescription}>
  <!-- Area Hero -->
  <section class="bg-section-highlight py-16 md:py-24 border-b-4 border-primary">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-sm text-body mb-6">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/areas" class="hover:text-primary transition-colors">Areas</a>
        <span class="mx-2">/</span>
        <span class="text-charcoal">{area.name}</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">{area.h1}</h1>
      <p class="text-lg text-body max-w-3xl mb-8">{area.shortDesc}</p>
      <a href={PHONE_HREF} class="inline-flex items-center gap-2 bg-primary hover:bg-primary-hover text-white font-bold px-8 py-4 rounded text-lg transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call {PHONE}
      </a>
    </div>
  </section>

  <!-- Area Description -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Roofing Supplies in {area.name}</h2>
        <p class="text-body leading-relaxed">{area.longDesc}</p>
      </div>
    </div>
  </section>

  <!-- Cross-link: Products available in this area -->
  <section class="bg-section py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal text-center mb-8">Products Available in {area.name}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map(product => (
          <a href={`/products/${product.slug}`} class="group bg-white rounded-lg p-6 transition-all border border-border hover:border-primary hover:shadow-lg">
            <h3 class="text-charcoal font-heading text-lg font-bold uppercase tracking-wide mb-2 group-hover:text-primary transition-colors">{product.name}</h3>
            <p class="text-body text-sm leading-relaxed mb-3">{product.shortDesc}</p>
            <span class="text-primary text-sm font-medium group-hover:text-primary-hover transition-colors">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Other areas -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal text-center mb-8">Other Areas We Cover</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {areas.filter(a => a.slug !== area.slug).map(a => (
          <a href={`/areas/${a.slug}`} class="group bg-white rounded-lg p-5 text-center transition-all border border-border hover:border-primary hover:shadow-lg">
            <h3 class="text-charcoal font-heading text-lg font-bold uppercase tracking-wide group-hover:text-primary transition-colors">{a.name}</h3>
            <p class="text-body text-sm mt-2">{a.shortDesc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner title={`Roofing Supplies ${area.name}`} subtitle={`Call our trade team for pricing and delivery across ${area.name} and the surrounding area.`} />
</Layout>