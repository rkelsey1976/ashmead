---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Button from '../../components/Button.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import AreaCard from '../../components/AreaCard.astro';
import ProductCard from '../../components/ProductCard.astro';
import { areas } from '../../data/areas';
import { products } from '../../data/products';
import { PHONE } from '../../data/site';

export function getStaticPaths() {
  return areas.map(area => ({
    params: { slug: area.slug },
    props: { area }
  }));
}

const { area } = Astro.props;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Areas', href: '/areas' },
  { label: area.name, href: `/areas/${area.slug}` }
];
---

<Layout title={area.metaTitle} description={area.metaDescription}>
  <!-- Area Hero with house watermark -->
  <section class="bg-section-highlight py-16 md:py-24 border-b-4 border-primary relative overflow-hidden">
    <div class="absolute right-[-5%] top-1/2 -translate-y-1/2 w-2/5 max-w-md opacity-[0.04] pointer-events-none">
      <svg viewBox="0 0 120 69" fill="currentColor" class="text-charcoal w-full h-auto"><polygon points="60,0 120,69 0,69" /></svg>
    </div>
    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <Breadcrumb items={breadcrumbItems} />
      <h1 class="text-3xl md:text-5xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">{area.h1}</h1>
      <p class="text-lg text-body max-w-3xl mb-8">{area.shortDesc}</p>
      <Button variant="primary" href="phone" icon="phone" size="lg">Call {PHONE}</Button>
    </div>
  </section>

  <!-- Area Description -->
  <section class="section-white section-padding">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Roofing Supplies in {area.name}</h2>
        <p class="text-body leading-relaxed">{area.longDesc}</p>
      </div>
    </div>
  </section>

  <!-- Cross-link: Products available in this area -->
  <section class="section-grey section-padding">
    <div class="container">
      <SectionHeading text={`Products Available in ${area.name}`} />
      <p class="text-body text-center max-w-2xl mx-auto mb-10">We supply roofing materials across {area.name}. Click on any product for details, pricing and availability.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map(product => (
          <ProductCard name={product.name} shortDesc={product.shortDesc} href={`/products/${product.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <!-- Other areas -->
  <section class="section-white section-padding">
    <div class="container">
      <SectionHeading text="Other Areas We Cover" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {areas.filter(a => a.slug !== area.slug).map(a => (
          <AreaCard name={a.name} shortDesc={a.shortDesc} href={`/areas/${a.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner title={`Roofing Supplies ${area.name}`} subtitle={`Call our trade team for pricing and delivery across ${area.name} and the surrounding area.`} />
</Layout>