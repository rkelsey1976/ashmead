---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Button from '../../components/Button.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME } from '../../data/site';
import { areas } from '../../data/areas';

export function getStaticPaths() {
  return areas.map(area => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Areas We Cover', href: '/areas' },
  { label: area.name },
];
---

<Layout title={`${area.h1} | Ashmead Roofing Supplies`} description={area.metaDesc}>
  <section class="bg-section-highlight section-padding">
    <div class="container">
      <div class="text-body/60 text-sm font-heading uppercase tracking-widest mb-4">
        {breadcrumbItems.map((item, i) => (
          <>{i > 0 && <span class="mx-2">/</span>}<a href={item.href} class="hover:text-primary transition-colors">{item.label}</a></>
        ))}
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">{area.h1}</h1>
      <p class="text-lg text-body max-w-2xl mb-8">{area.shortDesc}</p>
      <Button variant="primary" href="phone" icon="phone" size="lg">Call {PHONE}</Button>
    </div>
  </section>

  <section class="section-white section-padding">
    <div class="container">
      <div class="max-w-4xl">
        <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">{area.h1} — Expert Roofing Supply</h2>
        <div class="prose prose-lg text-body leading-relaxed space-y-4" set:html={area.longDesc} />
      </div>

      {area.products && area.products.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Roofing Supplies in {area.name}</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {area.products.map(product => (
              <li class="flex items-center gap-2 text-body">
                <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <a href={`/products/${product.slug}`} class="hover:text-primary transition-colors">{product.name}</a>
              </li>
            ))}
          </ul>
        </div>
      )}
      {area.suburbs && area.suburbs.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Areas We Serve in {area.name}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {area.suburbs.map(suburb => (
              <a href={`/areas/${area.slug}/${suburb.slug}`} class="flex items-center justify-between p-4 bg-section-highlight rounded hover:bg-primary hover:text-white group transition-colors">
                <span class="font-heading font-bold uppercase tracking-wide text-charcoal group-hover:text-white">{suburb.name}</span>
                <svg class="w-5 h-5 text-primary group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>

  <CtaBanner />
</Layout>