---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import AnimatedSection from '../../components/AnimatedSection.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME, CANONICAL_URL, heroImages } from '../../data/site';
import { areas } from '../../data/areas';
import { products } from '../../data/products';
import { brands } from '../../data/brands';
import BrandMarquee from '../../components/BrandMarquee.astro';

export function getStaticPaths() {
  return areas.map(area => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Areas We Cover', href: '/areas' },
  { label: area.name },
];

const heroImage = area.image || heroImages[area.slug as keyof typeof heroImages] || heroImages.areas;

const areaSchema = {
  "@context": "https://schema.org",
  "@type": "ServiceArea",
  name: `${BUSINESS_NAME} - ${area.name}`,
  provider: { "@type": "LocalBusiness", name: BUSINESS_NAME },
  areaServed: { "@type": "AdministrativeArea", name: area.name },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${CANONICAL_URL}/` },
    { "@type": "ListItem", position: 2, name: "Areas We Cover", item: `${CANONICAL_URL}/areas/` },
    { "@type": "ListItem", position: 3, name: area.name },
  ],
};

const suburbNames = area.suburbs ? area.suburbs.map(s => s.name) : [];
---

<Layout title={`${area.h1} | Ashmead Roofing Supplies`} description={area.metaDescription} schema={[areaSchema, breadcrumbSchema]} ogImage={heroImage}>
  
  <!-- Hero -->
  <section class="relative min-h-[60vh] md:min-h-[70vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt={area.h1} class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-charcoal via-charcoal/90 to-charcoal/40"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/40 to-charcoal/40"></div>
    </div>
    
    <div class="container relative z-10 py-20 md:py-28">
      <div class="max-w-4xl">
        <Breadcrumb items={breadcrumbItems} light={true} />
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-heading font-bold uppercase leading-[0.92] tracking-wide text-white mt-6 mb-6">
          {area.h1.replace(' Roofing Supplies', '')}
          <span class="block text-accent">Roofing Supplies</span>
        </h1>
        
        <p class="text-lg md:text-xl text-white/80 max-w-2xl mb-10 leading-relaxed">
          {area.shortDesc}
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-white font-semibold px-8 py-4 rounded-md transition-all hover:shadow-lg text-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call {PHONE}
          </a>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white text-white hover:bg-white hover:text-charcoal font-semibold px-8 py-4 rounded-md transition-all text-lg">
            Get a Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Main content -->
  <section class="section-white section-padding">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-start">
        
        <!-- Main copy -->
        <div class="lg:col-span-8">
          <AnimatedSection>
            <SectionLabel text={`${area.name} Delivery`} />
            
            <h2 class="text-charcoal font-heading text-3xl md:text-4xl lg:text-5xl font-bold uppercase tracking-wide mb-6">
              Expert Roofing Supply in {area.name}
            </h2>
            
            <div class="prose prose-lg text-body leading-relaxed space-y-4" set:html={area.longDesc} />
          </AnimatedSection>
          
          {area.products && area.products.length > 0 && (
            <AnimatedSection delay={0.1} class="mt-12">
              <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-6">Roofing Supplies Available in {area.name}</h3>
              
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {area.products.map(product => (
                  <li class="flex items-center gap-3 text-body p-4 bg-section rounded-xl">
                    <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <a href={`/products/${product.slug}`} class="hover:text-primary transition-colors font-medium">{product.name}</a>
                  </li>
                ))}
              </ul>
            </AnimatedSection>
          )}

          {suburbNames.length > 0 && (
            <AnimatedSection delay={0.15} class="mt-12">
              <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-4">Areas We Serve in {area.name}</h3>
              
              <div class="flex flex-wrap gap-2">
                {area.suburbs!.map(suburb => (
                  <a href={`/areas/${area.slug}/${suburb.slug}`} class="bg-white text-charcoal text-sm font-semibold uppercase tracking-wide px-4 py-2 rounded-full border border-border hover:border-primary hover:text-primary transition-colors">
                    {suburb.name}
                  </a>
                ))}
              </div>
            </AnimatedSection>
          )}
        </div>
        
        <!-- Sidebar -->
        <div class="lg:col-span-4">
          <AnimatedSection class="bg-charcoal rounded-2xl p-6 md:p-8 sticky top-28">
            <h3 class="text-white font-heading text-xl font-bold uppercase tracking-wide mb-6">Why Roofers Choose Ashmead</h3>
            
            <ul class="space-y-4 mb-8">
              <li class="flex items-start gap-3 text-white/90">
                <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Huge trade stock at our Bristol depot, ready for collection or delivery.</span>
              </li>
              <li class="flex items-start gap-3 text-white/90">
                <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Next-day delivery to {area.name} and across the South West.</span>
              </li>
              <li class="flex items-start gap-3 text-white/90">
                <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Trade pricing and expert advice on coverage, fixings and specification.</span>
              </li>
              <li class="flex items-start gap-3 text-white/90">
                <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Materials for heritage, modern and new-build properties.</span>
              </li>
            </ul>
            
            <div class="flex flex-col gap-3">
              <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-white font-semibold px-6 py-4 rounded-md transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                Call {PHONE}
              </a>
              <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-section text-charcoal font-semibold px-6 py-4 rounded-md transition-colors">
                Get a Quote
              </a>
            </div>
          </AnimatedSection>
        </div>
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>
