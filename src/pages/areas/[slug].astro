---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Button from '../../components/Button.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import AreaCard from '../../components/AreaCard.astro';
import ProductCard from '../../components/ProductCard.astro';
import { areas } from '../../data/areas';
import { products } from '../../data/products';
import { PHONE, heroImages } from '../../data/site';

export function getStaticPaths() {
  return areas.map(area => ({
    params: { slug: area.slug },
    props: { area }
  }));
}

const { area } = Astro.props;
const heroImage = heroImages[area.slug as keyof typeof heroImages] || heroImages.home;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Areas', href: '/areas' },
  { label: area.name, href: `/areas/${area.slug}` }
];
---

<Layout title={area.metaTitle} description={area.metaDescription}>
  <!-- Area Hero — full-width image with dark overlay -->
  <section class="relative overflow-hidden min-h-[320px]">
    <div class="absolute inset-0">
      <img src={heroImage} alt={area.name} class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-charcoal/70"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20 md:py-28 flex items-center justify-center min-h-[320px]">
      <div class="text-center max-w-3xl mx-auto">
        <div class="text-white/70 text-sm font-heading uppercase tracking-widest mb-3">
          {breadcrumbItems.map((item, i) => (
            <>{i > 0 && <span class="mx-2">/</span>}<a href={item.href} class="hover:text-white transition-colors">{item.label}</a></>
          ))}
        </div>
        <h1 class="text-3xl md:text-5xl font-bold font-heading uppercase tracking-wide text-white mb-4">{area.h1}</h1>
        <p class="text-lg text-white/90 mb-8">{area.shortDesc}</p>
        <Button variant="white" href="phone" icon="phone" size="lg">Call {PHONE}</Button>
      </div>
    </div>
  </section>

  <!-- Area Description -->
  <section class="section-white section-padding">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Roofing Supplies in {area.name}</h2>
        <p class="text-body leading-relaxed">{area.longDesc}</p>
      </div>
    </div>
  </section>

  <!-- Cross-link: Products available in this area -->
  <section class="section-grey section-padding">
    <div class="container">
      <SectionHeading text={`Products Available in ${area.name}`} />
      <p class="text-body text-center max-w-2xl mx-auto mb-10">We supply roofing materials across {area.name}. Click on any product for details, pricing and availability.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map(product => (
          <ProductCard name={product.name} shortDesc={product.shortDesc} href={`/products/${product.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <!-- Other areas -->
  <section class="section-white section-padding">
    <div class="container">
      <SectionHeading text="Other Areas We Cover" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {areas.filter(a => a.slug !== area.slug).map(a => (
          <AreaCard name={a.name} shortDesc={a.shortDesc} href={`/areas/${a.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner title={`Roofing Supplies ${area.name}`} subtitle={`Call our trade team for pricing and delivery across ${area.name} and the surrounding area.`} />
</Layout>