---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import BrandMarquee from '../../components/BrandMarquee.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import Hero from '../../components/Hero.astro';
import AnimatedSection from '../../components/AnimatedSection.astro';
import { BUSINESS_NAME, CANONICAL_URL, heroImages } from '../../data/site';
import { areas } from '../../data/areas';
import { brands } from '../../data/brands';
import { getSiteSettings } from '../../lib/siteSettings';
import { areaProducts } from '../../data/areaProducts';
import { products } from '../../data/products';
import { areaBrands } from '../../data/areaBrands';

export function getStaticPaths() {
  return areas.map(area => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const { PHONE, PHONE_HREF } = await getSiteSettings();

const areaBrandPages = areaBrands.filter(ab => ab.areaSlug === area.slug);

const areaProductPages = areaProducts
  .filter(ap => ap.areaSlug === area.slug)
  .map(ap => ({ ...ap, product: products.find(p => p.slug === ap.productSlug)! }))
  .filter(ap => ap.product);

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Areas We Cover', href: '/areas' },
  { label: area.name },
];

const heroImage = area.image || heroImages[area.slug as keyof typeof heroImages] || heroImages.areas;

const areaSchema = {
  "@context": "https://schema.org",
  "@type": "ServiceArea",
  name: `${BUSINESS_NAME} - ${area.name}`,
  provider: { "@type": "LocalBusiness", name: BUSINESS_NAME },
  areaServed: { "@type": "AdministrativeArea", name: area.name },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${CANONICAL_URL}/` },
    { "@type": "ListItem", position: 2, name: "Areas We Cover", item: `${CANONICAL_URL}/areas/` },
    { "@type": "ListItem", position: 3, name: area.name },
  ],
};
---

<Layout title={`${area.h1} | Ashmead Roofing Supplies`} description={area.metaDescription} schema={[areaSchema, breadcrumbSchema]} ogImage={heroImage}>

  <Hero
    eyebrow="Local Trade Delivery"
    title={`${area.name}`}
    accent="Roofing Supplies"
    description={`${area.shortDesc} Same-day collection from our Bristol depot and next-day delivery across ${area.name}.`}
    image={heroImage}
    ctaPrimary={{ label: 'Call for Delivery', href: PHONE_HREF, icon: 'phone' }}
    ctaSecondary={{ label: 'Get a Quote', href: '/contact', icon: 'arrow' }}
    minHeight="min-h-[60vh] md:min-h-[70vh]"
  />

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Main content -->
  <section class="section-white section-padding">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-start">

        <!-- Main copy -->
        <div class="lg:col-span-8">
          <AnimatedSection>
            <Breadcrumb items={breadcrumbItems} />
            <div class="mt-6">
              <SectionLabel text={`${area.name} Coverage`} />
            </div>

            <h2 class="text-charcoal font-heading text-3xl md:text-4xl lg:text-5xl font-bold uppercase tracking-wide mb-6">
              Roofing Supply in {area.name}
            </h2>

            <div class="prose prose-lg text-body leading-relaxed space-y-4" set:html={area.longDesc} />
          </AnimatedSection>

          {area.suburbs && area.suburbs.length > 0 && (
            <AnimatedSection delay={0.1} class="mt-14">
              <div class="border-t border-border pt-10">
                <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-2">
                  Areas We Serve in {area.name}
                </h3>
                <p class="text-body text-sm mb-8">{area.suburbs.length} towns and suburbs covered — click to see local information.</p>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-border">
                  {area.suburbs.map(suburb => (
                    <a
                      href={`/areas/${area.slug}/${suburb.slug}`}
                      class="group flex items-center justify-between bg-white px-4 py-3.5 hover:bg-section transition-colors duration-200"
                    >
                      <span class="text-charcoal text-sm font-semibold group-hover:text-primary transition-colors duration-200">{suburb.name}</span>
                      <svg class="w-3.5 h-3.5 text-border group-hover:text-accent transition-colors duration-200 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  ))}
                </div>
              </div>
            </AnimatedSection>
          )}
          {areaProductPages.length > 0 && (
            <AnimatedSection delay={0.2} class="mt-14">
              <div class="border-t border-border pt-10">
                <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-2">
                  Products We Supply in {area.name}
                </h3>
                <p class="text-body text-sm mb-8">Local delivery information and trade advice for every product category.</p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  {areaProductPages.map(ap => (
                    <a href={`/areas/${area.slug}/products/${ap.productSlug}`}
                       class="group flex items-center justify-between gap-3 bg-white border border-border px-4 py-3.5 hover:border-primary hover:shadow-sm transition-all duration-200">
                      <div class="flex items-center gap-3">
                        <div class="w-2 h-2 bg-accent flex-shrink-0"></div>
                        <span class="text-charcoal text-sm font-semibold group-hover:text-primary transition-colors">{ap.product.name}</span>
                      </div>
                      <svg class="w-3.5 h-3.5 text-body-light group-hover:text-accent transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  ))}
                </div>
              </div>
            </AnimatedSection>
          )}
          {areaBrandPages.length > 0 && (
            <AnimatedSection delay={0.3} class="mt-14">
              <div class="border-t border-border pt-10">
                <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-2">
                  Key Brands for {area.name}
                </h3>
                <p class="text-body text-sm mb-8">Authorised stockist for these leading brands — local advice, trade pricing and fast delivery.</p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                  {areaBrandPages.map(ab => (
                    <a href={`/areas/${area.slug}/brands/${ab.brandSlug}`}
                       class="group flex items-center justify-between gap-3 bg-white border border-border px-4 py-3.5 hover:border-primary hover:shadow-sm transition-all duration-200">
                      <div class="flex items-center gap-3">
                        <div class="w-2 h-2 bg-accent flex-shrink-0"></div>
                        <span class="text-charcoal text-sm font-semibold group-hover:text-primary transition-colors">{ab.brandName}</span>
                      </div>
                      <svg class="w-3.5 h-3.5 text-body-light group-hover:text-accent transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  ))}
                </div>
              </div>
            </AnimatedSection>
          )}
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-4">
          <AnimatedSection class="sticky top-28 space-y-4">

            <!-- CTA card -->
            <div class="bg-charcoal p-7">
              <p class="text-white/40 text-[10px] font-semibold uppercase tracking-[0.22em] font-body mb-1">Call us direct</p>
              <a href={PHONE_HREF} class="block font-heading font-bold text-accent hover:text-white transition-colors duration-300 leading-none mb-6"
                 style="font-size: clamp(1.5rem, 3vw, 2rem)">{PHONE}</a>

              <ul class="space-y-3 mb-7 border-t border-white/10 pt-6">
                {[
                  `Huge trade stock — ready for ${area.name}`,
                  'Same-day collection from Keynsham depot',
                  'Next-day delivery across the South West',
                  'Trade pricing & expert specification advice',
                ].map(point => (
                  <li class="flex items-start gap-2.5 text-white/75 text-sm font-body leading-snug">
                    <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {point}
                  </li>
                ))}
              </ul>

              <div class="flex flex-col gap-2.5">
                <a href={PHONE_HREF}
                   class="flex items-center justify-center gap-2 bg-accent text-charcoal font-heading font-bold uppercase tracking-wide text-sm px-5 py-3 hover:bg-white transition-colors duration-300">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  Call Now
                </a>
                <a href="/contact"
                   class="flex items-center justify-center gap-2 border border-white/20 text-white font-heading font-bold uppercase tracking-wide text-sm px-5 py-3 hover:border-white hover:bg-white/5 transition-all duration-300">
                  Get a Quote
                </a>
              </div>
            </div>

            <!-- Drive time card -->
            {area.driveTime && (
              <div class="bg-section border border-border p-5 flex items-center gap-4">
                <div class="w-10 h-10 bg-primary/10 text-primary flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-charcoal font-heading font-bold text-sm uppercase tracking-wide">{area.driveTime} from depot</p>
                  <p class="text-body text-xs mt-0.5">Keynsham, Bristol BS31 1TU</p>
                </div>
              </div>
            )}

          </AnimatedSection>
        </div>

      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>
