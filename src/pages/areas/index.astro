---
import Layout from '../../layouts/Layout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import AreaCard from '../../components/AreaCard.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import Hero from '../../components/Hero.astro';
import AnimatedSection from '../../components/AnimatedSection.astro';
import { PHONE, PHONE_HREF, heroImages } from '../../data/site';
import { areas } from '../../data/areas';
import { brands } from '../../data/brands';
import BrandMarquee from '../../components/BrandMarquee.astro';
---

<Layout title="Areas We Cover | Roofing Supplies Bristol, Bath, Somerset & Beyond | Ashmead" description="Ashmead Roofing Supplies delivers across Bristol, Bath, Somerset, Gloucester and Wiltshire. Trade prices, fast delivery. Call 0117 986 0600.">
  
  <Hero
    eyebrow="South West Coverage"
    title="Local Service,"
    accent="Regional Reach"
    description="Trade roofing supplies delivered across Bristol, Bath, Somerset, Gloucester and Wiltshire. Same-day collection, next-day drop."
    image={heroImages.areas}
    ctaPrimary={{ label: 'Call for Delivery', href: PHONE_HREF, icon: 'phone' }}
    ctaSecondary={{ label: 'Find Your Area', href: '#counties', icon: 'arrow' }}
    minHeight="min-h-[55vh] md:min-h-[65vh]"
  />

  <BrandMarquee label="Brands We Supply" brands={brands} theme="green" />

  <!-- Areas grid -->
  <section class="section-white section-padding">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-end mb-14">
        <AnimatedSection>
          <SectionLabel text="Our Delivery Region" />
          <h2 class="text-charcoal font-heading text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-wide leading-[0.95]">
            Roofing
            <span class="block text-primary">Delivered Regionally</span>
          </h2>
        </AnimatedSection>
        
        <AnimatedSection class="lg:text-right">
          <p class="text-body text-lg leading-relaxed">
            Bristol depot dispatch to 5 counties and 68+ towns. Same-day collection, next-day delivery and trade pricing throughout the South West.
          </p>
        </AnimatedSection>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {areas.map((area, i) => (
          <AnimatedSection delay={i * 0.05}>
            <AreaCard name={area.name} shortDesc={area.shortDesc} href={`/areas/${area.slug}`} image={area.image} />
          </AnimatedSection>
        ))}
      </div>
    </div>
  </section>

  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={45} />

  <CtaBanner />
</Layout>
