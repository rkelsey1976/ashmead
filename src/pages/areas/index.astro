---
import Layout from '../../layouts/Layout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import AreaCard from '../../components/AreaCard.astro';
import { areas } from '../../data/areas';
import { heroImages } from '../../data/site';
---

<Layout title="Areas We Cover | Roofing Supplies Bristol, Bath, Somerset & Beyond | Ashmead" description="Ashmead Roofing Supplies delivers across Bristol, Bath, Somerset, Gloucester and Wiltshire. Trade prices, fast delivery. Call 0117 986 0600.">
  <!-- Areas Hero — diagonal split -->
  <section class="relative overflow-hidden min-h-[400px] md:min-h-[500px]">
    <div class="absolute inset-0">
      <img src={heroImages.areas} alt="" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="absolute inset-0 bg-charcoal" style="clip-path: polygon(0 0, 75% 0, 50% 100%, 0 100%)"></div>
    <div class="absolute inset-0" style="clip-path: polygon(74.5% 0, 75.5% 0, 50.5% 100%, 49.5% 100%); background: #009900;"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-8 py-16 md:py-24 flex items-center min-h-[400px] md:min-h-[500px]">
      <div class="max-w-xl">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading uppercase tracking-wide text-primary mb-6">Areas We Cover</h1>
        <p class="text-lg text-white/80 mb-8">We supply professional roofers and builders across Bristol, Bath, Somerset, Gloucester and Wiltshire with trade pricing and fast delivery.</p>
      </div>
    </div>
  </section>

  <section class="section-white section-padding">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {areas.map(area => (
          <AreaCard name={area.name} shortDesc={area.shortDesc} href={`/areas/${area.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</Layout>