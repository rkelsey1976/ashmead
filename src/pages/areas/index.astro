---
import Layout from '../../layouts/Layout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import AreaCard from '../../components/AreaCard.astro';
import { areas } from '../../data/areas';
import { heroImages } from '../../data/site';
---

<Layout title="Areas We Cover | Roofing Supplies Bristol, Bath, Somerset & Beyond | Ashmead" description="Ashmead Roofing Supplies delivers across Bristol, Bath, Somerset, Gloucester and Wiltshire. Trade prices, fast delivery. Call 0117 986 0600.">
  <!-- Areas Hero — full-width background image -->
  <section class="relative overflow-hidden min-h-[320px]">
    <div class="absolute inset-0">
      <img src={heroImages.areas} alt="Areas we cover" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-charcoal/70"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20 md:py-28 flex items-center justify-center min-h-[320px]">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-3xl md:text-5xl font-bold font-heading uppercase tracking-wide text-primary mb-4">Areas We Cover</h1>
        <p class="text-lg text-white/90 mb-8">We supply professional roofers and builders across Bristol, Bath, Somerset, Gloucester and Wiltshire with trade pricing and fast delivery.</p>
      </div>
    </div>
  </section>

  <section class="section-white section-padding">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {areas.map(area => (
          <AreaCard name={area.name} shortDesc={area.shortDesc} href={`/areas/${area.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</Layout>