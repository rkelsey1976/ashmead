---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { areas } from '../../data/areas';
---

<Layout title="Areas We Cover | Roofing Supplies Bristol, Bath, Somerset & Beyond | Ashmead" description="Ashmead Roofing Supplies delivers across Bristol, Bath, Somerset, Gloucester and Wiltshire. Trade prices, fast delivery. Call 0117 986 0600.">
  <Hero title="Areas We Cover" subtitle="We supply professional roofers and builders across Bristol, Bath, Somerset, Gloucester and Wiltshire with trade pricing and fast delivery." />

  <section class="bg-primary py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {areas.map(area => (
          <a href={`/areas/${area.slug}`} class="group bg-card rounded-lg p-8 hover:bg-card/80 transition-all border border-card hover:border-accent/50">
            <h2 class="text-heading font-heading text-2xl font-bold uppercase tracking-wide mb-3 group-hover:text-accent transition-colors">{area.h1}</h2>
            <p class="text-body text-sm leading-relaxed mb-4">{area.shortDesc}</p>
            <span class="text-accent font-medium group-hover:text-accent-light transition-colors">View supplies in {area.name} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</Layout>