---
import Layout from '../../layouts/Layout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import AreaCard from '../../components/AreaCard.astro';
import { areas } from '../../data/areas';
---

<Layout title="Areas We Cover | Roofing Supplies Bristol, Bath, Somerset & Beyond | Ashmead" description="Ashmead Roofing Supplies delivers across Bristol, Bath, Somerset, Gloucester and Wiltshire. Trade prices, fast delivery. Call 0117 986 0600.">
  <section class="bg-section-highlight section-padding">
    <div class="container">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Areas We Cover</h1>
      <p class="text-lg text-body max-w-2xl mb-8">We supply professional roofers and builders across Bristol, Bath, Somerset, Gloucester and Wiltshire with trade pricing and fast delivery.</p>
    </div>
  </section>

  <section class="section-white section-padding">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {areas.map(area => (
          <AreaCard name={area.name} shortDesc={area.shortDesc} href={`/areas/${area.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</Layout>