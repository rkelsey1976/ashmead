---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CtaBanner from '../components/CtaBanner.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ProductCard from '../components/ProductCard.astro';
import AreaCard from '../components/AreaCard.astro';
import BrandBar from '../components/BrandBar.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { products } from '../data/products';
import { areas } from '../data/areas';
import { PHONE_HREF } from '../data/site';
---

<Layout title="Roofing Supplies Bristol | Ashmead Roofing Supplies" description="Bristol's trusted roofing trade counter. Concrete tiles, slates, flat roofing, membranes, fixings & more. Trade prices, expert advice. Call 0117 986 0600.">
  <!-- Hero -->
  <section class="bg-section-highlight py-16 md:py-24 lg:py-32 border-b-4 border-primary">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading uppercase tracking-wide text-charcoal mb-6">Roofing Supplies Bristol</h1>
        <p class="text-lg md:text-xl text-body mb-8">Bristol's trusted roofing trade counter. We supply professional roofers and builders across Bristol, Bath, Somerset, Gloucester and Wiltshire with tiles, slates, flat roofing, membranes, fixings and everything in between.</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-white font-bold px-8 py-4 rounded text-lg transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call 0117 986 0600
          </a>
          <a href="/products" class="inline-block bg-white hover:bg-gray-50 text-charcoal border border-border hover:border-primary font-bold px-8 py-4 rounded transition-colors text-lg text-center">
            View Products
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Ashmead -->
  <section class="section-green section-padding">
    <div class="container">
      <SectionHeading text="Why Choose Ashmead?" />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <FeatureCard title="Trade Expertise" description="Our team has decades of combined roofing experience. We don't just sell materials — we advise on product selection, calculate quantities and help you specify the right system for every project." icon="trade" />
        <FeatureCard title="Massive Stock" description="Our Bristol depot holds one of the widest ranges of roofing materials in the South West. From concrete tiles to EPDM membranes, battens to lead sheet — it's on the shelf and ready for collection or delivery." icon="stock" />
        <FeatureCard title="Fast Delivery" description="We deliver across Bristol, Bath, Somerset, Gloucester and Wiltshire — often next day. Need it faster? Our Bristol depot is open for trade collection, so you can pick up what you need when you need it." icon="delivery" />
      </div>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="section-white section-padding">
    <div class="container">
      <SectionHeading text="Our Products" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map(product => (
          <ProductCard name={product.name} shortDesc={product.shortDesc} href={`/products/${product.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <!-- Areas Grid -->
  <section class="section-grey section-padding">
    <div class="container">
      <SectionHeading text="Areas We Cover" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {areas.map(area => (
          <AreaCard name={area.name} shortDesc={area.shortDesc} href={`/areas/${area.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <BrandBar />

  <CtaBanner />
</Layout>