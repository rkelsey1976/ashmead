---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import FeatureCard from '../components/FeatureCard.astro';
import BrandMarquee from '../components/BrandMarquee.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Button from '../components/Button.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Testimonials from '../components/Testimonials.astro';
import SuppliesFinder from '../components/SuppliesFinder.astro';
import ProjectCard from '../components/ProjectCard.astro';
import AreasSection from '../components/AreasSection.astro';
import AnimatedSection from '../components/AnimatedSection.astro';
import { PHONE, PHONE_HREF, BUSINESS_NAME } from '../data/site';
import { products } from '../data/products';
import { areas } from '../data/areas';
import { brands, brandByName } from '../data/brands';

const heroBrandNames = ["Redland", "Marley", "Velux", "Cupa Pizarras", "A. Proctor Group", "FloPlast"];
const heroBrands = heroBrandNames.map(name => brandByName[name]).filter(Boolean);

const stats = [
  { value: '40+', label: 'Years Experience' },
  { value: '5', label: 'Counties Supplied' },
  { value: '18+', label: 'Product Ranges' },
  { value: '1000s', label: 'Trade Customers' },
];

const projects = [
  {
    image: '/images/hero-bristol.jpg',
    title: 'Heritage Re-Roof',
    category: 'Re-Roof',
    location: 'Bath',
    description: 'Full clay tile re-roof on a Georgian townhouse using Redland and Marley products.',
    metric: 'Completed in 6 weeks'
  },
  {
    image: '/images/hero-somerset.jpg',
    title: 'New-Build Development',
    category: 'New Build',
    location: 'Somerset',
    description: 'Large-scale roofing supply for a 24-home development with next-day delivery scheduling.',
    metric: '24 homes roofed'
  },
  {
    image: '/images/hero-bath.jpg',
    title: 'Flat-Roof Refurbishment',
    category: 'Flat Roof',
    location: 'Bristol',
    description: 'ClassicBond EPDM system installed on commercial units with full membrane and trims supplied.',
    metric: 'Zero leaks since install'
  }
];
---

<Layout title="Roofing Supplies Bristol | Ashmead Roofing Supplies" description="Ashmead Roofing Supplies Ltd — Bristol's trusted roofing trade counter. Tiles, slates, flat roofing, membranes, battens, fixings & more. Trade pricing, expert advice, fast delivery. Call 0117 986 0600.">

  <!-- Hero -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Background image with parallax wrapper -->
    <div class="absolute inset-0 z-0 hero-bg">
      <img
        src="/images/hero-home.jpg"
        alt="Roofing supplies stacked at Ashmead Roofing Supplies Bristol depot"
        class="w-full h-full object-cover scale-110"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-charcoal via-charcoal/90 to-charcoal/40"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal/95 via-charcoal/40 to-charcoal/40"></div>
    </div>
    
    <div class="container relative z-10 py-24 md:py-32">
      <div class="max-w-4xl">
        <!-- Eyebrow -->
        <div class="hero-eyebrow inline-flex items-center gap-2.5 bg-white/10 backdrop-blur-md text-white pl-2 pr-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-[0.18em] mb-8 border border-white/20 shadow-sm">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-accent/20 text-accent">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          South West's Roofing Trade Counter
        </div>

        <!-- Headline -->
        <h1 class="hero-title text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-heading font-bold uppercase leading-[0.9] tracking-tight text-white mb-8">
          <span class="block">Roofing Supplies</span>
          <span class="block font-serif normal-case text-accent">Built for Trade</span>
        </h1>

        <!-- Subhead -->
        <p class="hero-sub text-lg md:text-xl lg:text-2xl text-white/80 max-w-3xl mb-10 leading-relaxed"
        >
          Tiles, slates, flat roofing, membranes, fixings and battens — stocked for immediate collection or next-day delivery across Bristol, Bath, Somerset, Gloucester and Wiltshire.
        </p>

        <!-- CTAs -->
        <div class="hero-ctas flex flex-col sm:flex-row gap-4 mb-16">
          <Button variant="primary" href="phone" icon="phone" size="lg" class="text-lg px-10 py-5">{PHONE}</Button>
          <Button variant="outline" href="/products" icon="arrow" size="lg" class="text-lg px-10 py-5">Explore Products</Button>
        </div>

        <!-- Stats -->
        <div class="hero-stats grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 pt-8 border-t border-white/20">
          {stats.map(stat => (
            <div class="text-left md:text-center">
              <div class="text-4xl md:text-5xl font-heading font-bold text-accent mb-2">{stat.value}</div>
              <div class="text-white/70 text-sm uppercase tracking-wider">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Brands marquee -->
  <BrandMarquee label="Authorised Stockists Of" brands={heroBrands} theme="green" />

  <!-- Why choose -->
  <section class="section-white section-padding">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-end mb-16">
        <AnimatedSection>
          <SectionLabel text="Why Ashmead" />
          <h2 class="text-charcoal font-heading text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-wide leading-[0.95]">
            The Trade Counter
            <span class="block text-primary">Roofers Trust</span>
          </h2>
        </AnimatedSection>
        
        <AnimatedSection>
          <p class="text-body text-lg leading-relaxed">
            We don't just shift boxes. Our team has years of on-the-tools experience and will advise on the right system, calculate quantities and make sure you leave the depot with exactly what you need — every time.
          </p>
        </AnimatedSection>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <AnimatedSection delay={0.1}>
          <FeatureCard title="Trade Expertise" description="Years of hands-on roofing knowledge. We advise, calculate and specify the right system first time." icon="trade" />
        </AnimatedSection>
        <AnimatedSection delay={0.2}>
          <FeatureCard title="Massive Stock" description="One of the widest ranges in the South West, ready for collection or next-day delivery." icon="stock" />
        </AnimatedSection>
        <AnimatedSection delay={0.3}>
          <FeatureCard title="Fast Delivery" description="Our fleet covers Bristol, Bath, Somerset, Gloucester and Wiltshire six days a week." icon="delivery" />
        </AnimatedSection>
        <AnimatedSection delay={0.4}>
          <FeatureCard title="Expert Support" description="From trade accounts to technical specs, we're here to keep your project on track." icon="support" />
        </AnimatedSection>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="section-grey section-padding">
    <div class="container">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14">
        <AnimatedSection>
          <SectionLabel text="Our Range" />
          <h2 class="text-charcoal font-heading text-4xl md:text-5xl font-bold uppercase tracking-wide">
            Trade-Roofing Products
          </h2>
        </AnimatedSection>
        
        <AnimatedSection>
          <a href="/products" class="inline-flex items-center gap-2 text-primary font-semibold hover:text-primary-hover transition-colors">
            View all products
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </AnimatedSection>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {products.slice(0, 8).map((product, i) => (
          <AnimatedSection delay={i * 0.05}>
            <ProductCard name={product.name} shortDesc={product.shortDesc} href={`/products/${product.slug}`} brands={product.brands} image={product.image} />
          </AnimatedSection>
        ))}
      </div>
    </div>
  </section>

  <!-- Areas -->
  <AreasSection />

  <!-- Supplies Finder -->
  <SuppliesFinder />

  <!-- Case Studies -->
  <section class="section-grey section-padding">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-end mb-14">
        <AnimatedSection>
          <SectionLabel text="Case Studies" />
          <h2 class="text-charcoal font-heading text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-wide leading-[0.95]">
            Real Projects,
            <span class="block text-primary">Real Results</span>
          </h2>
        </AnimatedSection>
        
        <AnimatedSection class="lg:text-right">
          <p class="text-body text-lg">
            A snapshot of the roofing supply projects we've supported across the South West — from heritage re-roofs to large new-build developments.
          </p>
        </AnimatedSection>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project, i) => (
          <AnimatedSection delay={i * 0.1}>
            <ProjectCard {...project} />
          </AnimatedSection>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <Testimonials />

  <!-- Brands -->
  <BrandMarquee label="Brands We Supply" brands={brands} theme="white" speed={50} />

  <!-- CTA -->
  <CtaBanner />

  <!-- Hero entrance animation -->
  <script>
    import { gsap } from 'gsap';

    document.addEventListener('DOMContentLoaded', () => {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) return;

      const tl = gsap.timeline();

      tl.fromTo('.hero-bg img', 
        { scale: 1.15, opacity: 0 },
        { scale: 1.1, opacity: 1, duration: 1.8, ease: 'power2.out' }
      );

      tl.fromTo('.hero-eyebrow',
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.7, ease: 'power3.out' },
        '-=1.2'
      );

      tl.fromTo('.hero-title span',
        { y: 60, opacity: 0 },
        { y: 0, opacity: 1, duration: 1, stagger: 0.15, ease: 'power3.out' },
        '-=0.8'
      );

      tl.fromTo('.hero-sub',
        { y: 30, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out' },
        '-=0.6'
      );

      tl.fromTo('.hero-ctas > *',
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6, stagger: 0.1, ease: 'power3.out' },
        '-=0.5'
      );

      tl.fromTo('.hero-stats > div',
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.7, stagger: 0.1, ease: 'power3.out' },
        '-=0.3'
      );
    });
  </script>
</Layout>
