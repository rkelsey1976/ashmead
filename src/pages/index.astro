---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ProductCard from '../components/ProductCard.astro';
import AreaCard from '../components/AreaCard.astro';
import BrandBar from '../components/BrandBar.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import { products } from '../data/products';
import { areas } from '../data/areas';
import { heroImages } from '../data/site';
---

<Layout title="Roofing Supplies Bristol | Ashmead Roofing Supplies" description="Bristol's trusted roofing trade counter. Concrete tiles, slates, flat roofing, membranes, fixings & more. Trade prices, expert advice. Call 0117 986 0600.">
  <!-- Hero -->
  <section class="relative overflow-hidden min-h-[400px] md:min-h-[500px] lg:min-h-[600px]">
    <div class="absolute inset-0">
      <img src={heroImages.home} alt="Ashmead Roofing Supplies depot" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-charcoal/70"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 py-16 md:py-24 lg:py-32 flex items-center min-h-[400px] md:min-h-[500px] lg:min-h-[600px]">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading uppercase tracking-wide text-white mb-6">Roofing Supplies Bristol</h1>
        <p class="text-lg md:text-xl text-white/90 mb-8">Bristol's trusted roofing trade counter. We supply professional roofers and builders across Bristol, Bath, Somerset, Gloucester and Wiltshire with tiles, slates, flat roofing, membranes, fixings and everything in between.</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button variant="white" href="phone" icon="phone" size="lg" />
          <a href="/products" class="inline-block border-2 border-white text-white hover:bg-white hover:text-charcoal font-bold px-8 py-4 rounded transition-colors text-lg text-center">View Products</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Ashmead -->
  <section class="section-green section-padding">
    <div class="container">
      <SectionHeading text="Why Choose Ashmead?" />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <FeatureCard title="Trade Expertise" description="Our team has decades of combined roofing experience. We don't just sell materials — we advise on product selection, calculate quantities and help you specify the right system for every project." icon="trade" />
        <FeatureCard title="Massive Stock" description="Our Bristol depot holds one of the widest ranges of roofing materials in the South West. From concrete tiles to EPDM membranes, battens to lead sheet — it's on the shelf and ready for collection or delivery." icon="stock" />
        <FeatureCard title="Fast Delivery" description="We deliver across Bristol, Bath, Somerset, Gloucester and Wiltshire — often next day. Need it faster? Our Bristol depot is open for trade collection, so you can pick up what you need when you need it." icon="delivery" />
      </div>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="section-white section-padding">
    <div class="container">
      <SectionHeading text="Our Products" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map(product => (
          <ProductCard name={product.name} shortDesc={product.shortDesc} href={`/products/${product.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <!-- Areas Grid -->
  <section class="section-grey section-padding">
    <div class="container">
      <SectionHeading text="Areas We Cover" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {areas.map(area => (
          <AreaCard name={area.name} shortDesc={area.shortDesc} href={`/areas/${area.slug}`} />
        ))}
      </div>
    </div>
  </section>

  <BrandBar />

  <CtaBanner />
</Layout>