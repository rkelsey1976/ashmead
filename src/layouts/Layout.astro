---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyMobileFooter from '../components/StickyMobileFooter.astro';
import SeoHead from '../components/SeoHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  schema?: object[];
}

const { title, description, ogImage, schema } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <SeoHead title={title} description={description} ogImage={ogImage} schema={schema} />
</head>
<body class="bg-white text-body font-body min-h-screen flex flex-col">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
  <StickyMobileFooter />
</body>
</html>
