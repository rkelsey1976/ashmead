---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyMobileFooter from '../components/StickyMobileFooter.astro';
import SeoHead from '../components/SeoHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  schema?: object[];
}

const { title, description, ogImage, schema } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <SeoHead title={title} description={description} ogImage={ogImage} schema={schema} />
</head>
<body class="bg-white text-body font-body min-h-screen flex flex-col">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
  <StickyMobileFooter />

  <!-- Mobile menu script -->
  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const close = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => {
        menu.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });
    }
    if (close && menu) {
      close.addEventListener('click', () => {
        menu.classList.add('hidden');
        document.body.style.overflow = '';
      });
    }
    if (menu) {
      menu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          menu.classList.add('hidden');
          document.body.style.overflow = '';
        });
      });
    }
  </script>
</body>
</html>
