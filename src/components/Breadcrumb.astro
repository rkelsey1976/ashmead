---
interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  items: BreadcrumbItem[];
}
---

<nav class="text-sm text-body mb-6" aria-label="Breadcrumb">
  <ol class="flex items-center flex-wrap gap-1">
    {Astro.props.items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span class="mx-1 text-gray-400">/</span>}
        {i < Astro.props.items.length - 1 ? (
          <a href={item.href} class="hover:text-primary transition-colors">{item.label}</a>
        ) : (
          <span class="text-charcoal">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>