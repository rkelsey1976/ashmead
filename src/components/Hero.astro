---
import Breadcrumb from './Breadcrumb.astro';
import Button from './Button.astro';
import { PHONE, PHONE_HREF } from '../data/site';

interface Props {
  title: string;
  subtitle?: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  /** Hero image — shown with dark overlay or as split layout */
  image?: string;
  /** "full" = full-width image with dark overlay | "split" = charcoal left + image right | "default" = no image */
  variant?: 'default' | 'full' | 'split';
}

const { title, subtitle, breadcrumbs, image, variant = image ? 'full' : 'default' } = Astro.props;
---

{variant === 'full' && image ? (
  <section class="relative overflow-hidden min-h-[320px]">
    <div class="absolute inset-0">
      <img src={image} alt="" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-charcoal/70"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 py-16 md:py-24 lg:py-28">
      {breadcrumbs && <Breadcrumb items={breadcrumbs} />}
      <h1 class="text-3xl md:text-5xl font-bold font-heading uppercase tracking-wide text-white mb-4">{title}</h1>
      {subtitle && (
        <p class="text-lg md:text-xl text-white/90 max-w-2xl mb-8">{subtitle}</p>
      )}
      <div class="flex flex-col sm:flex-row gap-4">
        <slot />
      </div>
    </div>
  </section>
) : variant === 'split' && image ? (
  <section class="overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[320px]">
        <div class="bg-charcoal flex flex-col justify-center px-6 py-16 md:px-12 md:py-20 lg:py-24">
          {breadcrumbs && <Breadcrumb items={breadcrumbs} />}
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading uppercase tracking-wide text-white mb-4">{title}</h1>
          {subtitle && (
            <p class="text-lg text-white/80 mb-8">{subtitle}</p>
          )}
          <div class="flex flex-col sm:flex-row gap-4">
            <slot />
          </div>
        </div>
        <div class="hidden lg:block relative">
          <img src={image} alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
        </div>
      </div>
    </div>
  </section>
) : (
  <section class="bg-section-highlight py-16 md:py-24 border-b-4 border-primary">
    <div class="max-w-7xl mx-auto px-4">
      {breadcrumbs && <Breadcrumb items={breadcrumbs} />}
      <h1 class="text-3xl md:text-5xl font-bold font-heading uppercase tracking-wide text-charcoal mb-4">{title}</h1>
      {subtitle && (
        <p class="text-lg text-body max-w-2xl mb-8">{subtitle}</p>
      )}
      <div class="flex flex-col sm:flex-row gap-4">
        <slot />
      </div>
    </div>
  </section>
)}