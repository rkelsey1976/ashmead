---
import Button from './Button.astro';

interface Props {
  eyebrow?: string;
  title: string;
  accent?: string;
  description?: string;
  image: string;
  imageAlt?: string;
  ctaPrimary?: { label: string; href: string; icon?: 'phone' | 'arrow' | 'none' };
  ctaSecondary?: { label: string; href: string; icon?: 'phone' | 'arrow' | 'none' };
  minHeight?: string;
}

const {
  eyebrow,
  title,
  accent,
  description,
  image,
  imageAlt = '',
  ctaPrimary,
  ctaSecondary,
  minHeight = 'min-h-[60vh] md:min-h-[70vh]'
} = Astro.props;
---

<section class={`relative ${minHeight} flex items-center overflow-hidden hero-section`}>
  <!-- Background image with cinematic treatment -->
  <div class="absolute inset-0 z-0 hero-bg">
    <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover object-center scale-105"
        loading="eager"
      />
      <!-- Stronger vignette for text legibility on any image -->
      <div class="absolute inset-0 bg-charcoal/40"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-charcoal via-charcoal/85 to-charcoal/30"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/30 to-charcoal/50"></div>
      <!-- Bottom edge fade for trust bar overlap -->
      <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-charcoal to-transparent"></div>
  </div>
  
  <div class="container relative z-10 py-20 md:py-28">
    <div class="max-w-4xl">
      
      {eyebrow && (
        <div class="hero-eyebrow inline-flex items-center gap-2.5 bg-white/10 backdrop-blur-md text-white pl-2 pr-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-[0.18em] mb-8 border border-white/20 shadow-sm">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-accent/20 text-accent">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          {eyebrow}
        </div>
      )}
      
      <h1 class="hero-title text-5xl md:text-6xl lg:text-7xl font-heading font-bold uppercase leading-[0.9] tracking-tight text-white mb-6">
        <span class="block">{title}</span>
        {accent && <span class="block text-accent">{accent}</span>}
      </h1>
      
      {description && (
        <p class="hero-sub text-lg md:text-xl text-white/80 max-w-2xl mb-10 leading-relaxed">
          {description}
        </p>
      )}
      
      <div class="hero-ctas flex flex-col sm:flex-row gap-4">
        {ctaPrimary && (
          <Button variant="primary" href={ctaPrimary.href} icon={ctaPrimary.icon || 'none'} size="lg" class="text-lg px-10 py-5">
            {ctaPrimary.label}
          </Button>
        )}
        {ctaSecondary && (
          <Button variant="outline" href={ctaSecondary.href} icon={ctaSecondary.icon || 'none'} size="lg" class="text-lg px-10 py-5">
            {ctaSecondary.label}
          </Button>
        )}
      </div>
    </div>
  </div>
</section>
