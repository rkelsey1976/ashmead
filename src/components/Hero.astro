---
import Breadcrumb from './Breadcrumb.astro';

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  subtitle?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, subtitle, breadcrumbs } = Astro.props;
---

<section class="bg-section-highlight py-16 md:py-24 border-b-4 border-primary">
  <div class="max-w-7xl mx-auto px-4 text-center">
    {breadcrumbs && breadcrumbs.length > 0 && (
      <div class="text-left mb-2">
        <Breadcrumb items={breadcrumbs} />
      </div>
    )}
    <h1 class="text-3xl md:text-5xl font-bold font-heading uppercase tracking-wide text-charcoal mb-4">{title}</h1>
    {subtitle && (
      <p class="text-lg md:text-xl text-body max-w-2xl mx-auto mb-8">{subtitle}</p>
    )}
    <slot />
  </div>
</section>