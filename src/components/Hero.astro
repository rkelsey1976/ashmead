---
import { PHONE, PHONE_HREF } from '../data/site';

interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="bg-gradient-to-br from-primary via-section to-primary py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <h1 class="text-3xl md:text-5xl font-bold font-heading uppercase tracking-wide text-heading mb-4">{title}</h1>
    {subtitle && (
      <p class="text-lg md:text-xl text-body max-w-2xl mx-auto mb-8">{subtitle}</p>
    )}
    <a href={PHONE_HREF} class="inline-flex items-center gap-2 bg-accent hover:bg-accent-light text-white font-bold px-8 py-4 rounded text-lg transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      Call {PHONE}
    </a>
  </div>
</section>