---
import { products } from '../data/products';
import { areas } from '../data/areas';
---

<!-- Products Grid -->
<section class="bg-section py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-heading text-center mb-12">Our Products</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {products.map(product => (
        <a href={`/products/${product.slug}`} class="group bg-card rounded-lg p-6 hover:bg-card/80 transition-all border border-card hover:border-accent/50">
          <h3 class="text-heading font-heading text-xl font-bold uppercase tracking-wide mb-2 group-hover:text-accent transition-colors">{product.name}</h3>
          <p class="text-body text-sm leading-relaxed mb-4">{product.shortDesc}</p>
          <span class="text-accent text-sm font-medium group-hover:text-accent-light transition-colors">Learn more →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Areas Grid -->
<section class="bg-primary py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-heading text-center mb-12">Areas We Cover</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
      {areas.map(area => (
        <a href={`/areas/${area.slug}`} class="group bg-card rounded-lg p-6 text-center hover:bg-card/80 transition-all border border-card hover:border-accent/50">
          <h3 class="text-heading font-heading text-xl font-bold uppercase tracking-wide mb-2 group-hover:text-accent transition-colors">{area.name}</h3>
          <p class="text-body text-sm">{area.shortDesc}</p>
          <span class="text-accent text-sm font-medium mt-3 inline-block group-hover:text-accent-light transition-colors">View supplies →</span>
        </a>
      ))}
    </div>
  </div>
</section>