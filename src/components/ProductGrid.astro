---
import { areas } from '../data/areas';
import { reader } from '../lib/reader';

const slugs = await reader.collections.products.list();
const products = (await Promise.all(
  slugs.map(async slug => {
    const data = await reader.collections.products.read(slug);
    return data ? { slug, name: data.name, shortDesc: data.shortDesc } : null;
  })
)).filter(Boolean) as { slug: string; name: string; shortDesc: string }[];
---

<!-- Products Grid -->
<section class="bg-white py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-charcoal text-center mb-12">Our Products</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {products.map(product => (
        <a href={`/products/${product.slug}`} class="group bg-white rounded-lg p-6 transition-all border border-border hover:border-primary hover:shadow-lg">
          <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-2 group-hover:text-primary transition-colors">{product.name}</h3>
          <p class="text-body text-sm leading-relaxed mb-4">{product.shortDesc}</p>
          <span class="text-primary text-sm font-medium group-hover:text-primary-hover transition-colors">Learn more →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Areas Grid -->
<section class="bg-section py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-charcoal text-center mb-12">Areas We Cover</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
      {areas.map(area => (
        <a href={`/areas/${area.slug}`} class="group bg-white rounded-lg p-6 text-center transition-all border border-border hover:border-primary hover:shadow-lg">
          <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-2 group-hover:text-primary transition-colors">{area.name}</h3>
          <p class="text-body text-sm">{area.shortDesc}</p>
          <span class="text-primary text-sm mt-3 inline-block group-hover:text-primary-hover transition-colors">View supplies →</span>
        </a>
      ))}
    </div>
  </div>
</section>
