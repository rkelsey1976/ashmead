---
import { PHONE, PHONE_HREF, navLinks } from '../data/site';

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-40 bg-white/90 backdrop-blur-md border-b border-border/60 transition-all duration-300 lg:scrolled:py-0" data-header-sticky>
  <div class="container">
    <div class="flex items-center justify-between h-18 md:h-22 transition-all duration-300" data-header-inner>
      
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <img src="/logo-original.png" alt="Ashmead Roofing Supplies" class="h-10 md:h-12 w-auto transition-all duration-300" data-header-logo />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => {
          const isActive = currentPath === link.href || currentPath.startsWith(`${link.href}/`);
          return (
            <a
              href={link.href}
              class:list={[
                "nav-link group relative px-4 py-2.5 text-sm font-semibold uppercase tracking-wide font-heading transition-colors",
                isActive ? "text-primary" : "text-charcoal hover:text-primary"
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {link.label}
              <span
                class:list={[
                  "absolute bottom-1 left-1/2 -translate-x-1/2 h-1 rounded-full bg-primary transition-all duration-300 ease-out",
                  isActive ? "w-5 opacity-100" : "w-0 opacity-0 group-hover:w-5 group-hover:opacity-100"
                ]}
              />
            </a>
          );
        })}
      </nav>

      <!-- CTA + phone -->
      <div class="flex items-center gap-3">
        <a href={PHONE_HREF} class="hidden md:flex items-center gap-2 text-charcoal hover:text-primary transition-colors font-semibold text-sm group">
          <span class="flex items-center justify-center w-9 h-9 rounded-full bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </span>
          <span class="hidden xl:inline">{PHONE}</span>
        </a>
        
        <a href="/contact" class="hidden md:inline-flex items-center gap-2 bg-primary hover:bg-primary-hover text-white font-semibold px-5 py-2.5 rounded-md transition-all duration-300 hover:shadow-md text-sm uppercase tracking-wide font-heading">
          Get a Quote
        </a>
        
        <button id="mobile-menu-btn" type="button" class="lg:hidden flex items-center gap-2 text-charcoal p-2 -mr-2" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg class="w-7 h-7 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <span class="text-xs font-semibold uppercase tracking-wide pointer-events-none">Menu</span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-18 md:h-22"></div>

<!-- Mobile Menu Overlay — top-level so it covers the full viewport -->
<div id="mobile-menu" class="fixed inset-0 z-[60] bg-charcoal lg:hidden hidden flex-col" role="dialog" aria-modal="true">
  
  <!-- Background texture -->
  <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 25% 25%, rgba(74,222,128,0.3) 0%, transparent 25%), radial-gradient(circle at 75% 75%, rgba(11,122,62,0.4) 0%, transparent 35%);"></div>
  
  <div class="relative z-10 flex flex-col h-full container py-6">
    
    <div class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <img src="/logo-original.png" alt="Ashmead Roofing Supplies" class="h-12 w-auto brightness-0 invert" />
      </a>
      
      <button id="mobile-menu-close" type="button" onclick="document.getElementById('mobile-menu').classList.add('hidden'); document.getElementById('mobile-menu').classList.remove('flex'); document.body.style.overflow=''; document.getElementById('mobile-menu-btn').setAttribute('aria-expanded','false');" class="text-white/80 hover:text-white p-4 -mr-4 transition-colors touch-manipulation relative z-[70]" aria-label="Close menu">
        <svg class="w-8 h-8 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav class="flex-1 flex flex-col justify-center -mt-10">
      <ul class="space-y-2">
        {navLinks.map((link) => {
          const isActive = currentPath === link.href || currentPath.startsWith(`${link.href}/`);
          return (
            <li class="overflow-hidden">
              <a href={link.href} class:list={["mobile-nav-link group flex items-center justify-between py-4 border-b border-white/10", isActive ? "text-accent" : "text-white/90 hover:text-white"]}>
                <span class:list={["text-4xl md:text-5xl font-bold uppercase tracking-wide transition-colors font-heading", isActive ? "text-accent" : "text-white/90 group-hover:text-white"]} >
                  {link.label}
                </span>
                
                <span class:list={["flex items-center justify-center w-10 h-10 rounded-full border transition-colors", isActive ? "border-accent text-accent" : "border-white/20 text-white/50 group-hover:border-accent group-hover:text-accent"]}>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="space-y-6">
      
      <div class="flex items-center gap-4">
        <a href={PHONE_HREF} class="flex-1 inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-white font-semibold px-6 py-4 rounded-md transition-colors text-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {PHONE}
        </a>
        
        <a href="/contact" class="flex-1 inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white text-white hover:bg-white hover:text-charcoal font-semibold px-6 py-4 rounded-md transition-colors text-lg">
          Get a Quote
        </a>
      </div>
      
      <p class="text-white/40 text-xs text-center uppercase tracking-widest">
        Bristol's Roofing Trade Counter · Est. 1984
      </p>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const btn = document.getElementById('mobile-menu-btn');
    const close = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    const links = menu.querySelectorAll('.mobile-nav-link');
    const header = document.getElementById('site-header');
    const headerInner = header.querySelector('[data-header-inner]');
    const headerLogo = header.querySelector('[data-header-logo]');
    
    function openMenu() {
      menu.classList.remove('hidden');
      menu.classList.add('flex');
      document.body.style.overflow = 'hidden';
      btn.setAttribute('aria-expanded', 'true');
    }
    
    function closeMenu() {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      document.body.style.overflow = '';
      btn.setAttribute('aria-expanded', 'false');
    }
    
    btn.addEventListener('click', openMenu);
    close.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); closeMenu(); });
    close.addEventListener('touchend', function(e) { e.preventDefault(); closeMenu(); });
    links.forEach(link => link.addEventListener('click', closeMenu));
    
    // Sticky header shrink on scroll
    let ticking = false;
    function updateHeader() {
      const scrolled = window.scrollY > 60;
      if (scrolled) {
        header.classList.add('shadow-md');
        headerInner && (headerInner.style.height = '4.25rem');
        headerLogo && (headerLogo.style.height = '2.5rem');
      } else {
        header.classList.remove('shadow-md');
        headerInner && (headerInner.style.height = '');
        headerLogo && (headerLogo.style.height = '');
      }
      ticking = false;
    }
    
    window.addEventListener('scroll', function() {
      if (!ticking) {
        window.requestAnimationFrame(updateHeader);
        ticking = true;
      }
    }, { passive: true });
  });
</script>

<style>
  .nav-link {
    position: relative;
  }
  .nav-link span {
    left: 50%;
    transform: translateX(-50%);
  }
</style>
