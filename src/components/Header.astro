---
import { PHONE, PHONE_HREF, navLinks } from '../data/site';

const currentPath = Astro.url.pathname;
---

<div class="fixed top-4 left-1/2 -translate-x-1/2 z-40 w-[calc(100%-2rem)] max-w-6xl" id="site-header">
  <header class="relative rounded-full overflow-hidden transition-all duration-500" data-header-pill style="background:white;box-shadow:0 4px 24px rgba(0,0,0,0.12);">
    <div id="scroll-progress" style="position:absolute;bottom:0;left:0;width:0%;height:2px;background:#4ADE80;z-index:10;will-change:width;"></div>
    <div class="flex items-center justify-between px-5 py-3 md:px-8" data-header-inner>

      <!-- Logo: dark for hero, inverted for scrolled -->
      <a href="/" class="flex items-center gap-3 group shrink-0" aria-label="Ashmead Roofing Supplies — Home">
        <img src="/logo-mark.svg" alt="" aria-hidden="true" class="h-8 md:h-9 w-auto flex-shrink-0 transition-all duration-300" data-logo-light />
        <img src="/logo-mark-inverted.svg" alt="" aria-hidden="true" class="h-8 md:h-9 w-auto flex-shrink-0 transition-all duration-300 hidden" data-logo-dark />
        <div class="flex flex-col items-end font-heading font-bold uppercase tracking-tight" style="line-height:1;gap:1px">
          <span class="text-[13px] md:text-[14px] transition-colors duration-500" data-logo-name style="color:#1A1A1A">Ashmead Roofing</span>
          <span class="text-[13px] md:text-[14px]" style="color:#0A5C36" data-logo-sub>Supplies Ltd</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-0.5">
        {navLinks.map(link => {
          const isActive = currentPath === link.href || currentPath.startsWith(`${link.href}/`);
          return (
            <a
              href={link.href}
              class:list={[
                "nav-link group relative px-3.5 py-2 text-xs font-semibold uppercase tracking-wider font-heading transition-colors duration-500 rounded-full",
                isActive ? "nav-active" : "nav-inactive"
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {link.label}
              <span
                class:list={[
                  "absolute bottom-1.5 left-1/2 -translate-x-1/2 h-0.5 rounded-full bg-[#0A5C36] transition-all duration-300 ease-out nav-underline",
                  isActive ? "w-4 opacity-100" : "w-0 opacity-0 group-hover:w-4 group-hover:opacity-100"
                ]}
              />
            </a>
          );
        })}
      </nav>

      <!-- CTA + phone -->
      <div class="flex items-center gap-2 shrink-0">
        <a href={PHONE_HREF} class="hidden xl:flex items-center gap-2 transition-colors duration-500 font-semibold text-sm" data-phone-link style="color:#1A1A1A">
          <svg class="w-3.5 h-3.5" style="color:#0A5C36" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {PHONE}
        </a>

        <a href="/contact" class="hidden md:inline-flex items-center gap-2 bg-[#0A5C36] hover:bg-[#0b6b40] text-white font-semibold px-5 py-2 rounded-full transition-all duration-300 text-xs uppercase tracking-wider font-heading shadow-md">
          Get a Quote
        </a>

        <button id="mobile-menu-btn" type="button" class="lg:hidden flex items-center gap-1.5 p-2 -mr-1 transition-colors duration-500" data-menu-btn style="color:#1A1A1A" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg class="w-6 h-6 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <span class="text-[10px] font-semibold uppercase tracking-wide pointer-events-none">Menu</span>
        </button>
      </div>

    </div>
  </header>
</div>


<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-[60] bg-[#0B1F3A] lg:hidden hidden flex-col" role="dialog" aria-modal="true">

  <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 25% 25%, rgba(74,222,128,0.3) 0%, transparent 25%), radial-gradient(circle at 75% 75%, rgba(10,92,54,0.4) 0%, transparent 35%);"></div>

  <div class="relative z-10 flex flex-col h-full container py-6">

    <div class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <img src="/logo-mark-inverted.svg" alt="" aria-hidden="true" class="h-9 w-auto" />
        <div class="flex flex-col items-end font-heading font-bold uppercase tracking-tight" style="line-height:1;gap:1px">
          <span class="text-white text-[14px]">Ashmead Roofing</span>
          <span class="text-[#4ADE80] text-[14px]">Supplies Ltd</span>
        </div>
      </a>

      <button id="mobile-menu-close" type="button" onclick="document.getElementById('mobile-menu').classList.add('hidden'); document.getElementById('mobile-menu').classList.remove('flex'); document.body.style.overflow=''; document.getElementById('mobile-menu-btn').setAttribute('aria-expanded','false');" class="text-white/80 hover:text-white p-4 -mr-4 transition-colors touch-manipulation relative z-[70]" aria-label="Close menu">
        <svg class="w-8 h-8 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav class="flex-1 flex flex-col justify-center -mt-10">
      <ul class="space-y-2">
        {navLinks.map((link) => {
          const isActive = currentPath === link.href || currentPath.startsWith(`${link.href}/`);
          return (
            <li class="overflow-hidden">
              <a href={link.href} class:list={["mobile-nav-link group flex items-center justify-between py-4 border-b border-white/10", isActive ? "text-[#4ADE80]" : "text-white/90 hover:text-white"]}>
                <span class:list={["text-4xl md:text-5xl font-bold uppercase tracking-wide transition-colors font-heading", isActive ? "text-[#4ADE80]" : "text-white/90 group-hover:text-white"]}>
                  {link.label}
                </span>
                <span class:list={["flex items-center justify-center w-10 h-10 rounded-full border transition-colors", isActive ? "border-[#4ADE80] text-[#4ADE80]" : "border-white/20 text-white/50 group-hover:border-[#4ADE80] group-hover:text-[#4ADE80]"]}>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="space-y-6">
      <div class="flex items-center gap-4">
        <a href={PHONE_HREF} class="flex-1 inline-flex items-center justify-center gap-2 bg-[#0A5C36] hover:bg-[#0b6b40] text-white font-semibold px-6 py-4 rounded-full transition-colors text-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {PHONE}
        </a>
        <a href="/contact" class="flex-1 inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white text-white hover:bg-white hover:text-[#0B1F3A] font-semibold px-6 py-4 rounded-full transition-colors text-lg">
          Get a Quote
        </a>
      </div>
      <p class="text-white/40 text-xs text-center uppercase tracking-widest">
        Bristol's Roofing Trade Counter · Est. 1984
      </p>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const btn = document.getElementById('mobile-menu-btn');
    const close = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    const links = menu.querySelectorAll('.mobile-nav-link');

    function openMenu() {
      menu.classList.remove('hidden');
      menu.classList.add('flex');
      document.body.style.overflow = 'hidden';
      btn.setAttribute('aria-expanded', 'true');
    }

    function closeMenu() {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      document.body.style.overflow = '';
      btn.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('click', openMenu);
    close.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); closeMenu(); });
    close.addEventListener('touchend', function(e) { e.preventDefault(); closeMenu(); });
    links.forEach(link => link.addEventListener('click', closeMenu));

    // Scroll progress bar
    const progressBar = document.getElementById('scroll-progress');
    let progressRaf = false;
    function updateProgress() {
      const scrolled = window.scrollY;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      progressBar.style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
      progressRaf = false;
    }
    window.addEventListener('scroll', function() {
      if (!progressRaf) { window.requestAnimationFrame(updateProgress); progressRaf = true; }
    }, { passive: true });

    // Pill colour swap: white on hero, navy when scrolled
    const pill = document.querySelector('[data-header-pill]');
    const logoLight = document.querySelector('[data-logo-light]');
    const logoDark = document.querySelector('[data-logo-dark]');
    const logoName = document.querySelector('[data-logo-name]');
    const logoSub = document.querySelector('[data-logo-sub]');
    const navActives = document.querySelectorAll('.nav-active');
    const navInactives = document.querySelectorAll('.nav-inactive');
    const navUnderlines = document.querySelectorAll('.nav-underline');
    const phoneLink = document.querySelector('[data-phone-link]');
    const menuBtn = document.querySelector('[data-menu-btn]');

    function applyHeroState() {
      pill.style.background = 'white';
      pill.style.boxShadow = '0 4px 24px rgba(0,0,0,0.12)';
      logoLight && (logoLight.style.display = '');
      logoDark && (logoDark.style.display = 'none');
      logoName && (logoName.style.color = '#1A1A1A');
      logoSub && (logoSub.style.color = '#0A5C36');
      navActives.forEach(el => el.style.color = '#0A5C36');
      navInactives.forEach(el => { el.style.color = 'rgba(26,26,26,0.6)'; el.onmouseenter = () => el.style.color = '#1A1A1A'; el.onmouseleave = () => el.style.color = 'rgba(26,26,26,0.6)'; });
      navUnderlines.forEach(el => el.style.background = '#0A5C36');
      phoneLink && (phoneLink.style.color = '#1A1A1A');
      menuBtn && (menuBtn.style.color = '#1A1A1A');
    }

    function applyNavyState() {
      pill.style.background = '#0B1F3A';
      pill.style.boxShadow = '0 8px 32px rgba(0,0,0,0.4)';
      logoLight && (logoLight.style.display = 'none');
      logoDark && (logoDark.style.display = 'block');
      logoName && (logoName.style.color = 'white');
      logoSub && (logoSub.style.color = '#4ADE80');
      navActives.forEach(el => el.style.color = '#4ADE80');
      navInactives.forEach(el => { el.style.color = 'rgba(255,255,255,0.7)'; el.onmouseenter = () => el.style.color = 'white'; el.onmouseleave = () => el.style.color = 'rgba(255,255,255,0.7)'; });
      navUnderlines.forEach(el => el.style.background = '#4ADE80');
      phoneLink && (phoneLink.style.color = 'rgba(255,255,255,0.7)');
      menuBtn && (menuBtn.style.color = 'white');
    }

    // Run on load
    if (window.scrollY < 80) applyHeroState(); else applyNavyState();

    let pillTicking = false;
    window.addEventListener('scroll', function() {
      if (!pillTicking) {
        window.requestAnimationFrame(function() {
          if (window.scrollY < 80) applyHeroState(); else applyNavyState();
          pillTicking = false;
        });
        pillTicking = true;
      }
    }, { passive: true });
  });
</script>

<style>
  .nav-link { position: relative; }
  .nav-link span { left: 50%; transform: translateX(-50%); }
</style>
