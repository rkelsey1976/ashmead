---
interface Props {
  text: string;
  align?: 'center' | 'left';
}

const { text, align = 'center' } = Astro.props;

const alignClasses = align === 'center'
  ? 'text-center'
  : 'text-left';
---

<div class:list={['mb-12', alignClasses]}>
  <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-charcoal">{text}</h2>
  {align === 'center' && (
    <div class="w-16 h-1 bg-primary mx-auto mt-4 rounded-full" />
  )}
  {align === 'left' && (
    <div class="w-16 h-1 bg-primary mt-4 rounded-full" />
  )}
</div>