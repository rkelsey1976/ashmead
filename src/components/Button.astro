---
import { PHONE, PHONE_HREF } from '../data/site';

interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'white';
  href?: string;
  icon?: 'phone' | 'arrow' | 'none';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { variant = 'primary', href = '', icon = 'none', size = 'md', class: extraClass = '' } = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'px-5 py-2.5 text-sm',
  md: 'px-8 py-4 text-base',
  lg: 'px-8 py-4 text-lg'
};

const variantClasses: Record<string, string> = {
  primary: 'bg-primary hover:bg-primary-hover text-white',
  secondary: 'bg-charcoal hover:bg-gray-800 text-white',
  outline: 'bg-white hover:bg-gray-50 text-charcoal border border-border hover:border-primary',
  white: 'bg-white hover:bg-gray-100 text-primary'
};

const resolvedHref = href === 'phone' ? PHONE_HREF : href;
const defaultLabel = href === 'phone' ? PHONE : '';

const flexClass = icon !== 'none' ? 'inline-flex items-center justify-center gap-2' : 'inline-flex items-center justify-center';

const allClasses = [
  flexClass,
  sizeClasses[size],
  variantClasses[variant],
  'font-bold rounded transition-colors text-center',
  extraClass
].filter(Boolean).join(' ');
---

<a href={resolvedHref} class={allClasses}>
  {icon === 'phone' && (
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
  )}
  {icon === 'arrow' && (
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
    </svg>
  )}
  <slot>{defaultLabel}</slot>
</a>