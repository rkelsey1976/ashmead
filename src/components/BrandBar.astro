---
import { brands } from '../data/brands';
---

<section class="bg-section py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-charcoal text-center mb-10">Brands We Supply</h2>
    <div class="overflow-x-auto scrollbar-hide">
      <div style="display: flex; align-items: center; gap: 1.5rem; width: max-content;">
        {brands.map(brand => (
          <a
            href={brand.url}
            target="_blank"
            rel="noopener noreferrer"
            style="flex-shrink: 0; height: 4rem; padding: 0 1rem; background: #fff; border-radius: 0.5rem; border: 1px solid #e5e7eb; display: inline-flex; align-items: center; justify-content: center; text-decoration: none;"
            aria-label={brand.name}
          >
            {brand.logo ? (
              <img src={brand.logo} alt={brand.name} style="max-height: 2.5rem; width: auto; object-fit: contain;" />
            ) : (
              <span class="text-charcoal font-heading text-base md:text-lg font-bold uppercase tracking-wide text-center">{brand.name}</span>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>