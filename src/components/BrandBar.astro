---
import { brands } from '../data/brands';
---

<section class="bg-section py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-charcoal text-center mb-10">Brands We Supply</h2>
    <div class="flex items-center gap-6 md:gap-10 overflow-x-auto whitespace-nowrap pb-4 scrollbar-hide">
      {brands.map(brand => (
        <a
          href={brand.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex flex-shrink-0 h-16 md:h-20 px-4 md:px-6 bg-white rounded-lg border border-border hover:border-primary transition-colors items-center justify-center"
          aria-label={brand.name}
        >
          {brand.logo ? (
            <img src={brand.logo} alt={brand.name} class="max-h-10 md:max-h-12 w-auto object-contain" />
          ) : (
            <span class="text-charcoal font-heading text-base md:text-lg font-bold uppercase tracking-wide text-center">{brand.name}</span>
          )}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>