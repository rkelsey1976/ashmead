---
import { brands } from '../data/site';
---

<section class="bg-section py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-charcoal text-center mb-12">Brands We Supply</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
      {brands.map(brand => (
        <div class="bg-white rounded-lg p-4 text-center border border-border hover:border-primary transition-colors">
          <span class="text-charcoal font-heading text-base font-bold uppercase tracking-wide">{brand}</span>
        </div>
      ))}
    </div>
  </div>
</section>