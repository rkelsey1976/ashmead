---
import { brands } from '../data/brands';
---

<section class="bg-section py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-charcoal text-center mb-10">Brands We Supply</h2>
    <div class="overflow-x-auto scrollbar-hide pb-2">
      <div class="flex items-center gap-10 md:gap-14" style="width: max-content; min-width: calc(100% + 6rem);">
        {brands.map(brand => (
          <a
            href={brand.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-shrink-0 inline-flex items-center h-14 md:h-16"
            aria-label={brand.name}
          >
            {brand.logo ? (
              <img src={brand.logo} alt={brand.name} class="h-full w-auto object-contain" />
            ) : (
              <span class="text-charcoal font-heading text-base md:text-lg font-bold uppercase tracking-wide">{brand.name}</span>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>