---
interface Props {
  title?: string;
  limit?: number;
}

import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const { limit = 9 } = Astro.props;

const reader = createReader(process.cwd(), keystaticConfig);
const slugs = await reader.collections.testimonials.list();
const allTestimonials = (
  await Promise.all(slugs.map(slug => reader.collections.testimonials.read(slug)))
).filter(Boolean);
const items = allTestimonials.slice(0, limit);
---

<section class="section-white overflow-hidden section-padding">
  <div class="container">

    <!-- Label -->
    <div class="flex items-center gap-3 mb-16">
      <span class="w-6 h-px bg-accent opacity-50"></span>
      <span class="text-primary/60 text-xs font-semibold uppercase tracking-[0.25em] font-body">What Customers Say</span>
    </div>

    <!-- Slider -->
    <div class="relative" id="testimonial-slider">

      <!-- Giant decorative quote mark -->
      <div class="absolute -top-8 -left-4 font-heading font-bold text-charcoal/[0.04] select-none pointer-events-none leading-none" style="font-size: clamp(12rem, 22vw, 20rem)" aria-hidden="true">"</div>

      <!-- Slides -->
      <div class="relative min-h-[280px] lg:min-h-[240px]">
        {items.map((t, i) => (
          <div
            class="testimonial-slide absolute inset-0 transition-all duration-700"
            class:list={[i === 0 ? 'opacity-100 translate-y-0 pointer-events-auto' : 'opacity-0 translate-y-6 pointer-events-none']}
            data-index={i}
          >
            <blockquote
              class="text-charcoal font-body leading-relaxed mb-10"
              style="font-size: clamp(1.15rem, 2.5vw, 1.65rem); max-width: 52rem"
            >
              &ldquo;{t?.quote}&rdquo;
            </blockquote>

            <!-- Stars -->
            <div class="flex gap-1 mb-6">
              {[...Array(5)].map((_, s) => (
                <svg class={`w-4 h-4 ${s < (t?.rating ?? 5) ? 'text-accent' : 'text-border'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Attribution -->
            <div class="flex items-center gap-4">
              <span class="w-8 h-px bg-accent/60"></span>
              <div>
                <p class="text-charcoal font-heading font-bold uppercase tracking-[0.15em] text-sm">{t?.name}</p>
                <p class="text-body text-xs uppercase tracking-[0.12em] font-body mt-0.5">{t?.role}{t?.location ? ` · ${t.location}` : ''}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Navigation -->
      <div class="flex items-center gap-6 mt-16 pt-8 border-t border-border">

        <!-- Dots -->
        <div class="flex gap-2 flex-1" id="testimonial-dots">
          {items.map((_, i) => (
            <button
              class="testimonial-dot h-[3px] transition-all duration-300 rounded-none"
              class:list={[i === 0 ? 'bg-accent w-8' : 'bg-border w-4 hover:bg-body/40']}
              data-index={i}
              aria-label={`Review ${i + 1}`}
            />
          ))}
        </div>

        <!-- Prev / Next -->
        <div class="flex gap-3">
          <button
            id="testimonial-prev"
            class="w-10 h-10 rounded-full border border-border text-body hover:border-primary hover:text-primary transition-all duration-300 flex items-center justify-center"
            aria-label="Previous review"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button
            id="testimonial-next"
            class="w-10 h-10 rounded-full border border-border text-body hover:border-primary hover:text-primary transition-all duration-300 flex items-center justify-center"
            aria-label="Next review"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  const slider = document.getElementById('testimonial-slider');
  if (slider) {
    const slides = slider.querySelectorAll<HTMLElement>('.testimonial-slide');
    const dots = slider.querySelectorAll<HTMLButtonElement>('.testimonial-dot');
    let current = 0;
    let autoTimer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      slides[current].classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      slides[current].classList.add('opacity-0', 'translate-y-6', 'pointer-events-none');
      dots[current].classList.remove('bg-accent', 'w-8');
      dots[current].classList.add('bg-border', 'w-4');

      current = (index + slides.length) % slides.length;

      slides[current].classList.remove('opacity-0', 'translate-y-6', 'pointer-events-none');
      slides[current].classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
      dots[current].classList.remove('bg-border', 'w-4');
      dots[current].classList.add('bg-accent', 'w-8');
    }

    function startAuto() {
      autoTimer = setInterval(() => goTo(current + 1), 6000);
    }

    function resetAuto() {
      clearInterval(autoTimer);
      startAuto();
    }

    document.getElementById('testimonial-next')?.addEventListener('click', () => { goTo(current + 1); resetAuto(); });
    document.getElementById('testimonial-prev')?.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
    dots.forEach(dot => dot.addEventListener('click', () => { goTo(Number(dot.dataset.index)); resetAuto(); }));

    startAuto();
  }
</script>
