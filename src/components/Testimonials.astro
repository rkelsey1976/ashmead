---
interface Props {
  title?: string;
  limit?: number;
}

import { testimonials } from '../data/testimonials';

const { title = "What Our Customers Say", limit = 6 } = Astro.props;
const items = testimonials.slice(0, limit);
---

<section class="py-12 md:py-16 bg-section">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-charcoal mb-8 text-center">{title}</h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map(item => (
        <blockquote class="bg-white p-6 border border-border shadow-sm flex flex-col">
          <div class="flex items-center gap-1 mb-3">
            {Array.from({ length: item.rating }).map(() => (
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-body italic flex-grow mb-4">"{item.quote}"</p>
          <footer class="mt-auto">
            <p class="font-bold text-charcoal">{item.name}</p>
            <p class="text-sm text-body">{item.role}, {item.location}</p>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
