---
interface Props {
  title?: string;
  limit?: number;
}

import { testimonials } from '../data/testimonials';

const { title = "What Our Customers Say", limit = 6 } = Astro.props;
const items = testimonials.slice(0, limit);
---

<section class="section-white section-padding">
  <div class="container">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-end mb-14">
      <div class="gsap-reveal">
        <div class="flex items-center gap-3 mb-5">
          <span class="h-px w-8 bg-primary"></span>
          <span class="text-primary text-sm font-semibold uppercase tracking-[0.2em]">Testimonials</span>
        </div>
        <h2 class="text-charcoal font-heading text-4xl md:text-5xl font-bold uppercase tracking-wide">{title}</h2>
      </div>
      
      <div class="gsap-reveal lg:text-right">
        <p class="text-body text-lg">Genuine feedback from roofers, builders and contractors who rely on our Bristol trade counter every day.</p>
      </div>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map((t, i) => (
        <div class="gsap-reveal bg-white rounded-xl p-8 border border-border hover:border-primary/20 hover:shadow-lg transition-all duration-500" style={`transition-delay: ${i * 0.1}s`}>
          <div class="flex gap-1 mb-5">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          
          <blockquote class="text-charcoal text-lg leading-relaxed mb-6 font-serif italic">
            “{t.quote}”
          </blockquote>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-primary/10 text-primary flex items-center justify-center font-heading font-bold text-lg">
              {t.name.charAt(0)}
            </div>
            <div>
              <p class="text-charcoal font-heading font-bold uppercase tracking-wide">{t.name}</p>
              <p class="text-body text-sm">{t.role}, {t.location}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
