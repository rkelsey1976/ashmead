---
interface Props {
  title?: string;
  limit?: number;
}

import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import AnimatedSection from './AnimatedSection.astro';
import SectionLabel from './SectionLabel.astro';

const { limit = 6 } = Astro.props;

const reader = createReader(process.cwd(), keystaticConfig);
const slugs = await reader.collections.testimonials.list();
const allTestimonials = (
  await Promise.all(slugs.map(slug => reader.collections.testimonials.read(slug)))
).filter(Boolean);
const items = allTestimonials.slice(0, limit);
---

<section class="bg-charcoal section-padding overflow-hidden relative">
  <!-- Diagonal texture -->
  <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: repeating-linear-gradient(-45deg, transparent, transparent 30px, white 30px, white 31px);"></div>

  <div class="container relative z-10">

    <AnimatedSection class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14">
      <div>
        <SectionLabel text="Customer Reviews" light={true} />
        <h2 class="text-white font-heading text-4xl md:text-5xl font-bold uppercase tracking-wide leading-[0.95]">
          Trusted by Roofers
          <span class="block text-accent">Across the South West</span>
        </h2>
      </div>
      <div class="flex gap-1.5 flex-shrink-0">
        {[...Array(5)].map(() => (
          <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
        <span class="text-white/40 text-sm ml-2 self-center">5.0 average</span>
      </div>
    </AnimatedSection>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-white/5">
      {items.map((t, i) => (
        <AnimatedSection delay={i * 0.08}>
          <article class="bg-charcoal p-8 flex flex-col h-full group hover:bg-[#0B2240] transition-colors duration-300 relative overflow-hidden">
            <!-- Left accent bar -->
            <div class="absolute left-0 top-0 w-0.5 h-0 bg-accent transition-all duration-500 group-hover:h-full"></div>

            <!-- Stars -->
            <div class="flex gap-1 mb-6">
              {[...Array(5)].map((_, s) => (
                <svg class={`w-4 h-4 ${s < (t?.rating ?? 5) ? 'text-accent' : 'text-white/20'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <blockquote class="text-white/80 leading-relaxed flex-1 mb-8 text-base">
              &ldquo;{t?.quote}&rdquo;
            </blockquote>

            <!-- Attribution -->
            <div class="flex items-center gap-4 border-t border-white/10 pt-6">
              <div class="w-10 h-10 bg-accent/15 flex items-center justify-center flex-shrink-0 text-accent font-heading font-bold text-sm">
                {t?.name?.charAt(0).toUpperCase()}
              </div>
              <div>
                <p class="text-white font-heading font-bold uppercase tracking-[0.12em] text-sm">{t?.name}</p>
                <p class="text-white/40 text-[11px] uppercase tracking-[0.1em] mt-0.5">{t?.role}{t?.location ? ` · ${t.location}` : ''}</p>
              </div>
            </div>
          </article>
        </AnimatedSection>
      ))}
    </div>

  </div>
</section>
