---
import { getSiteSettings } from '../lib/siteSettings';

interface Props {
  title?: string;
}

const { title = "Talk to the\nTrade Team." } = Astro.props;
const { PHONE, PHONE_HREF, OPENING_HOURS } = await getSiteSettings();

const isOpen = (h: { opens: string }) => h.opens !== 'Closed' && h.opens !== '';
const weekdays = OPENING_HOURS.filter(h => isOpen(h));
const firstDay = weekdays[0]?.day ?? 'Monday';
const lastWeekday = weekdays.filter(h => !['Saturday','Sunday'].includes(h.day)).slice(-1)[0];
const saturday = OPENING_HOURS.find(h => h.day === 'Saturday');
---

<section class="bg-charcoal overflow-hidden relative">
  <div class="absolute inset-0 opacity-[0.05]" style="background-image: repeating-linear-gradient(-45deg, transparent, transparent 30px, white 30px, white 31px);"></div>
  <div class="container relative z-10">
    <div class="grid lg:grid-cols-2 gap-0 min-h-[420px]">

      <!-- Left: headline -->
      <div class="flex flex-col justify-center py-16 lg:py-20 lg:pr-16 border-b lg:border-b-0 lg:border-r border-white/10">
        <div class="flex items-center gap-3 mb-8">
          <span class="w-6 h-px bg-accent opacity-60"></span>
          <span class="text-accent/70 text-xs font-semibold uppercase tracking-[0.25em] font-body">Trade Enquiries</span>
        </div>
        <h2 class="font-heading font-bold uppercase text-white leading-[0.9] tracking-tight mb-6"
            style="font-size: clamp(2.8rem, 5.5vw, 5rem)">
          Talk to the<br>Trade Team.
        </h2>
        <p class="text-white/50 font-body text-base leading-relaxed max-w-sm">
          Expert advice, trade pricing and fast delivery across the South West. Accounts available for regular contractors.
        </p>
      </div>

      <!-- Right: phone + hours + CTAs -->
      <div class="flex flex-col justify-center py-16 lg:py-20 lg:pl-16 gap-8">

        <!-- Phone number -->
        <a href={PHONE_HREF}
           class="group inline-block">
          <p class="text-white/30 text-xs font-semibold uppercase tracking-[0.22em] font-body mb-2">Call us direct</p>
          <p class="font-heading font-bold text-accent leading-none tracking-tight group-hover:text-white transition-colors duration-300"
             style="font-size: clamp(2.2rem, 5vw, 3.8rem)">{PHONE}</p>
        </a>

        <!-- Opening hours summary -->
        <div class="border-t border-white/10 pt-6">
          <p class="text-white/30 text-[10px] font-semibold uppercase tracking-[0.22em] font-body mb-3">Opening hours</p>
          <div class="flex flex-col gap-1">
            {lastWeekday && (
              <div class="flex justify-between gap-8">
                <span class="text-white/60 text-sm font-body">{firstDay} – {lastWeekday.day}</span>
                <span class="text-white text-sm font-semibold font-body">{lastWeekday.opens} – {lastWeekday.closes}</span>
              </div>
            )}
            {saturday && (
              <div class="flex justify-between gap-8">
                <span class="text-white/60 text-sm font-body">Saturday</span>
                {!isOpen(saturday)
                  ? <span class="text-white/40 text-sm font-body">Closed</span>
                  : <span class="text-white text-sm font-semibold font-body">{saturday.opens} – {saturday.closes}</span>
                }
              </div>
            )}
            <div class="flex justify-between gap-8">
              <span class="text-white/60 text-sm font-body">Sunday</span>
              <span class="text-white/40 text-sm font-body">Closed</span>
            </div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <a href={PHONE_HREF}
             class="inline-flex items-center justify-center gap-2 bg-accent text-charcoal font-heading font-bold uppercase tracking-wide text-sm px-6 py-3.5 hover:bg-white transition-colors duration-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call Now
          </a>
          <a href="/contact"
             class="inline-flex items-center justify-center gap-2 border border-white/20 text-white font-heading font-bold uppercase tracking-wide text-sm px-6 py-3.5 hover:border-white hover:bg-white/5 transition-all duration-300">
            Get a Quote
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
