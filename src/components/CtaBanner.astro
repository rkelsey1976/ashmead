---
import Button from './Button.astro';

interface Props {
  title?: string;
  subtitle?: string;
}

const { title = "Get a Quote", subtitle } = Astro.props;
---

<section class="bg-primary py-12 md:py-16 relative overflow-hidden">
  <!-- Decorative house shape watermark -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 w-2/5 max-w-md opacity-10 pointer-events-none">
    <svg viewBox="0 0 120 69" fill="white" class="w-full h-auto"><polygon points="60,0 120,69 0,69" /></svg>
  </div>
  <div class="max-w-7xl mx-auto px-4 text-center relative z-10">
    <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-white mb-3">{title}</h2>
    {subtitle && (
      <p class="text-white/90 mb-6 text-lg">{subtitle}</p>
    )}
    <p class="text-white/80 mb-6">Call our trade team for expert advice, pricing and fast delivery across the South West.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <Button variant="white" href="phone" icon="phone" size="lg" />
      <a href="/contact" class="inline-block bg-transparent border-2 border-white text-white font-bold px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors text-lg">Contact Us</a>
    </div>
  </div>
</section>