---
import Button from './Button.astro';

interface Props {
  title?: string;
  subtitle?: string;
}

const { title = "Get a Quote", subtitle } = Astro.props;
---

<section class="relative overflow-hidden py-10 md:py-14">
  <!-- Background image with green tint -->
  <div class="absolute inset-0 z-0">
    <img src="/images/hero-home.jpg" alt="" class="w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-primary/85"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/40 to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 text-center">
    <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-white mb-3">{title}</h2>
    {subtitle && (
      <p class="text-white/90 mb-6 text-lg">{subtitle}</p>
    )}
    <p class="text-white/90 mb-6 max-w-2xl mx-auto">Call our trade team for expert advice, pricing and fast delivery across the South West.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <Button variant="white" href="phone" icon="phone" size="lg" />
      <a href="/contact" class="inline-block bg-transparent border-2 border-white text-white font-bold px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors text-lg">Contact Us</a>
    </div>
  </div>
</section>