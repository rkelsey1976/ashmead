---
import Button from './Button.astro';

interface Props {
  title?: string;
  subtitle?: string;
}

const { title = "Ready to Order?", subtitle } = Astro.props;
---

<section class="relative overflow-hidden py-20 md:py-24">
  <!-- Background image with dark overlay -->
  <div class="absolute inset-0 z-0">
    <img src="/images/hero-home.jpg" alt="" class="w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-charcoal/85"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/30 to-transparent"></div>
  </div>
  
  <div class="relative z-10 container">
    <div class="max-w-4xl">
      <div class="gsap-reveal">
        <div class="flex items-center gap-3 mb-5">
          <span class="h-px w-6 bg-accent opacity-60"></span>
          <span class="text-accent text-xs font-bold uppercase tracking-[0.22em]">Trade Enquiries</span>
        </div>
        
        <h2 class="text-white font-heading text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-wide mb-6">{title}</h2>
        
        <p class="text-white/80 text-lg md:text-xl leading-relaxed mb-8 max-w-2xl">
          {subtitle || "Call our trade team for expert advice, pricing and fast delivery across the South West. Trade accounts and bulk pricing available."}
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <Button variant="white" href="phone" icon="phone" size="lg" />
          <Button variant="ghost" href="/contact">Request a Quote</Button>
        </div>
      </div>
    </div>
  </div>
</section>
