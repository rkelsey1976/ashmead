---
import { PHONE, PHONE_HREF } from '../data/site';

interface Props {
  title?: string;
  subtitle?: string;
}

const { title = "Get a Quote", subtitle } = Astro.props;
---

<section class="bg-accent py-10 md:py-14">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <h2 class="text-2xl md:text-3xl font-bold font-heading uppercase tracking-wide text-white mb-3">{title}</h2>
    {subtitle && (
      <p class="text-white/90 mb-6 text-lg">{subtitle}</p>
    )}
    <p class="text-white/80 mb-6">Call our trade team for expert advice, pricing and fast delivery across the South West.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={PHONE_HREF} class="inline-flex items-center gap-2 bg-white text-accent font-bold px-8 py-4 rounded hover:bg-heading transition-colors text-lg">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {PHONE}
      </a>
      <a href="/contact" class="inline-block bg-transparent border-2 border-white text-white font-bold px-8 py-4 rounded hover:bg-white hover:text-accent transition-colors text-lg">
        Contact Us
      </a>
    </div>
  </div>
</section>