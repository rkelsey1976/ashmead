---
interface Props {
  text: string;
  light?: boolean;
}

const { text, light = false } = Astro.props;
---

<div class="flex items-center gap-3 mb-4">
  <span class="h-px w-8 bg-primary"></span>
  <span class={`text-sm font-semibold uppercase tracking-[0.2em] ${light ? 'text-white/70' : 'text-primary'}`}>{text}</span>
</div>
