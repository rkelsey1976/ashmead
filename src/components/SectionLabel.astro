---
interface Props {
  text: string;
  light?: boolean;
}

const { text, light = false } = Astro.props;
---

<div class="flex items-center gap-3 mb-4">
  <span class="h-px w-6 bg-current opacity-40"></span>
  <span class={`text-xs font-bold uppercase tracking-[0.22em] ${light ? 'text-white/60' : 'text-primary'}`}>{text}</span>
</div>
