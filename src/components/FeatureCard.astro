---
interface Props {
  title: string;
  description: string;
  icon: 'trade' | 'stock' | 'delivery';
}

const { title, description, icon } = Astro.props;

const icons: Record<string, string> = {
  trade: '<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>',
  stock: '<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>',
  delivery: '<svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>'
};
---

<div class="bg-white rounded-lg p-8 border border-border hover:border-primary hover:shadow-lg transition-all">
  <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
    <Fragment set:html={icons[icon]} />
  </div>
  <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-3">{title}</h3>
  <p class="text-body text-sm leading-relaxed">{description}</p>
</div>