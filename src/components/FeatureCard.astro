---
interface Props {
  title: string;
  description: string;
  icon: 'trade' | 'stock' | 'delivery' | 'support';
}

const { title, description, icon } = Astro.props;

const icons: Record<string, string> = {
  trade: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
  stock: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>',
  delivery: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>',
  support: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>'
};
---

<div class="group relative bg-white p-8 border border-border hover:border-primary/20 transition-all duration-500 hover:shadow-xl h-full">
  <div class="absolute top-0 left-0 w-1 h-0 bg-primary transition-all duration-500 group-hover:h-full"></div>

  <div class="relative">
    <div class="w-12 h-12 bg-primary/10 flex items-center justify-center mb-6 text-primary transition-all duration-500 group-hover:bg-primary group-hover:text-white">
      <Fragment set:html={icons[icon]} />
    </div>
    <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-3">{title}</h3>
    <p class="text-body leading-relaxed text-sm">{description}</p>
  </div>
</div>
