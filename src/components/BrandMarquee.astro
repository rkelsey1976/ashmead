---
export interface Props {
  label?: string;
  brands: { name: string; logo: string | null; url: string }[];
  theme?: 'green' | 'white';
  speed?: number;
}

const { label, brands, theme = 'green', speed = 35 } = Astro.props;

// Standard marquee needs exactly 2x duplication and -50% translation
const duplicated = [...brands, ...brands];
const isGreen = theme === 'green';
const duration = `${speed}s`;
---

<div class:list={['py-4 md:py-6 overflow-hidden', isGreen ? 'bg-primary border-t border-white/10' : 'bg-section border-t border-border']}>
  {label && (
    <div class:list={['container mb-4 md:mb-5 text-center', isGreen ? 'text-white' : 'text-charcoal']}>
      <span class="text-xs md:text-sm font-medium uppercase tracking-wider whitespace-nowrap">{label}</span>
    </div>
  )}
  
  <div class="marquee-track flex items-center gap-10 md:gap-16" style={{ width: 'max-content', '--duration': duration }}>
    {duplicated.map((brand, i) => (
      <a
        key={i}
        href={brand.url}
        target="_blank"
        rel="noopener noreferrer"
        class:list={[
          'flex-shrink-0 inline-flex items-center justify-center rounded-lg bg-white shadow-sm group transition-all duration-300 hover:shadow-md hover:-translate-y-0.5',
          isGreen ? 'h-14 md:h-16 px-6 md:px-10' : 'h-16 md:h-20 px-8 md:px-12'
        ]}
        aria-label={brand.name}
      >
        {brand.logo ? (
          <img
            src={brand.logo}
            alt={brand.name}
            class="h-7 md:h-9 w-auto max-w-[140px] md:max-w-[180px] object-contain transition-transform duration-300 group-hover:scale-105"
          />
        ) : (
          <span class:list={[
            'font-heading text-base md:text-lg font-bold uppercase tracking-wide',
            isGreen ? 'text-charcoal' : 'text-charcoal'
          ]}>{brand.name}</span>
        )}
      </a>
    ))}
  </div>
</div>

<style>
  .marquee-track {
    animation: marquee var(--duration, 60s) linear infinite;
    will-change: transform;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
