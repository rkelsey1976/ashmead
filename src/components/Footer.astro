---
import { PHONE, PHONE_HREF, BUSINESS_NAME, navLinks } from '../data/site';
import { products } from '../data/products';
import { areas } from '../data/areas';
---

<footer class="bg-section border-t border-card">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Company -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-10 h-10 bg-accent rounded flex items-center justify-center">
            <span class="text-white font-bold text-xl font-heading">A</span>
          </div>
          <div>
            <span class="text-heading font-heading text-lg font-bold uppercase tracking-wide">Ashmead</span>
            <span class="block text-body text-xs leading-tight">Roofing Supplies</span>
          </div>
        </div>
        <p class="text-body text-sm mb-4">{BUSINESS_NAME} is Bristol's trusted roofing trade counter, supplying professional roofers and builders across the South West.</p>
        <a href={PHONE_HREF} class="inline-flex items-center gap-2 text-accent hover:text-accent-light transition-colors font-bold text-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {PHONE}
        </a>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-heading font-heading text-lg font-bold uppercase tracking-wide mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {navLinks.map(link => (
            <li><a href={link.href} class="text-body hover:text-accent transition-colors text-sm">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Products -->
      <div>
        <h3 class="text-heading font-heading text-lg font-bold uppercase tracking-wide mb-4">Products</h3>
        <ul class="space-y-2">
          {products.slice(0, 8).map(p => (
            <li><a href={`/products/${p.slug}`} class="text-body hover:text-accent transition-colors text-sm">{p.name}</a></li>
          ))}
          <li><a href="/products" class="text-accent hover:text-accent-light transition-colors text-sm font-medium">View all products →</a></li>
        </ul>
      </div>

      <!-- Areas -->
      <div>
        <h3 class="text-heading font-heading text-lg font-bold uppercase tracking-wide mb-4">Areas We Cover</h3>
        <ul class="space-y-2">
          {areas.map(a => (
            <li><a href={`/areas/${a.slug}`} class="text-body hover:text-accent transition-colors text-sm">{a.name}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-card mt-8 pt-8 text-center text-sm text-body">
      <p>&copy; {new Date().getFullYear()} {BUSINESS_NAME}. All rights reserved.</p>
    </div>
  </div>
</footer>