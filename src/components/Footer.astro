---
import { PHONE, PHONE_HREF, BUSINESS_NAME, navLinks } from '../data/site';
import { products } from '../data/products';
import { areas } from '../data/areas';

const footerColumns = [
  {
    title: 'Quick Links',
    links: navLinks.map(link => ({ label: link.label, href: link.href })),
  },
  {
    title: 'Products',
    links: [
      ...products.slice(0, 8).map(p => ({ label: p.name, href: `/products/${p.slug}` })),
      { label: 'View all products →', href: '/products', highlight: true },
    ],
  },
  {
    title: 'Areas We Cover',
    links: areas.map(a => ({ label: a.name, href: `/areas/${a.slug}` })),
  },
];
---

<footer class="bg-charcoal text-white">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Company -->
      <div class="md:col-span-2 lg:col-span-1">
        <div class="mb-4">
          <img src="/logo-original.png" alt="Ashmead Roofing Supplies" class="h-10 w-auto" />
        </div>
        <p class="text-gray-300 text-sm mb-4">{BUSINESS_NAME} is Bristol's trusted roofing trade counter, supplying professional roofers and builders across the South West.</p>
        <a href={PHONE_HREF} class="inline-flex items-center gap-2 text-primary hover:text-primary-hover transition-colors font-bold text-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {PHONE}
        </a>
      </div>

      {footerColumns.map(col => (
        <div class="footer-accordion md:block">
          <button type="button" class="footer-accordion-heading md:hidden w-full flex items-center justify-between text-left py-3 border-b border-gray-600">
            <span class="text-white font-heading text-lg font-bold uppercase tracking-wide">{col.title}</span>
            <svg class="footer-accordion-icon w-5 h-5 text-primary transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </button>
          <h3 class="hidden md:block text-white font-heading text-lg font-bold uppercase tracking-wide mb-4">{col.title}</h3>
          <ul class="footer-accordion-body hidden md:block md:space-y-2 px-1 pb-4">
            {col.links.map(link => (
              <li class="py-2 md:py-0 border-b border-gray-700/50 md:border-0">
                <a href={link.href} class:list={['hover:text-primary transition-colors text-sm', link.highlight ? 'text-primary hover:text-primary-hover font-medium' : 'text-gray-300']}>{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t border-gray-600 mt-8 pt-8 text-center text-sm text-gray-400">
      <p>&copy; {new Date().getFullYear()} {BUSINESS_NAME}. All rights reserved.</p>
    </div>
  </div>

  <script>
    document.querySelectorAll('.footer-accordion').forEach(acc => {
      const heading = acc.querySelector('.footer-accordion-heading');
      const body = acc.querySelector('.footer-accordion-body');
      const icon = acc.querySelector('.footer-accordion-icon');
      if (heading && body && icon) {
        heading.addEventListener('click', () => {
          const isOpen = !body.classList.contains('hidden');
          if (isOpen) {
            body.classList.add('hidden');
            icon.classList.remove('rotate-45');
          } else {
            body.classList.remove('hidden');
            icon.classList.add('rotate-45');
          }
        });
      }
    });
  </script>
</footer>