---
import { BUSINESS_NAME } from '../data/site';
import { areas } from '../data/areas';
import { reader } from '../lib/reader';
import { getSiteSettings } from '../lib/siteSettings';

const { PHONE, PHONE_HREF, EMAIL, ADDRESS, POSTCODE, OPENING_HOURS } = await getSiteSettings();

const slugs = await reader.collections.products.list();
const footerProducts = (await Promise.all(
  slugs.map(async slug => {
    const data = await reader.collections.products.read(slug);
    return data ? { slug, name: data.name } : null;
  })
)).filter(Boolean).slice(0, 8) as { slug: string; name: string }[];
---

<footer class="bg-[#0B1F3A] text-white">

  <!-- Accent line -->
  <div class="h-px" style="background:linear-gradient(90deg,transparent,#4ADE80 30%,#0A5C36 70%,transparent)"></div>

  <div class="container pt-14 pb-8">

    <!-- Desktop grid: 4 / 2 / 2 / 4 -->
    <div class="hidden lg:grid lg:grid-cols-12 gap-10 xl:gap-14">

      <!-- Brand column -->
      <div class="lg:col-span-4 flex flex-col">
        <a href="/" class="flex items-center gap-3 mb-6" aria-label="Ashmead Roofing Supplies — Home">
          <img src="/logo-mark-inverted.svg" alt="" aria-hidden="true" class="h-10 w-auto flex-shrink-0" />
          <div class="flex flex-col items-end font-heading font-bold uppercase tracking-tight" style="line-height:1;gap:1px">
            <span class="text-white text-[15px]">Ashmead Roofing</span>
            <span class="text-[#4ADE80] text-[15px]">Supplies Ltd</span>
          </div>
        </a>

        <p class="text-white/50 text-sm leading-relaxed mb-6 max-w-xs">
          Bristol's specialist roofing trade counter. Supplying professional roofers, builders and developers across the South West since 1984.
        </p>

        <!-- Phone -->
        <a href={PHONE_HREF} class="group inline-flex items-center gap-2 mb-4 hover:text-[#4ADE80] transition-colors duration-300">
          <svg class="w-4 h-4 text-[#4ADE80] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          <span class="text-white font-heading font-bold text-xl tracking-wide group-hover:text-[#4ADE80] transition-colors duration-300">{PHONE}</span>
        </a>

        <a href="/contact" class="inline-flex items-center gap-2 bg-[#0A5C36] hover:bg-[#4ADE80] hover:text-[#0B1F3A] text-white font-heading font-bold uppercase tracking-wider text-xs px-6 py-3 transition-all duration-300 mb-8 self-start">
          Get a Quote
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>

        <!-- Trust points -->
        <ul class="space-y-2 mt-auto">
          {[
            'Authorised stockist — major brands',
            'Next-day delivery across the South West',
            'Trade pricing & accounts available',
            'Est. 1984 — 40+ years in roofing',
          ].map(point => (
            <li class="flex items-center gap-2 text-white/40 text-xs">
              <span class="w-1 h-1 bg-[#4ADE80] flex-shrink-0"></span>
              {point}
            </li>
          ))}
        </ul>
      </div>

      <!-- Products column -->
      <div class="lg:col-span-2">
        <h3 class="text-white/40 font-heading text-[10px] font-bold uppercase tracking-[0.25em] mb-5">Products</h3>
        <ul class="space-y-2.5">
          {footerProducts.map(p => (
            <li><a href={`/products/${p.slug}`} class="text-white/60 hover:text-white transition-colors duration-200 text-sm">{p.name}</a></li>
          ))}
          <li class="pt-2 border-t border-white/10 mt-2">
            <a href="/products" class="inline-flex items-center gap-1.5 text-[#4ADE80] hover:text-white transition-colors duration-200 text-xs font-semibold uppercase tracking-wider">
              All products
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- Areas column -->
      <div class="lg:col-span-2">
        <h3 class="text-white/40 font-heading text-[10px] font-bold uppercase tracking-[0.25em] mb-5">Areas</h3>
        <ul class="space-y-2.5">
          {areas.map(a => (
            <li><a href={`/areas/${a.slug}`} class="text-white/60 hover:text-white transition-colors duration-200 text-sm">{a.name}</a></li>
          ))}
          <li class="pt-2 border-t border-white/10 mt-2">
            <a href="/areas" class="inline-flex items-center gap-1.5 text-[#4ADE80] hover:text-white transition-colors duration-200 text-xs font-semibold uppercase tracking-wider">
              All areas
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- Depot column -->
      <div class="lg:col-span-4">
        <h3 class="text-white/40 font-heading text-[10px] font-bold uppercase tracking-[0.25em] mb-5">Depot & Hours</h3>

        <address class="not-italic mb-6 space-y-2">
          <p class="text-white text-sm font-semibold">{BUSINESS_NAME}</p>
          <p class="text-white/60 text-sm leading-relaxed">{ADDRESS}<br />{POSTCODE}</p>
          <a href={`mailto:${EMAIL}`} class="inline-flex items-center gap-2 text-white/60 hover:text-[#4ADE80] transition-colors duration-200 text-sm">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            {EMAIL}
          </a>
        </address>

        <!-- Condensed hours -->
        <div class="space-y-2 mb-6">
          {(() => {
            const weekdays = OPENING_HOURS.filter(h => !['Saturday','Sunday'].includes(h.day));
            const saturday = OPENING_HOURS.find(h => h.day === 'Saturday');
            const sunday = OPENING_HOURS.find(h => h.day === 'Sunday');
            const wdOpen = weekdays[0]?.opens && weekdays[0]?.closes;
            return (
              <>
                <div class="flex justify-between text-sm border-b border-white/5 pb-2">
                  <span class="text-white/60">Mon – Fri</span>
                  <span class={wdOpen ? 'text-white font-medium' : 'text-white/30'}>
                    {wdOpen ? `${weekdays[0].opens}–${weekdays[0].closes}` : 'Closed'}
                  </span>
                </div>
                {saturday && (
                  <div class="flex justify-between text-sm border-b border-white/5 pb-2">
                    <span class="text-white/60">Saturday</span>
                    <span class={saturday.opens ? 'text-white font-medium' : 'text-white/30'}>
                      {saturday.opens ? `${saturday.opens}–${saturday.closes}` : 'Closed'}
                    </span>
                  </div>
                )}
                {sunday && (
                  <div class="flex justify-between text-sm">
                    <span class="text-white/60">Sunday</span>
                    <span class={sunday.opens ? 'text-white font-medium' : 'text-white/30'}>
                      {sunday.opens ? `${sunday.opens}–${sunday.closes}` : 'Closed'}
                    </span>
                  </div>
                )}
              </>
            );
          })()}
        </div>

        <a
          href="https://maps.google.com/?q=Ashmead+Roofing+Supplies,Keynsham,BS31+1TU"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-white/40 hover:text-white transition-colors duration-200 text-xs uppercase tracking-wider font-semibold"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          Get directions
        </a>
      </div>

    </div>

    <!-- Mobile layout -->
    <div class="lg:hidden">

      <!-- Brand block -->
      <div class="mb-8 pb-8 border-b border-white/10">
        <a href="/" class="flex items-center gap-3 mb-5" aria-label="Ashmead Roofing Supplies — Home">
          <img src="/logo-mark-inverted.svg" alt="" aria-hidden="true" class="h-9 w-auto flex-shrink-0" />
          <div class="flex flex-col items-end font-heading font-bold uppercase tracking-tight" style="line-height:1;gap:1px">
            <span class="text-white text-[14px]">Ashmead Roofing</span>
            <span class="text-[#4ADE80] text-[14px]">Supplies Ltd</span>
          </div>
        </a>
        <p class="text-white/50 text-sm leading-relaxed mb-6">
          Bristol's specialist roofing trade counter. Supplying professional roofers, builders and developers across the South West since 1984.
        </p>
        <div class="flex gap-3">
          <a href={PHONE_HREF} class="flex-1 inline-flex items-center justify-center gap-2 bg-[#4ADE80]/10 text-[#4ADE80] font-semibold px-4 py-3 text-sm hover:bg-[#4ADE80] hover:text-[#0B1F3A] transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            {PHONE}
          </a>
          <a href="/contact" class="flex-1 inline-flex items-center justify-center bg-[#0A5C36] hover:bg-[#0b6b40] text-white font-semibold px-4 py-3 text-sm transition-colors">
            Get a Quote
          </a>
        </div>
      </div>

      <!-- Accordion: Products -->
      <div class="border-b border-white/10">
        <button class="footer-acc-btn w-full flex items-center justify-between py-4" aria-expanded="false" data-target="acc-products">
          <span class="text-white/60 font-heading text-xs font-bold uppercase tracking-[0.2em]">Products</span>
          <svg class="w-4 h-4 text-white/30 footer-acc-icon transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div id="acc-products" class="overflow-hidden" style="max-height:0;transition:max-height 0.3s ease">
          <ul class="space-y-3 pb-4">
            {footerProducts.map(p => (
              <li><a href={`/products/${p.slug}`} class="text-white/60 hover:text-white transition-colors text-sm">{p.name}</a></li>
            ))}
            <li class="pt-1"><a href="/products" class="text-[#4ADE80] text-sm font-semibold">All products →</a></li>
          </ul>
        </div>
      </div>

      <!-- Accordion: Areas -->
      <div class="border-b border-white/10">
        <button class="footer-acc-btn w-full flex items-center justify-between py-4" aria-expanded="false" data-target="acc-areas">
          <span class="text-white/60 font-heading text-xs font-bold uppercase tracking-[0.2em]">Areas We Cover</span>
          <svg class="w-4 h-4 text-white/30 footer-acc-icon transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div id="acc-areas" class="overflow-hidden" style="max-height:0;transition:max-height 0.3s ease">
          <ul class="space-y-3 pb-4">
            {areas.slice(0, 8).map(a => (
              <li><a href={`/areas/${a.slug}`} class="text-white/60 hover:text-white transition-colors text-sm">{a.name}</a></li>
            ))}
            <li class="pt-1"><a href="/areas" class="text-[#4ADE80] text-sm font-semibold">All areas →</a></li>
          </ul>
        </div>
      </div>

      <!-- Accordion: Depot & Hours -->
      <div class="border-b border-white/10">
        <button class="footer-acc-btn w-full flex items-center justify-between py-4" aria-expanded="false" data-target="acc-depot">
          <span class="text-white/60 font-heading text-xs font-bold uppercase tracking-[0.2em]">Depot & Hours</span>
          <svg class="w-4 h-4 text-white/30 footer-acc-icon transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div id="acc-depot" class="overflow-hidden" style="max-height:0;transition:max-height 0.3s ease">
          <div class="space-y-4 pb-4">
            <address class="not-italic">
              <p class="text-white/60 text-sm leading-relaxed">{ADDRESS}<br /><span class="text-white">{POSTCODE}</span></p>
            </address>
            <a href={`mailto:${EMAIL}`} class="text-white/60 hover:text-[#4ADE80] transition-colors text-sm">{EMAIL}</a>
            <div class="pt-1 space-y-1.5">
              {OPENING_HOURS.map(day => (
                <div class="flex justify-between text-sm">
                  <span class="text-white/60">{day.day}</span>
                  <span class={day.opens && day.closes ? 'text-white' : 'text-white/30'}>
                    {day.opens && day.closes ? `${day.opens}–${day.closes}` : 'Closed'}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 mt-12 pt-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-xs text-white/50">&copy; {new Date().getFullYear()} {BUSINESS_NAME}. All rights reserved.</p>
        <div class="flex items-center gap-6 text-xs text-white/50">
          <a href="/privacy-policy" class="text-white/50 hover:text-white transition-colors">Privacy Policy</a>
          <a href="/faq" class="text-white/50 hover:text-white transition-colors">FAQ</a>
          <a href="/contact" class="text-white/50 hover:text-white transition-colors">Contact</a>
          <span class="text-white/50">Site by <a href="https://vortexdesignstudio.co.uk" class="text-white/50 hover:text-[#4ADE80] transition-colors">Vortex Design Studio</a></span>
        </div>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  document.querySelectorAll('.footer-acc-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = this.getAttribute('data-target');
      var panel = document.getElementById(id);
      var icon = this.querySelector('.footer-acc-icon');
      var isOpen = this.getAttribute('aria-expanded') === 'true';

      document.querySelectorAll('.footer-acc-btn').forEach(function(b) {
        b.setAttribute('aria-expanded', 'false');
        b.querySelector('.footer-acc-icon').style.transform = 'rotate(0deg)';
        var p = document.getElementById(b.getAttribute('data-target'));
        if (p) p.style.maxHeight = '0';
      });

      if (!isOpen) {
        this.setAttribute('aria-expanded', 'true');
        icon.style.transform = 'rotate(180deg)';
        panel.style.maxHeight = panel.scrollHeight + 'px';
      }
    });
  });
</script>
