---
interface Props {
  name: string;
  shortDesc: string;
  href: string;
  image?: string;
}

const { name, shortDesc, href, image } = Astro.props;
---

<a href={href} class="group bg-white rounded-lg overflow-hidden transition-all border border-border hover:border-primary hover:shadow-lg">
  {image && (
    <div class="h-48 overflow-hidden">
      <img src={image} alt={`Roofing supplies ${name}`} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
    </div>
  )}
  <div class="p-6 text-center">
    <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-2 group-hover:text-primary transition-colors">{name}</h3>
    <p class="text-body text-sm">{shortDesc}</p>
    <span class="text-primary text-sm mt-3 inline-block group-hover:text-primary-hover transition-colors">View supplies →</span>
  </div>
</a>