---
interface Props {
  name: string;
  shortDesc: string;
  href: string;
  image?: string;
}

const { name, shortDesc, href, image } = Astro.props;
---

<a href={href} class="group relative h-80 rounded-xl overflow-hidden">
  {image && (
    <img src={image} alt={`Roofing supplies ${name}`} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
  )}
  
  <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/50 to-transparent"></div>
  
  <div class="absolute inset-0 bg-primary/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  
  <div class="absolute bottom-0 left-0 right-0 p-6">
    <div class="transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
      <span class="inline-block text-accent text-sm font-semibold uppercase tracking-wider mb-2">Roofing Supplies</span>
      <h3 class="text-white font-heading text-3xl font-bold uppercase tracking-wide mb-2">{name}</h3>
      <p class="text-white/80 text-sm mb-4 line-clamp-2">{shortDesc}</p>
      <span class="inline-flex items-center gap-2 text-white text-sm font-semibold">
        View supplies
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </span>
    </div>
  </div>
</a>
