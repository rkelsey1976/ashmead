---
interface Props {
  name: string;
  shortDesc: string;
  href: string;
  image?: string;
  driveTime?: string;
  townCount?: number;
}

const { name, shortDesc, href, image, driveTime, townCount } = Astro.props;
---

<a href={href} class="group relative h-80 md:h-96 overflow-hidden block">
  {image && (
    <img src={image} alt={`Roofing supplies ${name}`} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
  )}

  <!-- Gradient -->
  <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/50 to-charcoal/10"></div>
  <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/15 transition-colors duration-500"></div>

  <!-- Drive time badge — top right -->
  {driveTime && (
    <div class="absolute top-4 right-4">
      <span class="inline-flex items-center gap-1.5 bg-charcoal/80 backdrop-blur-sm text-white/80 text-[10px] font-semibold uppercase tracking-[0.15em] px-3 py-1.5 border border-white/10">
        <svg class="w-3 h-3 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {driveTime}
      </span>
    </div>
  )}

  <!-- Content -->
  <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
    <div class="transform translate-y-1 group-hover:translate-y-0 transition-transform duration-400">

      {townCount && (
        <p class="text-accent text-[10px] font-semibold uppercase tracking-[0.2em] mb-2">{townCount}+ towns covered</p>
      )}

      <h3 class="text-white font-heading text-3xl md:text-4xl font-bold uppercase tracking-wide leading-none mb-2">{name}</h3>

      <p class="text-white/70 text-sm mb-4 line-clamp-2 max-w-xs">{shortDesc}</p>

      <span class="inline-flex items-center gap-2 text-accent text-sm font-semibold">
        View area
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </span>
    </div>
  </div>
</a>
