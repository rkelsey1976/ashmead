---
interface Props {
  name: string;
  shortDesc: string;
  href: string;
  image?: string;
}

const { name, shortDesc, href, image } = Astro.props;
---

<a href={href} class="group relative h-80 md:h-96 rounded-2xl overflow-hidden block shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-1">
  {image && (
    <img src={image} alt={`Roofing supplies ${name}`} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
  )}
  
  <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/60 to-transparent"></div>
  <div class="absolute inset-0 bg-primary/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  
  <div class="absolute top-4 left-4">
    <span class="inline-block bg-white/10 backdrop-blur-sm text-white text-xs font-semibold uppercase tracking-wider px-3 py-1.5 rounded-full border border-white/20">Roofing Supplies</span>
  </div>
  
  <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
    <div class="transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
      <h3 class="text-white font-heading text-3xl md:text-4xl font-bold uppercase tracking-wide mb-2">{name}</h3>
      <p class="text-white/80 text-sm md:text-base mb-4 line-clamp-2">{shortDesc}</p>
      <span class="inline-flex items-center gap-2 text-accent text-sm font-semibold">
        View supplies
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </span>
    </div>
  </div>
</a>
