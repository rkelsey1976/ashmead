---
interface Props {
  name: string;
  shortDesc: string;
  href: string;
  brands?: string[];
  image?: string;
}

const { name, shortDesc, href, brands = [], image } = Astro.props;
---

<a href={href} class="group relative bg-white rounded-xl overflow-hidden border border-border hover:border-primary/30 transition-all duration-500 hover:shadow-xl">
  <div class="h-56 overflow-hidden relative">
    {image && (
      <img src={image} alt={name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    
    {brands.length > 0 && (
      <div class="absolute top-4 left-4 flex flex-wrap gap-2">
        {brands.slice(0, 2).map(brand => (
          <span class="bg-white/95 text-charcoal text-xs font-semibold px-2.5 py-1 rounded-md shadow-sm">{brand}</span>
        ))}
      </div>
    )}
    
    <div class="absolute bottom-4 right-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
      <span class="inline-flex items-center justify-center w-10 h-10 bg-primary text-white rounded-full">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </span>
    </div>
  </div>
  
  <div class="p-6">
    <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-2 group-hover:text-primary transition-colors duration-300">{name}</h3>
    <p class="text-body text-sm leading-relaxed mb-4 line-clamp-2">{shortDesc}</p>
    
    <span class="inline-flex items-center gap-2 text-primary text-sm font-semibold group-hover:text-primary-hover transition-colors duration-300">
      Explore range
      <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </div>
</a>
