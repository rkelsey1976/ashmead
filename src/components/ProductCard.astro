---
interface Props {
  name: string;
  shortDesc: string;
  href: string;
  brands?: string[];
}

const { name, shortDesc, href, brands = [] } = Astro.props;
---

<a href={href} class="group relative bg-white rounded-lg p-6 pt-10 transition-all border border-border hover:border-primary hover:shadow-lg overflow-hidden">
  <!-- House accent on hover -->
  <div class="absolute top-0 left-4 w-6 h-4 opacity-0 group-hover:opacity-100 transition-opacity">
    <svg viewBox="0 0 120 69" fill="currentColor" class="text-primary w-full h-auto"><polygon points="60,0 120,69 0,69" /></svg>
  </div>
  <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-2 group-hover:text-primary transition-colors">{name}</h3>
  <p class="text-body text-sm leading-relaxed mb-4">{shortDesc}</p>
  {brands.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      {brands.map(brand => (
        <span class="bg-primary/10 text-primary text-xs font-medium px-2 py-1 rounded">{brand}</span>
      ))}
    </div>
  )}
  <span class="text-primary text-sm font-medium group-hover:text-primary-hover transition-colors">Learn more →</span>
</a>