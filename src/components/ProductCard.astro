---
interface Props {
  name: string;
  shortDesc: string;
  href: string;
  brands?: string[];
  image?: string;
}

const { name, shortDesc, href, brands = [], image } = Astro.props;
---

<a href={href} class="group bg-white rounded-lg overflow-hidden transition-all border border-border hover:border-primary hover:shadow-lg">
  {image && (
    <div class="h-44 overflow-hidden bg-section">
      <img src={image} alt={name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
    </div>
  )}
  <div class="p-6">
    <h3 class="text-charcoal font-heading text-xl font-bold uppercase tracking-wide mb-2 group-hover:text-primary transition-colors">{name}</h3>
    <p class="text-body text-sm leading-relaxed mb-4">{shortDesc}</p>
    {brands.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-4">
        {brands.map(brand => (
          <span class="bg-primary/10 text-primary text-xs font-medium px-2 py-1 rounded">{brand}</span>
        ))}
      </div>
    )}
    <span class="text-primary text-sm font-medium group-hover:text-primary-hover transition-colors">Learn more →</span>
  </div>
</a>