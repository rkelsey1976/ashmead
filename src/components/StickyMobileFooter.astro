---
import { getSiteSettings } from '../lib/siteSettings';
const { PHONE, PHONE_HREF } = await getSiteSettings();
---

<!-- Sticky mobile CTA footer -->
<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-white border-t border-border shadow-[0_-4px_20px_rgba(0,0,0,0.08)]">
  <div class="flex items-center">
    <a
      href={PHONE_HREF}
      class="flex-1 flex items-center justify-center gap-2 py-3.5 text-charcoal font-semibold text-sm uppercase tracking-wide hover:bg-section transition-colors"
    >
      <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      {PHONE}
    </a>

    <div class="w-px h-10 bg-border"></div>

    <a
      href="/contact"
      class="flex-1 flex items-center justify-center gap-2 py-3.5 bg-primary hover:bg-primary-hover text-white font-semibold text-sm uppercase tracking-wide transition-colors"
    >
      Get a Quote
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>

  <!-- iOS safe-area padding -->
  <div class="h-[env(safe-area-inset-bottom)]"></div>
</div>

<!-- Spacer so body content isn't hidden behind the sticky bar on mobile -->
<div class="h-14 md:hidden"></div>
